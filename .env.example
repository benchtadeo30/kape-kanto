SESSION_SECRET=change-this-to-a-long-random-secret
BASE_URL=https://your-render-service.onrender.com
SQLITECLOUD_URL=sqlitecloud://your-host.sqlite.cloud:8860/your-db.sqlitecloud?apikey=your-api-key

GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
PAYREX_SECRET_KEY=your-payrex-secret-key
PAYREX_PUBLIC_KEY=your-payrex-public-key

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Optional: preferred on hosts where SMTP is blocked/unreachable
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_SECRET_KEY=your-mailjet-secret-key
MAILJET_FROM=Kape Kanto Hub <your-verified-sender@example.com>

