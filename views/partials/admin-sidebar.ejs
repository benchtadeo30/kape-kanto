<style>
    .sidebar { 
        width: 280px; 
        background: #fff; 
        border-right: 1px solid rgba(111, 78, 55, 0.1); 
        display: flex; 
        flex-direction: column; 
        height: 100vh; 
        position: sticky; 
        top: 0; 
        padding: 2.5rem 1.25rem;
        box-shadow: 10px 0 30px rgba(44, 26, 14, 0.02);
    }
    .sidebar h3 { 
        font-size: 0.7rem; 
        text-transform: uppercase; 
        letter-spacing: 2.5px; 
        color: #bca08d; 
        margin-bottom: 2.5rem; 
        font-weight: 800;
        padding-left: 15px;
    }
    .sidebar-nav { display: flex; flex-direction: column; gap: 12px; }
    .sidebar-nav a { 
        display: flex; 
        align-items: center; 
        gap: 16px; 
        padding: 14px 18px; 
        text-decoration: none; 
        color: #5c4033; 
        font-weight: 600; 
        border-radius: 16px; 
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        font-size: 0.95rem;
        position: relative;
    }
    .sidebar-nav a i { 
        font-size: 1.2rem; 
        width: 42px; 
        height: 42px; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        border-radius: 12px;
        background: #fdfaf8;
        color: #8b7355;
        transition: all 0.4s;
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
    }
    .sidebar-nav a:hover { background: #fdfaf8; color: var(--primary); transform: translateX(8px); }
    .sidebar-nav a:hover i { background: #fff; color: var(--primary); box-shadow: 0 8px 20px rgba(111, 78, 55, 0.1); }
    
    .sidebar-nav a.active { 
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); 
        color: white; 
        box-shadow: 0 15px 30px rgba(111, 78, 55, 0.25);
    }
    .sidebar-nav a.active i { 
        background: rgba(255, 255, 255, 0.15); 
        color: white; 
        backdrop-filter: blur(4px);
        box-shadow: none;
    }

    .sidebar-nav a.active::after {
        content: '';
        position: absolute;
        right: -1.25rem;
        top: 50%;
        transform: translateY(-50%);
        width: 5px;
        height: 30px;
        background: var(--primary);
        border-radius: 5px 0 0 5px;
        animation: sidebarLine 0.3s forwards;
    }

    @keyframes sidebarLine {
        from { height: 0; opacity: 0; }
        to { height: 30px; opacity: 1; }
    }
</style>

<aside class="sidebar">
    <h3>Admin Panel</h3>
    <nav class="sidebar-nav">
        <a href="/admin/dashboard" class="<%= activePage === 'dashboard' ? 'active' : '' %>">
            <i class="fa-solid fa-chart-line"></i> Dashboard
        </a>
        <a href="/admin/menu-manage" class="<%= activePage === 'menu' ? 'active' : '' %>">
            <i class="fa-solid fa-utensils"></i> Manage Menu
        </a>
        <a href="/admin/promo-manage" class="<%= activePage === 'promo' ? 'active' : '' %>">
            <i class="fa-solid fa-tags"></i> Manage Promos
        </a>
        <a href="/admin/user-manage" class="<%= activePage === 'user' ? 'active' : '' %>">
            <i class="fa-solid fa-users-gear"></i> Manage Users
        </a>
        <a href="/admin/orders" class="<%= activePage === 'orders' ? 'active' : '' %>">
            <i class="fa-solid fa-clipboard-list"></i> All Orders
        </a>
    </nav>
</aside>
