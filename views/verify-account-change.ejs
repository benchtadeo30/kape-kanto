<%- include('partials/header') %>

<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh; padding: 2rem 5%;">
    <div class="card" style="width: 100%; max-width: 600px; text-align: center; padding: 3rem;">

        <div style="width: 80px; height: 80px; background: rgba(111,78,55,0.1); color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 2rem; font-size: 2rem;">
            <i class="fa-solid fa-shield-halved"></i>
        </div>

        <h1 style="font-size: 2rem; margin-bottom: 0.5rem;" id="verify-title">Verify Your Action</h1>
        <p style="color: var(--text-light); margin-bottom: 2rem;" id="verify-text">
            To ensure your account's security, please verify your identity using the code sent to your email.
        </p>

        <form id="confirm-change-form">
            <!-- OTP Boxes -->
            <div class="otp-inputs" id="otp-inputs" style="display: flex; justify-content: center; gap: 10px; margin-bottom: 2rem;">
                <input type="text" class="otp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" style="width: 50px; height: 60px; text-align: center; font-size: 1.5rem; font-weight: bold; border: 2px solid #eee; border-radius: 12px; outline: none; transition: border-color 0.3s;">
                <input type="text" class="otp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" style="width: 50px; height: 60px; text-align: center; font-size: 1.5rem; font-weight: bold; border: 2px solid #eee; border-radius: 12px; outline: none; transition: border-color 0.3s;">
                <input type="text" class="otp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" style="width: 50px; height: 60px; text-align: center; font-size: 1.5rem; font-weight: bold; border: 2px solid #eee; border-radius: 12px; outline: none; transition: border-color 0.3s;">
                <input type="text" class="otp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" style="width: 50px; height: 60px; text-align: center; font-size: 1.5rem; font-weight: bold; border: 2px solid #eee; border-radius: 12px; outline: none; transition: border-color 0.3s;">
                <input type="text" class="otp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" style="width: 50px; height: 60px; text-align: center; font-size: 1.5rem; font-weight: bold; border: 2px solid #eee; border-radius: 12px; outline: none; transition: border-color 0.3s;">
                <input type="text" class="otp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" style="width: 50px; height: 60px; text-align: center; font-size: 1.5rem; font-weight: bold; border: 2px solid #eee; border-radius: 12px; outline: none; transition: border-color 0.3s;">
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.05rem; border-radius: 50px;" id="confirm-btn">
                <i class="fa-solid fa-check-circle"></i> Confirm Changes
            </button>
        </form>

        <div style="margin-top: 1.8rem;">
            <p style="font-size: 0.9rem; color: var(--text-light); margin-bottom: 0.5rem;">
                Didn't receive the code?
                <a href="#" onclick="resendCode(event)" style="color: var(--primary); font-weight: bold;">Resend Code</a>
            </p>
            <p style="font-size: 0.9rem; color: var(--text-light);">
                <a href="/profile" style="color: var(--danger); text-decoration: underline;">Cancel and go back</a>
            </p>
        </div>
    </div>
</div>

<script>
    const digits = document.querySelectorAll('.otp-digit');
    
    // Auto-focus and numeric logic
    digits.forEach((input, idx) => {
        input.addEventListener('input', (e) => {
            const val = e.target.value.replace(/\D/g, '');
            e.target.value = val;
            if (val) {
                e.target.classList.add('otp-filled');
                if (idx < digits.length - 1) {
                    digits[idx + 1].focus();
                } else {
                    // ALL DIGITS FILLED - Auto-submit!
                    const code = getOtpValue();
                    if (code.length === 6) {
                        document.getElementById('confirm-change-form').dispatchEvent(new Event('submit'));
                    }
                }
            } else {
                e.target.classList.remove('otp-filled');
            }
        });

        input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace' && !e.target.value && idx > 0) {
                digits[idx - 1].focus();
                digits[idx - 1].value = '';
                digits[idx - 1].classList.remove('otp-filled');
            }
        });

        input.addEventListener('paste', (e) => {
            e.preventDefault();
            const pasted = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '').slice(0, 6);
            pasted.split('').forEach((ch, i) => {
                if (digits[i]) {
                    digits[i].value = ch;
                    digits[i].classList.add('otp-filled');
                }
            });
            const nextEmpty = [...digits].findIndex(d => !d.value);
            if (nextEmpty !== -1) {
                digits[nextEmpty].focus();
            } else {
                // ALL DIGITS FILLED via paste - Auto-submit!
                const code = getOtpValue();
                if (code.length === 6) {
                    document.getElementById('confirm-change-form').dispatchEvent(new Event('submit'));
                }
            }
        });
    });

    function getOtpValue() {
        return [...digits].map(d => d.value).join('');
    }

    document.getElementById('confirm-change-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const code = getOtpValue();
        const btn = document.getElementById('confirm-btn');

        if (code.length < 6) return KapeKanto.toast('Please enter the 6-digit code.', 'warning');

        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Applying changes...';

        try {
            const res = await fetch('/api/auth/confirm-account-change', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ code })
            });

            const data = await res.json();
            if (res.ok) {
                KapeKanto.toast(data.message, 'success');
                setTimeout(() => {
                    if (data.deleted) window.location.href = '/';
                    else window.location.href = '/profile';
                }, 1500);
            } else {
                KapeKanto.toast(data.error || 'Invalid code.', 'error');
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-check-circle"></i> Confirm Changes';
            }
        } catch (error) {
            KapeKanto.toast('An error occurred.', 'error');
            btn.disabled = false;
        }
    });

    // Dynamic Text based on type
    const urlParams = new URLSearchParams(window.location.search);
    const type = urlParams.get('type');
    const titleEl = document.getElementById('verify-title');
    const textEl = document.getElementById('verify-text');

    if (type === 'password') {
        titleEl.innerText = 'Verify Password Change';
        textEl.innerText = 'Please enter the code sent to your email to confirm your new password.';
    } else if (type === 'delete') {
        titleEl.innerText = 'Verify Account Deletion';
        titleEl.style.color = 'var(--danger)';
        textEl.innerText = 'This is a permanent action. Enter the code to confirm you want to delete your account.';
    } else if (type === 'remove_email') {
        titleEl.innerText = 'Verify Email Removal';
        textEl.innerText = 'Confirm that you want to remove your email address from this account.';
    } else {
        titleEl.innerText = 'Confirm Profile Changes';
        textEl.innerText = 'Enter the security code we sent to your registered email to save your profile updates.';
    }

    async function resendCode(e) {
        e.preventDefault();
        const link = e.target;
        if (link.style.pointerEvents === 'none') return;

        link.style.pointerEvents = 'none';
        link.innerText = 'Sending...';

        try {
            const res = await fetch('/api/auth/resend-change-code', { method: 'POST' });
            const result = await res.json();
            
            if (res.ok) {
                KapeKanto.toast('A new security code has been sent.', 'success');
            } else {
                KapeKanto.toast(result.error || 'Failed to resend.', 'error');
            }
        } catch (err) {
            KapeKanto.toast('Connection error.', 'error');
        } finally {
            setTimeout(() => {
                link.style.pointerEvents = 'auto';
                link.innerText = 'Resend Code';
            }, 5000);
        }
    }
</script>

<%- include('partials/footer') %>
