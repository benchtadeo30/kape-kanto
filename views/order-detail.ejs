<%- include('partials/header') %>

<style>
/* Order Detail Page Styles */
.od-page { padding: 2rem 5%; max-width: 820px; margin: 0 auto; }

.od-back-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 0.55rem 1.2rem; border-radius: 50px;
    border: 2px solid #e8ddd4; background: #fff;
    color: var(--primary); font-family: var(--font-body);
    font-weight: 600; font-size: 0.9rem; cursor: pointer;
    text-decoration: none; transition: all 0.2s;
    margin-bottom: 1.5rem; display: inline-flex;
}
.od-back-btn:hover { background: var(--primary); border-color: var(--primary); color: #fff; }

.od-card { background:#fff; border-radius:24px; box-shadow:0 8px 30px rgba(44,26,14,0.07); overflow:hidden; border:1px solid rgba(0,0,0,0.04); margin-bottom:1.5rem; }

/* Header */
.od-header { display:flex; justify-content:space-between; align-items:center; padding:1.4rem 1.8rem; border-bottom:1px solid #f5f0eb; flex-wrap:wrap; gap:0.8rem; }
.od-order-id { font-weight:800; font-size:1.1rem; color:var(--primary-dark); }
.od-meta { font-size:0.82rem; color:var(--text-light); margin-top:2px; }
.od-total { font-weight:800; font-size:1.25rem; color:var(--primary); }

/* Status pills */
.od-status-pill { display:inline-flex; align-items:center; gap:6px; padding:5px 14px; border-radius:50px; font-size:0.78rem; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; }
.pill-pending    { background:#fff3e0; color:#e65100; }
.pill-preparing  { background:#fff8e1; color:#f57f17; }
.pill-ready      { background:#e8f5e9; color:#2e7d32; }
.pill-delivery   { background:#e3f2fd; color:#1565c0; }
.pill-completed  { background:#e8f5e9; color:#1b5e20; }
.pill-cancelled  { background:#ffebee; color:#b71c1c; }
.pill-awaiting   { background:#fff3e0; color:#f57c00; border:1px solid #ffe0b2; }

/* Tracker */
.od-tracker { padding:2rem 1.8rem 1.5rem; border-bottom:1px solid #f5f0eb; }
.od-track-heading { font-size:0.9rem; font-weight:700; color:var(--primary-dark); margin-bottom:1.5rem; display:flex; align-items:center; gap:8px; }
.od-track-heading span { font-weight:400; color:var(--text-light); font-size:0.82rem; }
.od-steps { display:flex; align-items:flex-start; justify-content:space-between; position:relative; }
.od-connector { flex:1; height:3px; background:#eee; margin-top:17px; border-radius:99px; position:relative; overflow:hidden; }
.od-connector::after { content:''; position:absolute; inset:0; background:linear-gradient(90deg,var(--primary),var(--accent)); transform:scaleX(0); transform-origin:left; transition:transform 0.6s ease; border-radius:99px; }
.od-connector.done::after { transform:scaleX(1); }
.od-step { display:flex; flex-direction:column; align-items:center; gap:8px; min-width:60px; text-align:center; }
.od-step-circle { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1rem; border:3px solid #e0e0e0; background:#fff; color:#ccc; transition:all 0.4s cubic-bezier(0.34,1.56,0.64,1); position:relative; z-index:1; }
.od-step.completed .od-step-circle { background:linear-gradient(135deg,#5B8C5A,#4a7a49); border-color:#5B8C5A; color:white; box-shadow:0 4px 12px rgba(91,140,90,0.35); transform:scale(1.1); }
.od-step.active .od-step-circle { background:linear-gradient(135deg,var(--primary),var(--accent)); border-color:var(--primary); color:white; box-shadow:0 4px 14px rgba(111,78,55,0.4); transform:scale(1.15); animation:stepPulse 1.8s ease-in-out infinite; }
@keyframes stepPulse { 0%,100%{box-shadow:0 4px 14px rgba(111,78,55,0.4);}50%{box-shadow:0 4px 22px rgba(111,78,55,0.7);} }
.od-step-label { font-size:0.72rem; font-weight:600; color:#bbb; line-height:1.3; max-width:60px; }
.od-step.completed .od-step-label,.od-step.active .od-step-label { color:var(--primary-dark); }

/* Rider card */
.od-rider-card { display:flex; align-items:center; gap:1rem; background:linear-gradient(135deg,#e3f2fd,#bbdefb); border-radius:14px; padding:1rem 1.4rem; margin:1.2rem 1.8rem 0; border:1px solid #90caf9; }
.od-rider-avatar { width:46px; height:46px; border-radius:50%; background:#1565c0; color:white; display:flex; align-items:center; justify-content:center; font-size:1.3rem; flex-shrink:0; }
.od-rider-name { font-weight:700; color:#0d47a1; }
.od-rider-note { font-size:0.8rem; color:#1565c0; margin-top:2px; }

/* Cancelled */
.od-cancelled-banner { background:#ffebee; color:#b71c1c; text-align:center; padding:1rem; font-weight:700; display:flex; align-items:center; justify-content:center; gap:8px; }

/* Awaiting payment */
.od-awaiting-section { padding:1.5rem; text-align:center; border-bottom:1px solid #f5f0eb; background:#fffcf5; }

/* Items list */
.od-items-list { padding:1.2rem 1.8rem; }
.od-item-row { display:flex; align-items:center; gap:1rem; padding:0.75rem 0; border-bottom:1px solid #f5f0eb; }
.od-item-row:last-child { border:none; }
.od-item-img { width:52px; height:52px; border-radius:12px; object-fit:cover; flex-shrink:0; background:#f5ede5; }
.od-item-name { font-weight:600; font-size:0.92rem; color:var(--primary-dark); }
.od-item-custom { font-size:0.79rem; color:var(--text-light); margin-top:2px; }
.od-item-price { margin-left:auto; font-weight:700; color:var(--primary); font-size:0.95rem; flex-shrink:0; }

/* Breakdown */
.od-breakdown { padding:1rem 1.8rem 1.4rem; background:#fdf8f4; border-top:1px solid #f0e8de; }
.od-breakdown-row { display:flex; justify-content:space-between; font-size:0.88rem; color:var(--text-light); padding:0.3rem 0; }
.od-breakdown-row.total { font-weight:800; font-size:1.05rem; color:var(--primary-dark); border-top:1px solid #e0d4c8; margin-top:0.5rem; padding-top:0.7rem; }
.od-breakdown-row.discount { color:var(--danger); }
