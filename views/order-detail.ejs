<div class="od-page">
    <a href="/order-tracking" class="od-back-btn">
        <i class="fa-solid fa-arrow-left"></i> Back to Orders
    </a>

    <div id="order-detail-container">
        <div style="text-align:center;padding:4rem;color:var(--text-light);">
            <i class="fa-solid fa-circle-notch fa-spin" style="font-size:2rem;color:var(--primary);display:block;margin-bottom:1rem;"></i>
            Loading order details…
        </div>
    </div>
</div>

<script>
    const orderId = '<%= orderId %>';

    const STEP_CONFIGS = {
        delivery: [
            { key: 'pending',          icon: 'fa-receipt',       label: 'Order\nPlaced' },
            { key: 'preparing',        icon: 'fa-fire-burner',   label: 'Preparing' },
            { key: 'ready',            icon: 'fa-box-open',      label: 'Ready' },
            { key: 'out_for_delivery', icon: 'fa-motorcycle',    label: 'On the\nWay' },
            { key: 'completed',        icon: 'fa-circle-check',  label: 'Delivered' },
        ],
        pickup: [
            { key: 'pending',    icon: 'fa-receipt',      label: 'Placed' },
            { key: 'preparing',  icon: 'fa-fire-burner',  label: 'Preparing' },
            { key: 'ready',      icon: 'fa-bell',         label: 'Ready for\nPickup' },
            { key: 'completed',  icon: 'fa-circle-check', label: 'Picked Up' },
        ]
    };

    const STATUS_PILL = {
        pending:          ['pill-pending',   'fa-clock',          'Pending'],
        preparing:        ['pill-preparing', 'fa-fire-burner',    'Preparing'],
        ready:            ['pill-ready',     'fa-bell',           'Ready'],
        out_for_delivery: ['pill-delivery',  'fa-motorcycle',     'On the Way'],
        completed:        ['pill-completed', 'fa-circle-check',   'Delivered'],
        cancelled:        ['pill-cancelled', 'fa-circle-xmark',   'Cancelled'],
        awaiting_payment: ['pill-awaiting',  'fa-wallet',         'Awaiting Payment'],
    };

    async function loadOrderDetail() {
        try {
            const res = await fetch(`/api/orders/my/${orderId}`);
            if (!res.ok) throw new Error(res.status);
            const order = await res.json();
            renderDetail(order);
        } catch (e) {
            document.getElementById('order-detail-container').innerHTML = `
                <div class="od-card" style="text-align:center;padding:3rem;color:var(--danger);">
                    <i class="fa-solid fa-circle-exclamation" style="font-size:2rem;margin-bottom:1rem;display:block;"></i>
                    <p>Order not found or access denied.</p>
                    <a href="/order-tracking" class="btn btn-secondary" style="margin-top:1rem;">Back to Orders</a>
                </div>`;
        }
    }

    function renderDetail(order) {
        const isDelivery = order.order_type === 'delivery';
        const steps = STEP_CONFIGS[isDelivery ? 'delivery' : 'pickup'];
        const currentIdx = steps.findIndex(s => s.key === order.status);
        const [pillClass, pillIcon, pillLabel] = STATUS_PILL[order.status] || ['pill-pending','fa-clock','Unknown'];
        const isCancelled = order.status === 'cancelled';
        const isAwaiting = order.status === 'awaiting_payment';
        const canCustomerCancel = order.status === 'pending' && ['pay_at_store', 'cod'].includes(order.payment_method);
        const date = new Date(order.created_at).toLocaleDateString('en-PH', {
            month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit'
        });

        // Tracker HTML
        let trackerHtml = '';
        if (!isCancelled && !isAwaiting) {
            let stepsHtml = '';
            steps.forEach((step, idx) => {
                const isCompleted = idx < currentIdx;
                const isActive = idx === currentIdx;
                const cls = isCompleted ? 'completed' : isActive ? 'active' : '';
                const label = step.label.replace('\n', '<br>');
                stepsHtml += `<div class="od-step ${cls}">
                    <div class="od-step-circle"><i class="fa-solid ${step.icon}"></i></div>
                    <div class="od-step-label">${label}</div>
                </div>`;
                if (idx < steps.length - 1) {
                    stepsHtml += `<div class="od-connector ${isCompleted ? 'done' : ''}"></div>`;
                }
            });
            trackerHtml = `
            <div class="od-tracker">
                <div class="od-track-heading"><i class="fa-solid fa-route" style="color:var(--accent)"></i> Order Progress <span>· Auto-updating every 30s</span></div>
                <div class="od-steps">${stepsHtml}</div>
            </div>`;
        } else if (isAwaiting) {
            trackerHtml = `
            <div class="od-awaiting-section">
                <p style="color:var(--text-light);margin-bottom:1rem;">This order is waiting for payment to be completed.</p>
                <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
                    ${order.payrex_checkout_id ? `<a href="/api/payment/success?order_id=${order.id}" class="btn btn-primary" style="padding:0.5rem 1.5rem;border-radius:50px;font-size:0.85rem;">Check Payment Status</a>` : ''}
                    <button onclick="cancelUnpaidOrder(${order.id})" class="btn btn-secondary" style="padding:0.5rem 1.5rem;border-radius:50px;font-size:0.85rem;">Cancel Order</button>
                </div>
            </div>`;
        }

        // Rider card
        let riderHtml = '';
        if (isDelivery && order.status === 'out_for_delivery') {
            const riderName = order.rider_name || 'Your Rider';
            const riderContact = order.rider_contact || '';
            riderHtml = `
            <div class="od-rider-card">
                <div class="od-rider-avatar"><i class="fa-solid fa-motorcycle"></i></div>
                <div>
                    <div class="od-rider-name"><i class="fa-solid fa-circle-dot" style="color:#4caf50;font-size:0.6rem;margin-right:4px;"></i>${riderName} is on the way!</div>
                    <div class="od-rider-note">${riderContact ? '📞 ' + riderContact : 'Your order is heading to you now'}</div>
                </div>
            </div>`;
        }

        // Items
        const itemsHtml = (order.items || []).map(item => {
            const customText = item.customizations
                ? Object.entries(JSON.parse(item.customizations || '{}')).map(([k,v]) => `${k}: ${v}`).join(' · ')
                : '';
            const itemImg = item.image
                ? (item.image.startsWith('/uploads/') ? item.image : (item.image.startsWith('http') ? item.image : `/uploads/menu/${item.image}`))
                : 'https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&q=80&w=200';
            return `
            <div class="od-item-row">
                <img class="od-item-img" src="${itemImg}" alt="${item.name}"
                    onerror="this.src='https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&q=80&w=200'">
                <div style="flex:1;min-width:0;">
                    <div class="od-item-name">${item.quantity}× ${item.name}</div>
                    ${customText ? `<div class="od-item-custom">${customText}</div>` : ''}
                </div>
                <div class="od-item-price">&#8369;${item.subtotal.toFixed(2)}</div>
            </div>`;
        }).join('');

        // Price breakdown
        const discountRow = order.discount_amount > 0
            ? `<div class="od-breakdown-row discount">
                    <span>${order.discount_type === 'promo' ? '🏷️ Promo Discount' : '🪪 SC/PWD Discount'}</span>
                    <span>-&#8369;${order.discount_amount.toFixed(2)}</span>
               </div>` : '';

        const payLabel = {
            cod: 'Cash on Delivery', online: 'PayRex (Online)', payrex: 'PayRex (Online)',
            pay_at_store: 'Pay at Store', gcash: 'GCash', card: 'Credit/Debit Card'
        }[order.payment_method] || order.payment_method;

        const hasScPwdDiscount = order.sc_discount_amount > 0;
        const regularPromoGrossDiscount = (!hasScPwdDiscount && order.promo_discount_amount > 0)
            ? order.promo_discount_amount * 1.12
            : order.promo_discount_amount;
        const regularPromoVatReduction = regularPromoGrossDiscount - order.promo_discount_amount;

        const cancelledBanner = isCancelled
            ? `<div class="od-cancelled-banner"><i class="fa-solid fa-circle-xmark"></i> This order has been cancelled</div>` : '';

        document.getElementById('order-detail-container').innerHTML = `
        <div class="od-card">
            <!-- Header -->
            <div class="od-header">
                <div>
                    <div class="od-order-id">Order #${order.id}</div>
                    <div class="od-meta">${date} · ${isDelivery ? '🛵 Delivery' : '🏪 Pickup'}</div>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;">
                    <span class="od-status-pill ${pillClass}">
                        <i class="fa-solid ${pillIcon}"></i> ${pillLabel}
                    </span>
                    <span class="od-total">&#8369;${order.total.toFixed(2)}</span>
                </div>
            </div>

            ${cancelledBanner}
            ${trackerHtml}
            ${riderHtml ? `<div style="padding-bottom:1.2rem;">${riderHtml}</div>` : ''}
            ${canCustomerCancel ? `
                <div style="padding:1rem 1.8rem;border-bottom:1px solid #f5f0eb;background:#fffaf4;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
                    <div style="color:var(--text-light);font-size:0.88rem;">
                        <strong style="color:var(--primary-dark);">Made a mistake?</strong> You can cancel while the order is still pending.
                    </div>
                    <button onclick="cancelUnpaidOrder(${order.id})" class="btn btn-danger" style="padding:0.55rem 1.2rem;border-radius:50px;font-size:0.85rem;">
                        <i class="fa-solid fa-ban"></i> Cancel Order
                    </button>
                </div>
            ` : ''}

            <!-- Address / Notes -->
            ${order.delivery_address ? `<div class="od-info-row"><i class="fa-solid fa-location-dot"></i><span><strong>Deliver to:</strong> ${order.delivery_address}</span></div>` : ''}
            ${order.scheduled_date ? `<div class="od-info-row"><i class="fa-solid fa-calendar-check"></i><span><strong>Scheduled:</strong> ${order.scheduled_date}${order.scheduled_time ? ' at ' + order.scheduled_time : ''}</span></div>` : ''}
            ${order.notes ? `<div class="od-info-row" style="padding-bottom:0.5rem;"><i class="fa-solid fa-note-sticky"></i><span><strong>Notes:</strong> ${order.notes}</span></div>` : ''}

            <!-- Items -->
            <div class="od-items-list">${itemsHtml}</div>

            <!-- Price Breakdown -->
            <div class="od-breakdown">
                <div class="od-breakdown-row"><span>Subtotal (Gross)</span><span>&#8369;${order.subtotal.toFixed(2)}</span></div>
                
                ${order.sc_discount_amount > 0 ? `
                    <div class="od-breakdown-row discount">
                        <span>VAT-Exempt Discount (12%)</span>
                        <span>-&#8369;${(order.subtotal - (order.subtotal / 1.12)).toFixed(2)}</span>
                    </div>
                    <div class="od-breakdown-row discount">
                        <span>${order.discount_type === 'senior' ? 'Senior Citizen' : 'PWD'} Disc (20%)</span>
                        <span>-&#8369;${order.sc_discount_amount.toFixed(2)}</span>
                    </div>
                ` : ''}

                ${order.promo_discount_amount > 0 && hasScPwdDiscount ? `
                    <div class="od-breakdown-row discount">
                        <span>🏷️ Promo/Coupon Discount</span>
                        <span>-&#8369;${order.promo_discount_amount.toFixed(2)}</span>
                    </div>
                ` : ''}


                ${order.promo_discount_amount > 0 && !hasScPwdDiscount ? `
                    <div class="od-breakdown-row discount">
                        <span>Promo/Coupon Discount</span>
                        <span>-PHP ${order.promo_discount_amount.toFixed(2)}</span>
                    </div>
                    <div class="od-breakdown-row discount">
                        <span>VAT Reduction from Promo</span>
                        <span>-PHP ${regularPromoVatReduction.toFixed(2)}</span>
                    </div>
                ` : ''}
                <div class="od-breakdown-row"><span>Delivery Fee</span><span>&#8369;${(order.delivery_fee || 0).toFixed(2)}</span></div>
                <div class="od-breakdown-row total"><span>Total Amount Due</span><span>&#8369;${order.total.toFixed(2)}</span></div>
                
                <div class="od-breakdown-row" style="margin-top:0.6rem;border-top:1px dashed #e0d4c8;padding-top:0.6rem;">
                    <span>💳 Payment Method</span><span><strong>${payLabel}</strong></span>
                </div>
            </div>
        </div>
        
        <div class="od-chat">
            <div class="od-chat-header"><i class="fa-solid fa-comments" style="color:var(--primary)"></i> Order Support Chat</div>
            <div id="od-chat-messages" class="od-chat-messages">
                <div style="text-align:center; color:var(--text-light); font-size:0.85rem; padding:1rem;">Loading messages...</div>
            </div>
            <form id="od-chat-form" class="od-chat-input-area" onsubmit="sendChatMessage(event)">
                <input type="text" id="od-chat-input" class="od-chat-input" placeholder="Type a message to staff..." autocomplete="off" required>
                <button type="submit" class="od-chat-send"><i class="fa-solid fa-paper-plane"></i></button>
            </form>
        </div>`;

        // Auto-refresh every 30s for active orders
        if (!isCancelled && !['completed'].includes(order.status)) {
            if (!window.orderRefreshInterval) {
                window.orderRefreshInterval = setInterval(loadOrderDetail, 30000);
            }
        }
        
        loadChatMessages();
        if (!window.chatRefreshInterval) {
            window.chatRefreshInterval = setInterval(loadChatMessages, 10000);
        }
    }

    async function cancelUnpaidOrder(orderId) {
        showConfirm('Are you sure you want to cancel this order?', async () => {
            try {
                const res = await fetch(`/api/orders/my/${orderId}/cancel`, { method: 'POST' });
                if (res.ok) {
                    KapeKanto.toast('Order cancelled.', 'success');
                    loadOrderDetail();
                } else {
                    KapeKanto.toast('Failed to cancel order.', 'error');
                }
            } catch (e) {
                KapeKanto.toast('Error cancelling order.', 'error');
            }
        }, { title: 'Cancel Order', confirmText: 'Yes, Cancel', cancelText: 'Keep Order', type: 'danger' });
    }

    async function loadChatMessages() {
        try {
            const res = await fetch(`/api/orders/${orderId}/messages`);
            if (!res.ok) return;
            const messages = await res.json();
            const container = document.getElementById('od-chat-messages');
            if (!container) return;
            
            if (!messages.length) {
                container.innerHTML = '<div style="text-align:center; color:var(--text-light); font-size:0.85rem; padding:1rem;">No messages yet. Send a message if you need help with your order.</div>';
                return;
            }

            const currentScroll = container.scrollTop;
            const isAtBottom = container.scrollHeight - container.scrollTop <= container.clientHeight + 50;

            container.innerHTML = messages.map(m => {
                const isCustomer = m.role === 'customer';
                const time = new Date(m.created_at).toLocaleTimeString('en-PH', { hour: '2-digit', minute: '2-digit' });
                const senderName = isCustomer ? 'You' : 'Staff';
                return `
                <div class="od-chat-msg ${isCustomer ? 'customer' : 'staff'}">
                    <div>${m.message}</div>
                    <div class="od-chat-meta">${senderName} · ${time}</div>
                </div>`;
            }).join('');

            if (isAtBottom) {
                container.scrollTop = container.scrollHeight;
            }
        } catch (e) {
            console.error('Failed to load messages');
        }
    }

    async function sendChatMessage(e) {
        e.preventDefault();
        const input = document.getElementById('od-chat-input');
        const message = input.value.trim();
        if (!message) return;

        input.value = '';
        input.disabled = true;

        try {
            const res = await fetch(`/api/orders/${orderId}/messages`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message })
            });
            if (res.ok) {
                await loadChatMessages();
                const container = document.getElementById('od-chat-messages');
                container.scrollTop = container.scrollHeight;
            } else {
                KapeKanto.toast('Failed to send message', 'error');
            }
        } catch (e) {
            KapeKanto.toast('Error sending message', 'error');
        } finally {
            input.disabled = false;
            input.focus();
        }
    }

    document.addEventListener('DOMContentLoaded', loadOrderDetail);
</script>

<%- include('partials/footer') %>
