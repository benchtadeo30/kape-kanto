<%- include('partials/header') %>
<!-- VERIFICATION_STAMP_CAFE_PROJECT_ACTIVE -->

    <!-- ══ INTRO LOADING SCREEN ══════════════════════════ -->
    <div id="kk-intro" aria-hidden="true">
        <!-- Floating beans background -->
        <div class="intro-beans" id="introBeans"></div>

        <!-- Steam above cup -->
        <div class="intro-steam">
            <span></span><span></span><span></span>
        </div>

        <!-- Coffee cup icon -->
        <div class="intro-cup">
            <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Cup body -->
                <path d="M15 35 L22 78 Q22 82 28 82 L72 82 Q78 82 78 78 L85 35 Z" fill="#E8B86D" opacity="0.95" />
                <!-- Cup shine -->
                <path d="M28 40 Q32 38 36 41" stroke="rgba(255,255,255,0.5)" stroke-width="2" stroke-linecap="round" />
                <!-- Saucer -->
                <ellipse cx="50" cy="86" rx="40" ry="5" fill="#D4A574" opacity="0.7" />
                <!-- Handle -->
                <path d="M78 45 Q98 45 98 60 Q98 75 78 75" stroke="#E8B86D" stroke-width="5" fill="none"
                    stroke-linecap="round" />
                <!-- Coffee liquid -->
                <ellipse cx="50" cy="50" rx="28" ry="6" fill="#6F4E37" opacity="0.6" />
                <!-- Foam swirl -->
                <path d="M35 50 Q50 44 65 50" stroke="rgba(255,255,255,0.35)" stroke-width="2" fill="none"
                    stroke-linecap="round" />
            </svg>
        </div>

        <!-- Brand -->
        <div class="intro-brand">
            <h1>Kape Kanto Hub</h1>
            <p>Brewing moments, one cup at a time</p>
        </div>

        <!-- Loading bar -->
        <div class="intro-bar-wrap">
            <div class="intro-bar"></div>
        </div>
    </div>
    <!-- ════════════════════════════════════════════════ -->

    <!-- Hero Carousel -->
    <section class="carousel-container">
        <!-- Static fallback / First Slide -->
        <div class="carousel-slide active"
            style="background-image: url('https://images.unsplash.com/photo-1554118811-1e0d58224f24?auto=format&fit=crop&q=80&w=1600');">
            <div class="carousel-overlay"></div>
            <div class="carousel-content">
                <h2>Welcome to Kape Kanto Hub</h2>
                <p>Experience the finest coffee and warmest ambiance in the neighborhood.</p>
                <a href="/menu" class="btn btn-primary">Explore Menu</a>
            </div>
        </div>

        <!-- Ambiance / Featured Items (Static or Dynamic) -->
        <div class="carousel-slide"
            style="background-image: url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&q=80&w=1600');">
            <div class="carousel-overlay"></div>
            <div class="carousel-content">
                <h2>Aesthetic Café Vibes</h2>
                <p>The perfect spot for your morning brew or afternoon study session.</p>
                <a href="#our-story" class="btn btn-primary" onclick="smoothScrollTo('our-story');">Our Story</a>
            </div>
        </div>

        <!-- Active Promos (Dynamic) -->
        <% const carouselPromos = (typeof activePromos !=='undefined' && activePromos.length > 0) ? activePromos.slice(0, 5) : []; %>
        <% if (carouselPromos.length > 0) { %>
            <% carouselPromos.forEach(function(promo) { %>
                <% const promoImg=promo.image
                    || 'https://images.unsplash.com/photo-1497935586351-b67a49e012bf?auto=format&fit=crop&q=80&w=1600' ;
                    let isUpcomingCarousel=false; const nowCarousel=new Date(); if (promo.start_date) { const
                    startDate=new Date(promo.start_date); if (startDate> nowCarousel) isUpcomingCarousel = true;
                    }
                    %>
                    <div class="carousel-slide" style="background-image: url('<%= promoImg %>');">
                        <div class="carousel-overlay"></div>
                        <div class="carousel-content">
                            <h2>
                                <%= promo.title %>
                            </h2>
                            <p>
                                <%= promo.description %>
                            </p>
                            <p style="font-size: 1.5rem; font-weight: bold; color: var(--accent); margin-bottom: 2rem;">
                                <% if (promo.event_type==='promo' ) { %>
                                    Get <%= promo.discount_percent %>% OFF! Code:
                                        <% if (isUpcomingCarousel) { %>
                                            <span
                                                style="filter: blur(10px); user-select: none; opacity: 0.6; letter-spacing: 2px;"
                                                title="Reveals when event starts">
                                                ••••••
                                            </span>
                                            <% } else { %>
                                                <%= promo.promo_code || 'N/A' %>
                                                    <% } %>
                                                        <% } else { %>
                                                            Loyalty Challenge: <%= promo.title %>
                                                                <% } %>
                            </p>
                            <a href="<%= (promo.event_type === 'promo' && !isUpcomingCarousel) ? '/cart' : '/profile' %>"
                                class="btn btn-primary">
                                <%= isUpcomingCarousel ? 'Learn More' : (promo.event_type==='promo' ? 'Get the Deal'
                                    : 'Start Task' ) %>
                            </a>
                        </div>
                    </div>
                    <% }); %>
                        <% } %>

                            <div class="carousel-controls">
                                <!-- Dots injected by JS -->
                            </div>
    </section>

    <!-- About Section -->
    <section id="our-story" style="padding: 5rem 5%; background-color: white;">
        <div class="about-grid" style="max-width: 1200px; margin: 0 auto; gap: 4rem; align-items: center;">
          <div class="reveal-left about-img-wrap">
            <img src="https://images.unsplash.com/photo-1442512595331-e89e73853f31?auto=format&fit=crop&q=80&w=800"
                 alt="Cafe Ambiance"
                 style="width: 100%; border-radius: 20px; box-shadow: 20px 20px 0 var(--secondary);">
          </div>
          <div class="reveal-right about-content">
            <h2 style="font-size: 2.5rem; margin-bottom: 1.5rem;">Our Story</h2>
            <p style="margin-bottom: 1.5rem; color: var(--text-light);">
              Kape Kanto Hub started with a simple dream: to bring premium coffee culture to every neighborhood
              corner. "Kanto" represents the heart of the community—the meeting place where stories are shared and
              friendships are brewed.
            </p>
            <p style="margin-bottom: 2rem; color: var(--text-light);">
              We source the finest beans and bake our pastries fresh every morning to ensure every visit feels
              like coming home. Whether you're here for a quick espresso or a long afternoon with a book, you're
              always welcome at the Kanto.
            </p>
            <a href="/menu" class="btn btn-secondary" onclick="smoothScrollTo('best-sellers-grid');">See What's
                Brewing</a>
          </div>
        </div>
    </section>

    <!-- Featured Menu Items -->
    <section style="padding: 4rem 5%; background-color: var(--bg-main);">
        <h2 class="section-title reveal">Featured Items</h2>
        <div class="grid-container stagger-children" id="featured-items-grid">
            <% if (typeof featuredItems !=='undefined' && featuredItems.length> 0) { %>
                <% featuredItems.forEach(function(item) { %>
                    <div class="menu-card" onclick="openItemDetails('<%= item.id %>')" style="cursor:pointer;">
                        <% 
                            let imgUrl;
                            if (item.image) {
                                imgUrl = item.image.startsWith('http') ? item.image :
                                    (item.image.startsWith('/uploads/') ? item.image : `/uploads/menu/${item.image}`);
                            } else {
                                const fallbackText = `${(item.name || '').toLowerCase()} ${(item.category_name || '').toLowerCase()}`;
                                if (/(iced|cold|spanish latte|cappuccino|americano|espresso)/.test(fallbackText)) {
                                    imgUrl = 'https://images.unsplash.com/photo-1517701550927-30cf4ba1f63f?auto=format&fit=crop&q=80&w=900';
                                } else if (/(frappe|blended)/.test(fallbackText)) {
                                    imgUrl = 'https://images.unsplash.com/photo-1572490122747-3968b75cc699?auto=format&fit=crop&q=80&w=900';
                                } else if (/(latte|mocha|macchiato)/.test(fallbackText)) {
                                    imgUrl = 'https://images.unsplash.com/photo-1461023058943-07fcbe16d735?auto=format&fit=crop&q=80&w=900';
                                } else if (/(milkshake|shake)/.test(fallbackText)) {
                                    imgUrl = 'https://images.unsplash.com/photo-1577805947697-89e18249d767?auto=format&fit=crop&q=80&w=900';
                                } else if (/(pastry|croissant|muffin|bread|cake|cookie|donut)/.test(fallbackText)) {
                                    imgUrl = 'https://images.unsplash.com/photo-1483695028939-5bb13f8648b0?auto=format&fit=crop&q=80&w=900';
                                } else if (/(meal|rice|pasta|sandwich|burger|silog|ulam)/.test(fallbackText)) {
                                    imgUrl = 'https://images.unsplash.com/photo-1515003197210-e0cd71810b5f?auto=format&fit=crop&q=80&w=900';
                                } else if (/(coffee|hot)/.test(fallbackText)) {
                                    imgUrl = 'https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&q=80&w=900';
                                } else {
                                    imgUrl = 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&q=80&w=900';
                                }
                            }
                        %>
                            <div style="position: relative;">
                                <img src="<%= imgUrl %>" alt="<%= item.name %>" class="menu-image">
                                <span class="badge badge-primary"
                                    style="position: absolute; top: 10px; right: 10px;">Popular Choice</span>
                            </div>
                            <div class="menu-details">
                                <h3 class="menu-name">
                                    <%= item.name %>
                                </h3>
                                <p
                                    style="font-size: 0.85rem; color: var(--text-light); margin-bottom: 0.5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    <%= item.description || 'Specially crafted for the best experience.' %>
                                </p>
                                <p class="menu-price">₱<%= item.price.toFixed(2) %>
                                </p>
                            </div>
                    </div>
                    <% }); %>
                        <% } %>
        </div>

        <!-- Product Details Container (Simplified Modal) -->
        <div id="item-details-container"
            style="display:none; margin-top: 2rem; padding: 2rem; background: white; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border: 1px solid #eee;">
            <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 2rem;">
                <div style="position: relative;">
                    <img id="detailImage" src=""
                        style="width: 100%; height: 350px; object-fit: cover; border-radius: 15px;">
                    <button onclick="closeItemDetails()"
                        style="position: absolute; top: 10px; left: 10px; background: white; border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer; box-shadow: 0 4px 10px rgba(0,0,0,0.1);"><i
                            class="fa-solid fa-arrow-left"></i></button>
                </div>
                <div>
                    <h2 id="detailTitle" style="font-size: 2rem; margin-bottom: 0.5rem; color: var(--primary-dark);">
                    </h2>
                    <p id="detailDescription"
                        style="color: var(--text-light); margin-bottom: 1.5rem; line-height: 1.6;"></p>

                    <div id="detailOptions" style="margin-bottom: 2rem;">
                        <!-- Options loaded via JS -->
                    </div>

                    <div
                        style="display: flex; align-items: center; justify-content: space-between; padding-top: 1.5rem; border-top: 1px solid #eee;">
                        <div>
                            <span
                                style="font-size: 0.8rem; text-transform: uppercase; color: var(--text-light); display: block;">Total
                                Price</span>
                            <span style="font-size: 1.5rem; font-weight: bold; color: var(--primary);">₱<span
                                    id="detailTotalPrice">0.00</span></span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 1rem;">
                            <div
                                style="display: flex; align-items: center; background: #f8f8f8; border-radius: 10px; padding: 5px;">
                                <button onclick="changeDetailQty(-1)"
                                    style="border: none; background: none; padding: 10px; cursor: pointer;"><i
                                        class="fa-solid fa-minus"></i></button>
                                <input type="number" id="detailQty" value="1" readonly
                                    style="width: 40px; text-align: center; border: none; background: none; font-weight: bold;">
                                <button onclick="changeDetailQty(1)"
                                    style="border: none; background: none; padding: 10px; cursor: pointer;"><i
                                        class="fa-solid fa-plus"></i></button>
                            </div>
                            <button id="detailAddBtn" class="btn btn-primary"
                                style="height: 50px; padding: 0 2rem; font-weight: bold;">Add to Cart</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div style="text-align: center; margin-top: 2rem;">
            <a href="/menu" class="btn btn-secondary">View Full Menu</a>
        </div>
    </section>

    <!-- Gallery Modal -->
    <div id="gallery-modal"
        style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:2000;align-items:center;justify-content:center;padding:1rem;">
        <div style="max-width:900px;width:100%;position:relative;">
            <button onclick="document.getElementById('gallery-modal').style.display='none'"
                style="position:absolute;top:-45px;right:0;background:rgba(255,255,255,0.15);border:none;color:white;font-size:1.5rem;width:40px;height:40px;border-radius:50%;cursor:pointer;">&times;</button>
            <div
                style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.5rem;border-radius:16px;overflow:hidden;">
                <img src="https://images.unsplash.com/photo-1554118811-1e0d58224f24?auto=format&fit=crop&q=80&w=500"
                    style="width:100%;aspect-ratio:1;object-fit:cover;" alt="Café 1">
                <img src="https://images.unsplash.com/photo-1442512595331-e89e73853f31?auto=format&fit=crop&q=80&w=500"
                    style="width:100%;aspect-ratio:1;object-fit:cover;" alt="Café 2">
                <img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&q=80&w=500"
                    style="width:100%;aspect-ratio:1;object-fit:cover;" alt="Café 3">
                <img src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&q=80&w=500"
                    style="width:100%;aspect-ratio:1;object-fit:cover;" alt="Café 4">
                <img src="https://images.unsplash.com/photo-1561047029-3000c68339ca?auto=format&fit=crop&q=80&w=500"
                    style="width:100%;aspect-ratio:1;object-fit:cover;" alt="Café 5">
                <img src="https://images.unsplash.com/photo-1572490122747-3968b75cc699?auto=format&fit=crop&q=80&w=500"
                    style="width:100%;aspect-ratio:1;object-fit:cover;" alt="Café 6">
            </div>
            <p style="text-align:center;color:rgba(255,255,255,0.6);margin-top:1rem;font-size:0.85rem;">Our cozy café
                space — visit us anytime!</p>
        </div>
    </div>

    <!-- Limited Time Promos with Countdown -->
    <section class="events-section" style="background: linear-gradient(135deg, var(--bg-dark) 0%, #1a1a1a 50%, var(--bg-dark) 100%); color: white; position: relative; overflow: hidden;">
        <!-- Background Pattern -->
        <div style="position: absolute; inset: 0; opacity: 0.03; background-image: radial-gradient(circle at 25% 25%, var(--accent) 2px, transparent 2px), radial-gradient(circle at 75% 75%, var(--primary) 1px, transparent 1px); background-size: 50px 50px;"></div>

        <div style="position: relative; z-index: 1;">
            <h2 class="section-title reveal" style="color: white; margin-bottom: 1rem; text-shadow: 0 2px 10px rgba(0,0,0,0.3);">Limited Time Events</h2>
            <p class="reveal"
                style="text-align: center; color: rgba(255,255,255,0.7); margin-bottom: 4rem; max-width: 700px; margin-left: auto; margin-right: auto; font-size: 1.1rem; line-height: 1.6;">
                Don't miss out on our exclusive seasonal offers and community rewards. These deals are only here for a
                limited time!
            </p>
            <div class="grid-container stagger-children event-grid" id="event-grid">
                <!-- Dynamically loaded via fetchEventPage -->
                <div style="grid-column: 1/-1; text-align: center; padding: 3rem;">
                    <i class="fa-solid fa-circle-notch fa-spin" style="font-size: 2rem; color: var(--primary); opacity: 0.5;"></i>
                    <p style="margin-top: 1rem; color: rgba(255,255,255,0.5);">Loading events...</p>
                </div>
            </div>

        <!-- Event Pagination Controls -->
        <div id="event-pagination" style="justify-content: center; align-items: center; gap: 1rem; margin-top: 3rem; display: none;">
            <button class="btn btn-outline" id="event-prev" onclick="changeEventPage(-1)" style="width: 40px; height: 40px; padding: 0; display: flex; align-items: center; justify-content: center; border-radius: 50%;">
                <i class="fa-solid fa-chevron-left"></i>
            </button>
            <div id="event-page-numbers" style="display: flex; gap: 0.5rem; align-items: center;"></div>
            <button class="btn btn-outline" id="event-next" onclick="changeEventPage(1)" style="width: 40px; height: 40px; padding: 0; display: flex; align-items: center; justify-content: center; border-radius: 50%;">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
        </div>
    </section>

    <script>
        let allMenuItems = [];
        let currentDetailItem = null;

        async function loadFeaturedItems() {
            try {
                const res = await fetch('/api/menu');
                if (res.ok) {
                    allMenuItems = await res.json();
                }
            } catch (e) {
                console.error('Failed to load menu items', e);
            }
        }

        async function openItemDetails(id) {
            if (allMenuItems.length === 0) await loadFeaturedItems();
            currentDetailItem = allMenuItems.find(i => i.id === id);
            if (!currentDetailItem) return;

            document.getElementById('featured-items-grid').style.display = 'none';
            // Also hide the "View All Menu" button to make it cleaner
            const viewAllBtn = document.querySelector('a[href="/menu"].btn-secondary');
            if (viewAllBtn && viewAllBtn.parentElement) viewAllBtn.parentElement.style.display = 'none';

            document.getElementById('item-details-container').style.display = 'block';

            const img = document.getElementById('detailImage');
            const title = document.getElementById('detailTitle');
            const desc = document.getElementById('detailDescription');
            const optionsBox = document.getElementById('detailOptions');
            const addBtn = document.getElementById('detailAddBtn');
            const qtyInput = document.getElementById('detailQty');

            const detailFallbackText = `${(currentDetailItem.name || '').toLowerCase()} ${(currentDetailItem.category_name || '').toLowerCase()}`;
            let detailFallbackImg = 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&q=80&w=900';
            if (/(iced|cold|spanish latte|cappuccino|americano|espresso)/.test(detailFallbackText)) {
                detailFallbackImg = 'https://images.unsplash.com/photo-1517701550927-30cf4ba1f63f?auto=format&fit=crop&q=80&w=900';
            } else if (/(frappe|blended)/.test(detailFallbackText)) {
                detailFallbackImg = 'https://images.unsplash.com/photo-1572490122747-3968b75cc699?auto=format&fit=crop&q=80&w=900';
            } else if (/(latte|mocha|macchiato)/.test(detailFallbackText)) {
                detailFallbackImg = 'https://images.unsplash.com/photo-1461023058943-07fcbe16d735?auto=format&fit=crop&q=80&w=900';
            } else if (/(milkshake|shake)/.test(detailFallbackText)) {
                detailFallbackImg = 'https://images.unsplash.com/photo-1577805947697-89e18249d767?auto=format&fit=crop&q=80&w=900';
            } else if (/(pastry|croissant|muffin|bread|cake|cookie|donut)/.test(detailFallbackText)) {
                detailFallbackImg = 'https://images.unsplash.com/photo-1483695028939-5bb13f8648b0?auto=format&fit=crop&q=80&w=900';
            } else if (/(meal|rice|pasta|sandwich|burger|silog|ulam)/.test(detailFallbackText)) {
                detailFallbackImg = 'https://images.unsplash.com/photo-1515003197210-e0cd71810b5f?auto=format&fit=crop&q=80&w=900';
            } else if (/(coffee|hot)/.test(detailFallbackText)) {
                detailFallbackImg = 'https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&q=80&w=900';
            }

            img.src = currentDetailItem.image
                ? (currentDetailItem.image.startsWith('http') ? currentDetailItem.image : `/uploads/menu/${currentDetailItem.image}`)
                : detailFallbackImg;
            title.innerText = currentDetailItem.name;
            desc.innerText = currentDetailItem.description || 'Mas Langhap Sarap!';
            qtyInput.value = 1;

            optionsBox.innerHTML = '<p style="color: var(--text-light);">Loading options...</p>';

            const isAvailable = currentDetailItem.is_available === 1 && currentDetailItem.stock > 0;
            addBtn.disabled = !isAvailable;
            updateDetailTotalPrice();

            try {
                const res = await fetch(`/api/menu/${id}/options`);
                if (res.ok) {
                    const options = await res.json();
                    renderDetailOptions(options);
                } else {
                    optionsBox.innerHTML = '';
                }
            } catch (e) {
                console.error('Failed to load options', e);
                optionsBox.innerHTML = '';
            }
        }

        function renderDetailOptions(options) {
            const container = document.getElementById('detailOptions');
            container.innerHTML = '';

            if (options.length === 0) return;

            options.forEach(opt => {
                let choicesHtml = '';
                opt.choices.forEach((choice, idx) => {
                    const priceAdj = choice.price_adjustment || 0;
                    const extraPriceDisplay = priceAdj > 0 ? `<span style="color: var(--text-dark); font-size: 0.9rem;">+ ₱${priceAdj.toFixed(2)}</span>` : '';
                    choicesHtml += `
                    <label style="display: flex; justify-content: space-between; align-items: center; padding: 12px 0; cursor: pointer; user-select: none;">
                        <div style="display: flex; align-items: center; gap: 15px;">
                            <input type="radio" name="detail_opt_${opt.id}" value="${choice.id}" data-price="${priceAdj}" ${idx === 0 ? 'checked' : ''} onchange="updateDetailTotalPrice()" style="width: 20px; height: 20px; accent-color: var(--primary); cursor: pointer;">
                            <span style="font-size: 0.95rem; color: var(--text-dark);">${choice.name}</span>
                        </div>
                        ${extraPriceDisplay}
                    </label>
                `;
                });

                container.innerHTML += `
                <div style="margin-bottom: 25px;">
                    <h3 style="font-size: 1.1rem; margin-bottom: 5px; color: var(--text-dark);">${opt.name}<span style="color: var(--primary);">*</span></h3>
                    <p style="font-size: 0.8rem; color: var(--text-light); margin-bottom: 10px;">Select 1 option</p>
                    <div style="display: flex; flex-direction: column;">
                        ${choicesHtml}
                    </div>
                </div>
            `;
            });
            updateDetailTotalPrice();
        }

        function updateDetailTotalPrice() {
            if (!currentDetailItem) return;

            let basePrice = currentDetailItem.price;
            let extraPrice = 0;

            // Add up selected options
            document.querySelectorAll('#detailOptions input[type="radio"]:checked').forEach(radio => {
                extraPrice += parseFloat(radio.dataset.price || 0);
            });

            const qty = parseInt(document.getElementById('detailQty').value) || 1;
            const total = (basePrice + extraPrice) * qty;

            const user = window.KapeKantoUser || { role: 'guest', isVerified: 0 };
            const isAvailable = currentDetailItem.is_available === 1 && currentDetailItem.stock > 0;
            const btn = document.getElementById('detailAddBtn');

            document.getElementById('detailTotalPrice').innerText = total.toFixed(2);

            if (user.role === 'guest') {
                btn.innerHTML = `Login to Order`;
                btn.disabled = true;
                btn.style.opacity = '0.6';
            } else if (user.role === 'customer' && user.isVerified != 1) {
                btn.innerHTML = `Verify Email`;
                btn.disabled = true;
                btn.style.opacity = '0.6';
            } else if (!isAvailable) {
                btn.innerHTML = `Out of Stock`;
                btn.disabled = true;
                btn.style.opacity = '0.6';
            } else {
                btn.innerHTML = `Add to Cart`;
                btn.disabled = false;
                btn.style.opacity = '1';
            }
        }

        function closeItemDetails() {
            document.getElementById('item-details-container').style.display = 'none';
            document.getElementById('featured-items-grid').style.display = 'grid';
            const viewAllBtn = document.querySelector('a[href="/menu"].btn-secondary');
            if (viewAllBtn && viewAllBtn.parentElement) viewAllBtn.parentElement.style.display = 'block';
            window.scrollTo({
                top: document.getElementById('featured-items-grid').offsetTop - 100,
                behavior: 'smooth'
            });
        }

        function changeDetailQty(amt) {
            const input = document.getElementById('detailQty');
            let val = parseInt(input.value) + amt;
            if (val < 1) val = 1;
            input.value = val;
            updateDetailTotalPrice();
        }

        document.getElementById('detailAddBtn')?.addEventListener('click', () => {
            if (!currentDetailItem) return;

            const qty = parseInt(document.getElementById('detailQty').value);
            const customizations = {};
            let extraPriceTotal = 0;

            document.querySelectorAll('#detailOptions input[type="radio"]:checked').forEach(radio => {
                // Find the option group title by navigating up DOM
                const groupDiv = radio.closest('div').parentElement.parentElement;
                const title = groupDiv.querySelector('h3').innerText.replace('*', '');

                // Find the label text (choice name)
                const choiceName = radio.nextElementSibling.innerText;
                const extraPrice = parseFloat(radio.dataset.price || 0);

                customizations[title] = choiceName;
                extraPriceTotal += extraPrice;
            });

            const fallbackText = `${(currentDetailItem.name || '').toLowerCase()} ${(currentDetailItem.category_name || '').toLowerCase()}`;
            let fallbackImg = 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&q=80&w=900';
            if (/(iced|cold|spanish latte|cappuccino|americano|espresso)/.test(fallbackText)) {
                fallbackImg = 'https://images.unsplash.com/photo-1517701550927-30cf4ba1f63f?auto=format&fit=crop&q=80&w=900';
            } else if (/(frappe|blended)/.test(fallbackText)) {
                fallbackImg = 'https://images.unsplash.com/photo-1572490122747-3968b75cc699?auto=format&fit=crop&q=80&w=900';
            } else if (/(latte|mocha|macchiato)/.test(fallbackText)) {
                fallbackImg = 'https://images.unsplash.com/photo-1461023058943-07fcbe16d735?auto=format&fit=crop&q=80&w=900';
            } else if (/(milkshake|shake)/.test(fallbackText)) {
                fallbackImg = 'https://images.unsplash.com/photo-1577805947697-89e18249d767?auto=format&fit=crop&q=80&w=900';
            } else if (/(pastry|croissant|muffin|bread|cake|cookie|donut)/.test(fallbackText)) {
                fallbackImg = 'https://images.unsplash.com/photo-1483695028939-5bb13f8648b0?auto=format&fit=crop&q=80&w=900';
            } else if (/(meal|rice|pasta|sandwich|burger|silog|ulam)/.test(fallbackText)) {
                fallbackImg = 'https://images.unsplash.com/photo-1515003197210-e0cd71810b5f?auto=format&fit=crop&q=80&w=900';
            } else if (/(coffee|hot)/.test(fallbackText)) {
                fallbackImg = 'https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&q=80&w=900';
            }

            const imgUrl = currentDetailItem.image
                ? (currentDetailItem.image.startsWith('http') ? currentDetailItem.image : `/uploads/menu/${currentDetailItem.image}`)
                : fallbackImg;

            const cart = KapeKanto.getCart();
            const existing = cart.find(item =>
                item.id === currentDetailItem.id &&
                JSON.stringify(item.customizations) === JSON.stringify(customizations)
            );

            if (existing) {
                existing.quantity += qty;
            } else {
                cart.push({
                    id: currentDetailItem.id,
                    name: currentDetailItem.name,
                    category_id: currentDetailItem.category_id,
                    price: currentDetailItem.price + extraPriceTotal,
                    image: imgUrl,
                    quantity: qty,
                    customizations: customizations
                });
            }

            KapeKanto.saveCart(cart);
            KapeKanto.toast(`${currentDetailItem.name} added to cart!`);
            closeItemDetails();
        });

        document.addEventListener('DOMContentLoaded', loadFeaturedItems);

        // Countdown Timer Logic

        function updateCountdowns() {
            const timers = document.querySelectorAll('.countdown');
            timers.forEach(timer => {
                const targetDate = new Date(timer.dataset.target).getTime();
                const isUpcoming = timer.dataset.isUpcoming === 'true';
                const now = new Date().getTime();
                const diff = targetDate - now;

                if (diff > 0) {
                    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((diff % (1000 * 60)) / 1000);

                    timer.querySelector('.days').innerText = days.toString().padStart(2, '0');
                    timer.querySelector('.hours').innerText = hours.toString().padStart(2, '0');
                    timer.querySelector('.minutes').innerText = minutes.toString().padStart(2, '0');
                    timer.querySelector('.seconds').innerText = seconds.toString().padStart(2, '0');
                } else {
                    } else {
                        if (!isUpcoming) {
                            const card = timer.closest('.event-card');
                            if (card) {
                                card.style.opacity = '0';
                                card.style.transform = 'scale(0.9)';
                                setTimeout(() => card.remove(), 500);
                            }
                        } else {
                            location.reload();
                        }
                    }
                }
            });
        }

        setInterval(updateCountdowns, 1000);
        updateCountdowns();

        // Event Pagination Logic
        let currentEventPage = 1;
        const eventsPerPage = 6;
        let totalEventPages = Math.ceil(<%= typeof activePromos !== 'undefined' ? activePromos.length : 0 %> / eventsPerPage);

        async function fetchEventPage(page) {
            const grid = document.getElementById('event-grid');
            const offset = (page - 1) * eventsPerPage;
            
            // Add loading state
            grid.style.opacity = '0.5';
            grid.style.pointerEvents = 'none';

            try {
                const res = await fetch(`/api/promos?limit=${eventsPerPage}&offset=${offset}`);
                const data = await res.json();
                
                if (res.ok) {
                    renderEventCards(data.items);
                    totalEventPages = Math.ceil(data.total / eventsPerPage);
                    currentEventPage = page;
                    renderEventPagination();
                }
            } catch (err) {
                console.error('Failed to fetch events:', err);
                KapeKanto.toast('Failed to load events.', 'error');
            } finally {
                grid.style.opacity = '1';
                grid.style.pointerEvents = 'auto';
            }
        }

        function renderEventCards(items) {
            const container = document.getElementById('event-grid');
            if (!items || items.length === 0) {
                container.innerHTML = '<div style=\"grid-column: 1/-1; text-align: center; padding: 4rem;\"><p style=\"color: rgba(255,255,255,0.5); font-size: 1.1rem;\">No active events or promos available at the moment. Check back soon!</p></div>';
                return;
            }

            container.innerHTML = items.map((promo) => {
                const isTask = promo.event_type === 'task';
                const now = new Date();
                let isUpcoming = false;
                let countdownTarget = promo.end_date;
                
                if (promo.start_date) {
                    const startDate = new Date(promo.start_date);
                    if (startDate > now) {
                        isUpcoming = true;
                        countdownTarget = promo.start_date;
                    }
                }

                const dateText = isUpcoming ? 'Starts:' : 'Started:';
                const formattedStart = promo.start_date ? new Date(promo.start_date).toLocaleString([], { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'Immediate';
                const formattedEnd = promo.end_date ? new Date(promo.end_date).toLocaleString([], { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'No Expiry';

                return `
                    <div class="card event-card" style="display: flex; flex-direction: column; overflow: hidden; border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.04); backdrop-filter: blur(20px); opacity: 1; transform: none;">
                        ${promo.image ? `
                        <div style="width: 100%; height: 160px; overflow: hidden; position: relative; background: #222;">
                            <img src="${promo.image}" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>` : ''}
                        <div style="padding: 1.5rem; flex: 1; display: flex; flex-direction: column;">
                            <div class="event-card-head" style="margin-bottom: 1.2rem; display: flex; justify-content: space-between; align-items: flex-start;">
                                <div class="event-title-wrap" style="display: flex; gap: 12px; align-items: center;">
                                    <div class="event-card-icon" style="background: rgba(111, 78, 55, 0.3); color: white; width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 0.9rem;">
                                        <i class="fa-solid ${isTask ? 'fa-trophy' : 'fa-tags'}"></i>
                                    </div>
                                    <div>
                                        <h3 class="event-card-title" style="font-size: 1.1rem; margin: 0; color: white; font-weight: 700;">${promo.title}</h3>
                                        <div class="event-card-subtitle" style="font-size: 0.75rem; opacity: 0.6; color: #ccc;">${isTask ? 'Achievement Reward' : 'Limited Time Offer'}</div>
                                    </div>
                                </div>
                                <span class="event-status-badge ${isUpcoming ? 'event-status-badge--upcoming' : 'event-status-badge--active'}" style="padding: 4px 10px; border-radius: 50px; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; ${isUpcoming ? 'background: #f57f17; color: white;' : 'background: #2e7d32; color: white;'}">
                                    ${isUpcoming ? 'Upcoming' : 'Active'}
                                </span>
                            </div>
                            ${promo.description ? `<p class="event-description" style="font-size: 0.9rem; line-height: 1.6; color: rgba(255,255,255,0.75); margin-bottom: 1.5rem; height: 3.2em; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">${promo.description}</p>` : ''}
                            ${(promo.start_date || promo.end_date) ? `
                            <div class="event-date-box" style="background: rgba(0,0,0,0.2); padding: 12px; border-radius: 12px; margin-bottom: 1.5rem; border: 1px solid rgba(255,255,255,0.05);">
                                <div class="event-date-row" style="font-size: 0.75rem; margin-bottom: 6px; color: #ddd; display: flex; align-items: center; gap: 8px;">
                                    <i class="fa-regular fa-clock" style="color: var(--primary);"></i>
                                    <span><strong>${dateText}</strong> ${formattedStart}</span>
                                </div>
                                <div class="event-date-row" style="font-size: 0.75rem; color: #ddd; display: flex; align-items: center; gap: 8px;">
                                    <i class="fa-solid fa-hourglass-end" style="color: var(--primary);"></i>
                                    <span><strong>Ends:</strong> ${formattedEnd}</span>
                                </div>
                            </div>` : ''}
                            ${countdownTarget ? `
                            <div class="countdown" data-target="${countdownTarget}" data-is-upcoming="${isUpcoming}" style="margin-bottom: 1.5rem; display: flex; gap: 8px; flex-wrap: wrap;">
                                <div class="countdown-item" style="flex: 1; min-width: 50px; background: rgba(255,255,255,0.05); padding: 8px 4px; border-radius: 8px; text-align: center;"><div class="countdown-value days" style="font-weight: 800; font-size: 1rem;">00</div><div class="countdown-label" style="font-size: 0.6rem; text-transform: uppercase; opacity: 0.5;">Days</div></div>
                                <div class="countdown-item" style="flex: 1; background: rgba(255,255,255,0.05); padding: 8px 4px; border-radius: 8px; text-align: center;"><div class="countdown-value hours" style="font-weight: 800; font-size: 1rem;">00</div><div class="countdown-label" style="font-size: 0.6rem; text-transform: uppercase; opacity: 0.5;">Hours</div></div>
                                <div class="countdown-item" style="flex: 1; background: rgba(255,255,255,0.05); padding: 8px 4px; border-radius: 8px; text-align: center;"><div class="countdown-value minutes" style="font-weight: 800; font-size: 1rem;">00</div><div class="countdown-label" style="font-size: 0.6rem; text-transform: uppercase; opacity: 0.5;">Mins</div></div>
                                <div class="countdown-item" style="flex: 1; background: rgba(255,255,255,0.05); padding: 8px 4px; border-radius: 8px; text-align: center;"><div class="countdown-value seconds" style="font-weight: 800; font-size: 1rem;">00</div><div class="countdown-label" style="font-size: 0.6rem; text-transform: uppercase; opacity: 0.5;">Secs</div></div>
                            </div>` : ''}
                            <div class="event-card-footer" style="margin-top: auto;">
                                ${(!isTask && promo.promo_code) ? `
                                <div class="promo-code-box" style="background: var(--primary); padding: 12px; border-radius: 12px; text-align: center; box-shadow: 0 4px 15px rgba(111, 78, 55, 0.4);">
                                    ${isUpcoming ? `
                                    <span class="promo-code-label" style="font-size: 0.7rem; display: block; opacity: 0.8; font-weight: 600;">Reveals at start</span>
                                    <div class="promo-code-value" style="font-weight: 800; letter-spacing: 3px; font-size: 1.1rem;">••••••</div>` : `
                                    <span class="promo-code-label" style="font-size: 0.7rem; display: block; opacity: 0.8; font-weight: 600;">Promo Code</span>
                                    <div class="promo-code-value" style="font-weight: 800; letter-spacing: 1.5px; font-size: 1.1rem;">${promo.promo_code}</div>`}
                                </div>` : (isTask ? `
                                <a href="/profile#loyalty" class="promo-action-btn" style="display: block; text-align: center; background: #2e7d32; padding: 14px; border-radius: 12px; color: white; text-decoration: none; font-weight: 700; font-size: 0.95rem; box-shadow: 0 4px 15px rgba(46, 125, 50, 0.3); transition: 0.3s;">
                                    <i class="fa-solid fa-bolt"></i> Join Challenge
                                </a>` : '')}
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            updateCountdowns();
            if (window.ScrollReveal) {
                ScrollReveal().reveal('.event-card', {
                    distance: '20px',
                    origin: 'bottom',
                    opacity: 0,
                    interval: 100,
                    duration: 600,
                    easing: 'cubic-bezier(0.5, 0, 0, 1)'
                });
            }
        }

        function renderEventPagination() {
            const controls = document.getElementById('event-pagination');
            const pageNumbers = document.getElementById('event-page-numbers');
            
            if (totalEventPages <= 1) {
                controls.style.display = 'none';
                return;
            }
            
            controls.style.display = 'flex';
            let html = '';
            const maxVisible = 10;
            
            // Calculate Sliding Window Range
            let startPage = Math.max(1, currentEventPage - Math.floor(maxVisible / 2));
            let endPage = Math.min(totalEventPages, startPage + maxVisible - 1);
            
            if (endPage - startPage < maxVisible - 1) {
                startPage = Math.max(1, endPage - maxVisible + 1);
            }

            // Left Ellipsis (Shifts range back)
            if (startPage > 1) {
                html += `<button class="btn btn-outline" onclick="goToEventPage(${startPage - 1})" style="width: 35px; height: 35px; padding: 0; display: flex; align-items: center; justify-content: center; font-size: 1rem; border-radius: 50%;" title="Previous Range">...</button>`;
            }

            // Page Numbers
            for (let i = startPage; i <= endPage; i++) {
                html += `<button class="btn ${i === currentEventPage ? 'btn-primary' : 'btn-outline'}" 
                                 onclick="goToEventPage(${i})" 
                                 style="width: 35px; height: 35px; padding: 0; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; border-radius: 50%;">${i}</button>`;
            }

            // Right Ellipsis (Shifts range forward)
            if (endPage < totalEventPages) {
                html += `<button class="btn btn-outline" onclick="goToEventPage(${endPage + 1})" style="width: 35px; height: 35px; padding: 0; display: flex; align-items: center; justify-content: center; font-size: 1rem; border-radius: 50%;" title="Next Range">...</button>`;
            }

            pageNumbers.innerHTML = html;
        }

        function goToEventPage(page) {
            fetchEventPage(page);
            document.getElementById('event-grid').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function changeEventPage(delta) {
            const next = currentEventPage + delta;
            if (next > totalEventPages) goToEventPage(1);
            else if (next < 1) goToEventPage(totalEventPages);
            else goToEventPage(next);
        }

        // Initialize display
        document.addEventListener('DOMContentLoaded', () => {
            fetchEventPage(1);
        });

        // Smooth scroll helper
        function smoothScrollTo(id) {
            const el = document.getElementById(id);
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        // Gallery modal open (for carousel button)
        document.querySelectorAll('[data-open-gallery]').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                const modal = document.getElementById('gallery-modal');
                if (modal) { modal.style.display = 'flex'; }
            });
        });
    </script>

    <script src="/js/carousel.js"></script>
    <script src="/js/animations.js"></script>
    <script>
        // Generate floating coffee beans for intro
        (function spawnBeans() {
            const container = document.getElementById('introBeans');
            if (!container) return;
            const count = 18;
            for (let i = 0; i < count; i++) {
                const bean = document.createElement('div');
                bean.className = 'intro-bean';
                bean.style.left = Math.random() * 100 + 'vw';
                bean.style.animationDuration = (4 + Math.random() * 5) + 's';
                bean.style.animationDelay = (Math.random() * 3) + 's';
                bean.style.width = (12 + Math.random() * 14) + 'px';
                bean.style.height = (7 + Math.random() * 7) + 'px';
                bean.style.opacity = (0.1 + Math.random() * 0.2).toString();
                container.appendChild(bean);
            }
        })();
    </script>

    <%- include('partials/footer') %>
