<%- include('../partials/header') %>

<style>
    .staff-shell { display: grid; grid-template-columns: 260px 1fr; gap: 1.5rem; padding: 2rem 5%; max-width: 1500px; margin: 0 auto; }
    .staff-sidebar { position: sticky; top: 96px; align-self: start; background: rgba(255,255,255,0.92); border: 1px solid rgba(111,78,55,0.08); border-radius: 18px; padding: 1.25rem; box-shadow: var(--shadow-soft); }
    .staff-sidebar h3 { 
        font-size: 1.4rem; 
        text-transform: uppercase; 
        letter-spacing: 2px; 
        color: var(--primary); 
        margin-bottom: 2rem; 
        font-weight: 900;
        text-align: center;
        padding: 0.5rem 0;
    }
    .staff-sidebar a { display: flex; align-items: center; gap: 10px; padding: 0.85rem 0.95rem; border-radius: 12px; color: var(--text-light); font-weight: 700; margin-bottom: 0.35rem; }
    .staff-sidebar a:hover, .staff-sidebar a.active { background: var(--primary); color: white; transform: translateX(3px); }
    .staff-hero { background: linear-gradient(135deg, #2c1a0e 0%, #6f4e37 68%, #a0785d 100%); border-radius: 22px; padding: 1.5rem; color: white; box-shadow: var(--shadow-medium); margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .staff-hero h1 { color: white; margin: 0 0 0.3rem; font-size: 1.8rem; letter-spacing: 0; }
    .staff-hero p { color: rgba(255,255,255,0.72); margin: 0; }
    .staff-panel { background: white; border: 1px solid rgba(111,78,55,0.08); border-radius: 18px; box-shadow: var(--shadow-soft); padding: 1.25rem; }
    .so-tabs { display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .so-tab { display: inline-flex; align-items: center; gap: 7px; padding: 0.62rem 0.85rem; border-radius: 999px; border: 1px solid #eaded3; background: white; color: var(--text-light); font-family: var(--font-body); font-weight: 800; font-size: 0.82rem; cursor: pointer; }
    .so-tab.active { background: var(--primary); color: white; border-color: var(--primary); box-shadow: 0 8px 18px rgba(111,78,55,0.16); }
    .so-count { color: var(--text-light); font-weight: 700; font-size: 0.88rem; margin-bottom: 1rem; }
    .so-list { display: grid; gap: 0.85rem; }
    .so-card { background: #fffdf9; border: 1px solid #f0e5dc; border-radius: 16px; padding: 1rem; display: grid; grid-template-columns: minmax(170px, 1.1fr) 110px 150px 110px minmax(320px, auto); gap: 1rem; align-items: center; }
    .so-card.select-mode { grid-template-columns: 34px minmax(170px, 1.1fr) 110px 150px 110px minmax(320px, auto); }
    .so-check { width: 18px; height: 18px; accent-color: var(--primary); cursor: pointer; }
    .so-id { font-weight: 900; font-size: 1rem; color: var(--primary-dark); }
    .so-customer { color: var(--text-light); font-size: 0.82rem; margin-top: 0.2rem; }
    .so-type-chip, .so-badge { display: inline-flex; align-items: center; gap: 6px; width: fit-content; border-radius: 999px; padding: 0.36rem 0.7rem; font-size: 0.74rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.02em; }
    .so-type-chip { background: var(--bg-main); color: var(--primary); border: 1px solid #ecdccc; }
    .badge-pending { background:#fff3e0; color:#b75d00; }
    .badge-preparing { background:#e8f2ff; color:#125a9c; }
    .badge-ready { background:#e8f5e9; color:#2e7d32; }
    .badge-delivery { background:#f2e8ff; color:#6c3ba2; }
    .badge-completed { background:#e8f5e9; color:#1b5e20; }
    .badge-cancelled { background:#ffebee; color:#b71c1c; }
    .badge-awaiting { background:#fff8e1; color:#ff8f00; border: 1px solid rgba(255,143,0,0.3); }
    .badge-awaiting i { margin-right: 4px; }
    .so-total { font-weight: 900; color: var(--primary); font-size: 1rem; }
    .so-status-select { width: 100%; min-width: 130px; border-radius: 999px !important; padding: 0.55rem 0.75rem !important; font-size: 0.78rem; font-weight: 800; border: 1px solid #e6d8cc !important; color: var(--primary-dark); background: white; }
    .so-actions { display: flex; justify-content: flex-end; gap: 0.45rem; flex-wrap: wrap; }
    .so-btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 0.55rem 0.78rem; border-radius: 999px; border: 0; font-family: var(--font-body); font-size: 0.78rem; font-weight: 900; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; }
    .so-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 18px rgba(44,26,14,0.12); }
    .so-btn-primary { background: var(--primary); color: white; }
    .so-btn-success { background: var(--success); color: white; }
    .so-btn-blue { background: #1565c0; color: white; }
    .so-btn-danger { background: var(--danger); color: white; }
    .so-btn-dark { background: #34302c; color: white; }
    .so-btn-outline { background: white; border: 1px solid #e6d8cc; color: var(--primary-dark); }
    .page-btn { width: 38px; height: 38px; padding: 0; border-radius: 12px; border: 1px solid #e6d8cc; background: white; color: var(--primary-dark); font-weight: 800; cursor: pointer; }
    .page-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
    .page-dots { cursor: pointer; padding: 0 8px; color: #999; display: flex; align-items: center; font-weight: 800; }
    .so-tools { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .so-search { max-width: 360px; border-radius: 999px !important; padding: 0.75rem 1rem !important; transition: all 0.25s ease; border: 1px solid #e6d8cc !important; background: #fffdf9; outline: none; }
    .so-search:focus { border-color: var(--primary) !important; box-shadow: 0 0 0 4px rgba(111,78,55,0.1) !important; background: white; }
    .so-bulk { display: flex; align-items: center; gap: 0.65rem; flex-wrap: wrap; }
    .empty-state { text-align: center; padding: 3rem 1rem; color: var(--text-light); }
    .empty-state i { display: block; font-size: 2rem; color: var(--accent); margin-bottom: 0.75rem; }
    #rider-modal { display:none; position:fixed; inset:0; background:rgba(44,26,14,0.48); z-index:9999; align-items:center; justify-content:center; padding:1rem; }
    #rider-modal.open { display:flex; }
    .rider-modal-box { background:white; border-radius:20px; padding:1.4rem; width:100%; max-width:430px; box-shadow:0 24px 70px rgba(0,0,0,0.22); }
    
    #chat-modal { display:none; position:fixed; inset:0; background:rgba(44,26,14,0.6); z-index:9999; align-items:center; justify-content:center; padding:1rem; backdrop-filter: blur(4px); }
    #chat-modal.open { display:flex; }
    .chat-modal-box { 
        background:white; 
        border-radius:24px; 
        width:100%; 
        max-width:500px; 
        height: 85vh;
        max-height: 700px;
        box-shadow:0 30px 90px rgba(0,0,0,0.3); 
        display:flex; 
        flex-direction:column; 
        overflow:hidden; 
        animation: modalPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @keyframes modalPop {
        from { transform: scale(0.9) translateY(20px); opacity: 0; }
        to { transform: scale(1) translateY(0); opacity: 1; }
    }
    .chat-modal-header { padding:1.25rem 1.5rem; border-bottom:1px solid #f0e6e0; display:flex; justify-content:space-between; align-items:center; background:#fdfaf7; }
    .chat-modal-title { margin:0; font-size:1.15rem; font-weight:800; color:var(--primary-dark); display:flex; align-items:center; gap:10px; }
    .chat-modal-close { 
        background:rgba(0,0,0,0.05); 
        border:none; 
        color:var(--text-light); 
        width: 32px; 
        height: 32px; 
        border-radius: 50%; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        cursor:pointer; 
        transition: 0.2s;
    }
    .chat-modal-close:hover { background: var(--danger); color: white; transform: rotate(90deg); }
    
    .chat-modal-messages { 
        flex: 1;
        padding:1.5rem; 
        overflow-y:auto; 
        display:flex; 
        flex-direction:column; 
        gap:1.25rem; 
        background:#fffcf9;
        scroll-behavior: smooth;
    }
    
    .chat-msg { 
        max-width:85%; 
        padding:0.9rem 1.25rem; 
        border-radius:18px; 
        font-size:0.92rem; 
        line-height: 1.5;
        position:relative; 
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .chat-msg.staff { 
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color:white; 
        align-self:flex-end; 
        border-bottom-right-radius:4px; 
    }
    .chat-msg.customer { 
        background:white; 
        color:var(--primary-dark); 
        align-self:flex-start; 
        border:1px solid #ede1d7; 
        border-bottom-left-radius:4px; 
    }
    .chat-meta { font-size:0.68rem; margin-top:6px; font-weight: 700; opacity:0.75; }
    .chat-msg.staff .chat-meta { text-align:right; color: rgba(255,255,255,0.9); }
    .chat-msg.customer .chat-meta { color:var(--text-light); }
    
    .chat-input-area { padding:1.25rem 1.5rem; border-top:1px solid #f0e6e0; display:flex; gap:12px; background:white; align-items: center; }
    .chat-input { 
        flex:1; 
        padding:0.85rem 1.25rem; 
        border-radius:50px; 
        border:1px solid #ede1d7; 
        font-family:var(--font-body); 
        font-size:0.95rem; 
        outline:none; 
        transition: all 0.2s; 
        background: #fdfaf7;
    }
    .chat-input:focus { border-color:var(--primary); background: white; box-shadow: 0 0 0 4px rgba(111,78,55,0.1); }
    .chat-send { 
        width:48px; 
        height:48px; 
        border-radius:50%; 
        background:var(--primary); 
        color:white; 
        border:none; 
        display:flex; 
        align-items:center; 
        justify-content:center; 
        cursor:pointer; 
        transition:all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
        flex-shrink:0; 
        box-shadow: 0 4px 12px rgba(111,78,55,0.2);
    }
    .chat-send:hover { transform: scale(1.1) rotate(5deg); background:var(--primary-dark); }
    
    @media (max-width: 600px) {
        .chat-modal-box { height: 100vh; max-height: 100vh; border-radius: 0; }
        .chat-msg { max-width: 90%; }
    }

    .chat-send:hover { transform:scale(1.05); background:var(--accent); }

    /* Modal Styles */
    #so-modal { display:none; position:fixed; inset:0; background:rgba(44,26,14,0.48); z-index:9999; align-items:center; justify-content:center; padding:1rem; }
    #so-modal.open { display:flex; }
    .so-modal-box { background:white; border-radius:24px; padding:2rem; width:100%; max-width:650px; max-height:90vh; overflow-y:auto; box-shadow:0 24px 70px rgba(0,0,0,0.22); position:relative; }
    .so-modal-close { position:absolute; top:1.5rem; right:1.5rem; background:none; border:none; font-size:1.8rem; cursor:pointer; color:#999; transition:all 0.2s; width:40px; height:40px; display:flex; align-items:center; justify-content:center; border-radius:50%; }
    .so-modal-close:hover { background:#fdfaf7; color:var(--primary); transform:rotate(90deg); }
    .so-detail-label { font-size:0.75rem; text-transform:uppercase; font-weight:800; color:#aaa; letter-spacing:1px; margin-bottom:4px; display:block; }
    .so-detail-value { font-size:1rem; font-weight:700; color:var(--primary-dark); }
    .so-item-row { display:flex; justify-content:space-between; align-items:center; padding:0.8rem 0; border-bottom:1px solid #f5f0eb; }
    .so-item-row:last-child { border-bottom:none; }
    .so-breakdown-row { display:flex; justify-content:space-between; padding:0.4rem 0; font-size:0.9rem; color:var(--text-light); }
    .so-breakdown-row.total { font-weight:800; font-size:1.1rem; color:var(--primary-dark); border-top:1px solid #f0e6e0; margin-top:0.5rem; padding-top:0.8rem; }
    .so-breakdown-row.red { color:var(--danger); }

    @media (max-width: 1100px) { .staff-shell { grid-template-columns: 1fr; padding: 1rem; } .staff-sidebar { position: static; } .so-card { grid-template-columns: 1fr; align-items: start; } .so-actions { justify-content: flex-start; } .staff-hero { flex-direction: column; align-items: flex-start; } }

</style>

<div class="staff-shell">
    <aside class="staff-sidebar">
        <h3>Staff Panel</h3>
        <a href="/staff/orders" class="active"><i class="fa-solid fa-list-check"></i> Manage Orders</a>
        <a href="/staff/menu-stock"><i class="fa-solid fa-boxes-stacked"></i> Update Stock</a>
    </aside>

    <section>
        <div class="staff-hero flex-stack-mobile">
            <div style="text-align: left; width: 100%;">
                <h1>Order Management</h1>
                <p>Move orders through prep, dispatch, completion, cancellation, and record cleanup.</p>
            </div>
            <button class="so-btn so-btn-outline" onclick="loadOrders()" style="background:rgba(255,255,255,0.16);color:white;border-color:rgba(255,255,255,0.24); margin-top: 1rem; width: 100%;">
                <i class="fa-solid fa-rotate"></i> Refresh
            </button>
        </div>

        <div class="staff-panel">
            <div class="so-tabs">
                <button class="so-tab active" onclick="filterOrders('all', this)"><i class="fa-solid fa-layer-group"></i> All Statuses</button>
                <button class="so-tab" onclick="filterOrders('pending', this)"><i class="fa-regular fa-clock"></i> Pending</button>
                <button class="so-tab" onclick="filterOrders('preparing', this)"><i class="fa-solid fa-fire"></i> Preparing</button>
                <button class="so-tab" onclick="filterOrders('ready', this)"><i class="fa-solid fa-check-double"></i> Ready</button>
                <button class="so-tab" onclick="filterOrders('out_for_delivery', this)"><i class="fa-solid fa-truck-fast"></i> Out for Delivery</button>
                <button class="so-tab" onclick="filterOrders('awaiting_payment', this)" style="border-color: #ff8f00; color: #ff8f00;"><i class="fa-solid fa-hourglass-half"></i> Unpaid / Awaiting</button>
                <button class="so-tab" onclick="filterOrders('completed', this)"><i class="fa-solid fa-flag-checkered"></i> Delivered / Picked Up</button>
            </div>

            <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap;">
                <!-- Type Filter -->
                <div style="display: flex; align-items: center; gap: 1rem; background: #fdfaf7; padding: 0.75rem 1.25rem; border-radius: 50px; border: 1px solid #f0e6e0;">
                    <span style="font-weight: 800; color: var(--primary-dark); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px;">Type:</span>
                    <div style="display: flex; gap: 6px;">
                        <button class="so-tab active" id="type-all" onclick="filterType('all')" style="padding: 6px 14px; font-size: 0.75rem;">All</button>
                        <button class="so-tab" id="type-delivery" onclick="filterType('delivery')" style="padding: 6px 14px; font-size: 0.75rem;">Delivery</button>
                        <button class="so-tab" id="type-pickup" onclick="filterType('pickup')" style="padding: 6px 14px; font-size: 0.75rem;">Pickup</button>
                    </div>
                </div>

                <!-- Schedule Filter -->
                <div style="display: flex; align-items: center; gap: 1rem; background: #fdfaf7; padding: 0.75rem 1.25rem; border-radius: 50px; border: 1px solid #f0e6e0;">
                    <span style="font-weight: 800; color: var(--primary-dark); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px;">Schedule:</span>
                    <div style="display: flex; gap: 6px;">
                        <button class="so-tab active" id="sched-all" onclick="filterSched('all')" style="padding: 6px 14px; font-size: 0.75rem;">All</button>
                        <button class="so-tab" id="sched-asap" onclick="filterSched('asap')" style="padding: 6px 14px; font-size: 0.75rem;"><i class="fa-solid fa-bolt" style="margin-right: 4px;"></i> ASAP</button>
                        <button class="so-tab" id="sched-scheduled" onclick="filterSched('scheduled')" style="padding: 6px 14px; font-size: 0.75rem;"><i class="fa-regular fa-clock" style="margin-right: 4px;"></i> Scheduled</button>
                    </div>
                </div>
            </div>

            <div class="so-tools">
                <div style="position: relative; flex: 1; max-width: 360px; min-width: 260px;">
                    <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: var(--text-light); font-size: 0.95rem;"></i>
                    <input class="so-search" id="order-search" type="text" placeholder="Search orders, customer, status..." oninput="setOrderSearch(this.value)" style="width: 100%; padding: 0.75rem 1rem 0.75rem 2.6rem !important;">
                </div>
                <div class="so-bulk">
                    <button class="so-btn so-btn-outline" id="bulk-mode-btn" onclick="toggleBulkMode()"><i class="fa-regular fa-square-check"></i> Select Orders</button>
                    <label id="select-all-wrap" style="display:none;align-items:center;gap:8px;margin:0;color:var(--text-light);font-size:0.86rem;font-weight:800;">
                        <input class="so-check" id="select-all-orders" type="checkbox" onchange="toggleSelectAllOrders(this.checked)">
                        Select all results
                    </label>
                    <button class="so-btn so-btn-danger" id="delete-selected-btn" style="display:none;" onclick="deleteSelectedOrders()"><i class="fa-solid fa-trash-can"></i> Delete Selected</button>
                </div>
            </div>
            <div class="so-count" id="order-count">Loading orders...</div>
            <div id="orders-container" class="so-list"></div>
            <div id="pagination-container" style="display:flex;justify-content:center;gap:8px;margin-top:1.5rem;padding-bottom:0.5rem;flex-wrap:wrap;"></div>
        </div>
    </section>
</div>

<div id="rider-modal">
    <div class="rider-modal-box">
        <h3 style="margin-bottom:0.4rem;"><i class="fa-solid fa-motorcycle" style="color:#1565c0"></i> Assign Rider</h3>
        <p style="color:var(--text-light);font-size:0.88rem;margin-bottom:1.25rem;">Enter rider details for Order <strong id="rider-order-id"></strong>.</p>
        <div class="form-group" style="margin-bottom:1rem;">
            <label style="font-weight:700;font-size:0.9rem;">Rider Name <span style="color:var(--danger);font-weight:bold;">*</span></label>
            <input type="text" id="rider-name" placeholder="e.g. Juan dela Cruz" required>
        </div>
        <div class="form-group" style="margin-bottom:1.5rem;">
            <label style="font-weight:700;font-size:0.9rem;">Rider Contact <span style="color:var(--text-light);font-weight:500;">(optional)</span></label>
            <input type="text" id="rider-contact" placeholder="e.g. 09XX XXX XXXX">
        </div>
        <div style="display:flex;gap:10px;">
            <button class="so-btn so-btn-blue" style="flex:1;padding:0.8rem;" onclick="confirmDispatch()">
                <i class="fa-solid fa-motorcycle"></i> Dispatch Rider
            </button>
            <button class="so-btn so-btn-outline" onclick="closeRiderModal()" style="padding:0.8rem 1rem;">Cancel</button>
        </div>
    </div>
</div>

<div id="chat-modal">
    <div class="chat-modal-box">
        <div class="chat-modal-header">
            <h3 class="chat-modal-title"><i class="fa-solid fa-comments" style="color:var(--primary)"></i> Chat - Order #<span id="chat-order-id"></span></h3>
            <button class="chat-modal-close" onclick="closeChatModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div id="chat-messages" class="chat-modal-messages">
            <div style="text-align:center; color:var(--text-light); font-size:0.85rem; padding:1rem;">Loading messages...</div>
        </div>
        <form id="chat-form" class="chat-input-area" onsubmit="sendStaffChatMessage(event)">
            <input type="text" id="chat-input" class="chat-input" placeholder="Type a message to customer..." autocomplete="off" required>
            <button type="submit" class="chat-send"><i class="fa-solid fa-paper-plane"></i></button>
        </form>
    </div>
</div>

<!-- Details modal -->
<div id="so-modal">
    <div class="so-modal-box">
        <button onclick="closeDetailsModal()" class="so-modal-close"><i class="fa-solid fa-xmark"></i></button>
        <h3 id="so-modal-title" style="margin:0 0 1.5rem 0; font-size:1.4rem; color:var(--primary-dark);">Order Details</h3>
        <div id="so-modal-body"></div>
    </div>
</div>

<script>
    let allOrders = [];
    let currentFilter = 'all';
    let pendingDispatchId = null;
    let currentPage = 1;
    let orderSearchTerm = '';
    let currentType = 'all';
    let currentSched = 'all';
    let bulkMode = false;
    let activeChatOrderId = null;
    let chatRefreshInterval = null;
    const selectedOrderIds = new Set();
    const PAGE_LIMIT = 10;

    const STATUS_NEXT = {
        pending: { status: 'preparing', label: 'Start Prep', cls: 'so-btn-primary', icon: 'fa-fire' },
        preparing: { status: 'ready', label: 'Mark Ready', cls: 'so-btn-success', icon: 'fa-check-double' },
        ready: { status: 'out_for_delivery', label: 'Dispatch', cls: 'so-btn-blue', icon: 'fa-truck-fast', deliveryOnly: true },
        ready_pickup: { status: 'completed', label: 'Complete', cls: 'so-btn-success', icon: 'fa-circle-check' },
        out_for_delivery: { status: 'completed', label: 'Delivered', cls: 'so-btn-success', icon: 'fa-circle-check' }
    };

    const BADGE_MAP = {
        pending: 'badge-pending',
        preparing: 'badge-preparing',
        ready: 'badge-ready',
        out_for_delivery: 'badge-delivery',
        completed: 'badge-completed',
        cancelled: 'badge-cancelled',
        awaiting_payment: 'badge-awaiting'
    };

    const STATUS_OPTIONS = [
        { value: 'pending', label: 'Pending', icon: 'fa-clock' },
        { value: 'preparing', label: 'Preparing', icon: 'fa-fire' },
        { value: 'ready', label: 'Ready', icon: 'fa-check-double' },
        { value: 'out_for_delivery', label: 'Out for Delivery', deliveryOnly: true, icon: 'fa-truck-fast' },
        { value: 'completed', label: 'Completed', icon: 'fa-flag-checkered' },
        { value: 'cancelled', label: 'Cancelled', icon: 'fa-ban' },
        { value: 'awaiting_payment', label: 'Awaiting Payment (Unpaid)', icon: 'fa-hourglass-half' }
    ];

    function statusLabel(status, orderType) {
        if (status === 'completed') return orderType === 'delivery' ? 'Delivered' : 'Picked Up';
        if (status === 'awaiting_payment') return 'UNPAID / AWAITING';
        return String(status || '').replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    }

    async function loadOrders() {
        try {
            const res = await fetch('/api/orders/all');
            if (!res.ok) throw new Error('Request failed');
            allOrders = await res.json();
            selectedOrderIds.clear();
            renderOrders();

            // Handle Deep Link to Chat
            const urlParams = new URLSearchParams(window.location.search);
            const openChatId = urlParams.get('openChat');
            if (openChatId) {
                // Clear the param from URL to avoid re-opening on refresh
                window.history.replaceState({}, document.title, window.location.pathname);
                openChatModal(Number(openChatId));
            }
        } catch (e) {
            document.getElementById('order-count').textContent = 'Could not load orders.';
            document.getElementById('orders-container').innerHTML = '<div class="empty-state"><i class="fa-solid fa-triangle-exclamation"></i> Failed to load orders.</div>';
            KapeKanto.toast('Failed to load staff orders.', 'error');
        }
    }

    function filterOrders(status, btn) {
        currentFilter = status;
        currentPage = 1;
        document.querySelectorAll('.so-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        renderOrders();
    }

    function setOrderSearch(value) {
        orderSearchTerm = value.trim().toLowerCase();
        currentPage = 1;
        renderOrders();
    }

    function getFilteredOrders() {
        return allOrders.filter(o => {
            const matchesStatus = currentFilter === 'all' || o.status === currentFilter;
            if (!matchesStatus) return false;

            const matchesType = currentType === 'all' || o.order_type === currentType;
            if (!matchesType) return false;

            const matchesSched = currentSched === 'all' || o.schedule_mode === currentSched;
            if (!matchesSched) return false;

            if (!orderSearchTerm) return true;

            const haystack = [
                o.id,
                o.username,
                o.email,
                o.status,
                o.order_type,
                o.payment_method,
                o.total
            ].join(' ').toLowerCase();

            return haystack.includes(orderSearchTerm);
        });
    }

    function filterType(type) {
        currentType = type;
        currentPage = 1;
        
        // Update UI
        ['all', 'delivery', 'pickup'].forEach(t => {
            const btn = document.getElementById(`type-${t}`);
            if (t === type) btn.classList.add('active');
            else btn.classList.remove('active');
        });
        
        renderOrders();
    }

    function filterSched(sched) {
        currentSched = sched;
        currentPage = 1;
        
        // Update UI
        ['all', 'asap', 'scheduled'].forEach(s => {
            const btn = document.getElementById(`sched-${s}`);
            if (s === sched) btn.classList.add('active');
            else btn.classList.remove('active');
        });
        
        renderOrders();
    }

    function renderOrders() {
        const filtered = getFilteredOrders();
        const totalPages = Math.ceil(filtered.length / PAGE_LIMIT);
        currentPage = totalPages > 0 ? Math.min(Math.max(currentPage, 1), totalPages) : 1;
        const startIndex = (currentPage - 1) * PAGE_LIMIT;
        const pagedOrders = filtered.slice(startIndex, startIndex + PAGE_LIMIT);
        document.getElementById('order-count').textContent =
            `Showing ${pagedOrders.length} of ${filtered.length} order${filtered.length === 1 ? '' : 's'}`;
        syncBulkControls(filtered);

        const container = document.getElementById('orders-container');
        if (!filtered.length) {
            container.innerHTML = '<div class="empty-state"><i class="fa-solid fa-inbox"></i> No orders in this category.</div>';
            document.getElementById('pagination-container').innerHTML = '';
            return;
        }

        container.innerHTML = pagedOrders.map(o => buildCard(o)).join('');
        KapeKanto.initSelects(container);
        renderPagination(currentPage, totalPages);
    }

    function renderPagination(current, totalPages) {
        const container = document.getElementById('pagination-container');
        if (totalPages <= 1) {
            container.innerHTML = '';
            return;
        }

        const prev = current === 1 ? totalPages : current - 1;
        const next = current === totalPages ? 1 : current + 1;
        let html = `<button class="page-btn" onclick="changePage(${prev})"><i class="fa-solid fa-chevron-left"></i></button>`;

        const limit = 10;
        let start = Math.max(1, current - limit + 1);
        let end = Math.min(totalPages, start + limit - 1);
        if (end - start < limit - 1) start = Math.max(1, end - limit + 1);

        if (start > 1) html += `<span class="page-dots" onclick="changePage(${start - 1})" title="Previous page range">...</span>`;
        for (let i = start; i <= end; i++) {
            html += `<button class="page-btn ${i === current ? 'active' : ''}" onclick="changePage(${i})">${i}</button>`;
        }
        if (end < totalPages) html += `<span class="page-dots" onclick="changePage(${end + 1})" title="Next page range">...</span>`;

        html += `<button class="page-btn" onclick="changePage(${next})"><i class="fa-solid fa-chevron-right"></i></button>`;
        container.innerHTML = html;
    }

    function changePage(page) {
        currentPage = page;
        renderOrders();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function buildCard(o) {
        const date = KapeKanto.parseUTCDate(o.created_at).toLocaleDateString('en-PH', {
            month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', hour12: true
        });
        const isDelivery = o.order_type === 'delivery';

        const statusDropdownOptions = STATUS_OPTIONS
            .filter(opt => !opt.deliveryOnly || isDelivery)
            .map(opt => `<option value="${opt.value}" ${opt.value === o.status ? 'selected' : ''}>${statusLabel(opt.value, o.order_type)}</option>`)
            .join('');

        const statusSelect = `<select class="so-status-select" onchange="changeStatusFromDropdown(${o.id}, '${o.status}', this)">
            ${statusDropdownOptions}
        </select>`;

        const riderInfo = o.status === 'out_for_delivery' && o.rider_name
            ? `<div class="so-customer"><i class="fa-solid fa-motorcycle"></i> ${o.rider_name}${o.rider_contact ? ' / ' + o.rider_contact : ''}</div>`
            : '';

        let actionBtns = '';
        actionBtns += statusSelect;
        actionBtns += `<button class="so-btn so-btn-blue" onclick="viewDetails(${o.id})"><i class="fa-solid fa-eye"></i> View</button>`;
        actionBtns += `<button class="so-btn so-btn-outline" onclick="openChatModal(${o.id})"><i class="fa-solid fa-comments"></i> Chat</button>`;
        actionBtns += `<button class="so-btn so-btn-dark" onclick="deleteOrder(${o.id})" title="Permanently delete this order record"><i class="fa-solid fa-trash-can"></i> Delete</button>`;

        return `
            <article class="so-card ${bulkMode ? 'select-mode' : ''}">
                ${bulkMode ? `<input class="so-check order-select" type="checkbox" ${selectedOrderIds.has(o.id) ? 'checked' : ''} onchange="toggleOrderSelection(${o.id}, this.checked)">` : ''}
                <div>
                    <div class="so-id">Order #${o.id}</div>
                    <div class="so-customer">${o.username || 'Customer'} / ${date}</div>
                    ${riderInfo}
                </div>
                <div style="display: flex; flex-direction: column; gap: 4px; align-items: start;">
                    <span class="so-type-chip"><i class="fa-solid ${isDelivery ? 'fa-truck-fast' : 'fa-bag-shopping'}"></i> ${isDelivery ? 'Delivery' : 'Pickup'}</span>
                    <span class="so-type-chip" style="${o.schedule_mode === 'asap' ? 'background:#e8f5e9; color:#2e7d32; border-color:#c8e6c9;' : 'background:#f8f9fa; color:#495057; border-color:#e9ecef;'}"><i class="fa-solid ${o.schedule_mode === 'asap' ? 'fa-bolt' : 'fa-calendar-days'}"></i> ${o.schedule_mode === 'asap' ? 'ASAP' : 'Scheduled'}</span>
                </div>
                <span class="so-badge ${BADGE_MAP[o.status] || ''}">${o.status === 'awaiting_payment' ? '<i class="fa-solid fa-triangle-exclamation"></i>' : ''}${statusLabel(o.status, o.order_type)}</span>
                <span class="so-total">&#8369;${Number(o.total || 0).toFixed(2)}</span>
                <div class="so-actions">${actionBtns || '<span class="so-customer">No actions</span>'}</div>
            </article>
        `;
    }

    function syncBulkControls(filtered = getFilteredOrders()) {
        const btn = document.getElementById('bulk-mode-btn');
        const selectAllWrap = document.getElementById('select-all-wrap');
        const selectAll = document.getElementById('select-all-orders');
        const deleteBtn = document.getElementById('delete-selected-btn');

        btn.innerHTML = bulkMode
            ? '<i class="fa-solid fa-xmark"></i> Cancel Selection'
            : '<i class="fa-regular fa-square-check"></i> Select Orders';

        selectAllWrap.style.display = bulkMode ? 'flex' : 'none';
        deleteBtn.style.display = bulkMode ? 'inline-flex' : 'none';
        selectAll.checked = bulkMode && filtered.length > 0 && filtered.every(o => selectedOrderIds.has(o.id));
    }

    function toggleBulkMode() {
        bulkMode = !bulkMode;
        if (!bulkMode) selectedOrderIds.clear();
        renderOrders();
    }

    function toggleOrderSelection(id, checked) {
        if (checked) {
            selectedOrderIds.add(id);
        } else {
            selectedOrderIds.delete(id);
        }
        const filtered = getFilteredOrders();
        document.getElementById('select-all-orders').checked = filtered.length > 0 && filtered.every(o => selectedOrderIds.has(o.id));
    }

    function toggleSelectAllOrders(checked) {
        getFilteredOrders().forEach(order => {
            if (checked) {
                selectedOrderIds.add(order.id);
            } else {
                selectedOrderIds.delete(order.id);
            }
        });
        renderOrders();
    }

    async function updateStatus(id, status, riderName = '', riderContact = '') {
        const performUpdate = async () => {
            try {
                const body = { status };
                if (riderName) body.rider_name = riderName;
                if (riderContact) body.rider_contact = riderContact;

                const res = await fetch(`/api/orders/${id}/status`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const data = await res.json().catch(() => ({}));
                if (!res.ok) throw new Error(data.error || 'Update failed');

                const order = allOrders.find(o => Number(o.id) === Number(id));
                KapeKanto.toast(`Order #${id} -> ${statusLabel(status, order?.order_type)}`, 'success');
                currentPage = 1;
                loadOrders();
            } catch (e) {
                KapeKanto.toast(e.message || 'Failed to update order.', 'error');
            }
        };

        if (status === 'cancelled') {
            KapeKanto.confirm(`Cancel Order #${id}?`, performUpdate, { type: 'danger', confirmText: 'Cancel Order' });
        } else {
            performUpdate();
        }
    }

    function changeStatusFromDropdown(id, currentStatus, select) {
        const nextStatus = select.value;
        if (nextStatus === currentStatus) return;

        const order = allOrders.find(o => Number(o.id) === Number(id));

        if (nextStatus === 'out_for_delivery') {
            openRiderModal(id);
            select.value = currentStatus;
            return;
        }

        KapeKanto.confirm(
            `Change Order #${id} from ${statusLabel(currentStatus, order?.order_type)} to ${statusLabel(nextStatus, order?.order_type)}?`,
            async () => {
                await updateStatus(id, nextStatus);
            },
            {
                title: 'Change Status',
                confirmText: 'Update Status',
                cancelText: 'Keep Current',
                type: nextStatus === 'cancelled' ? 'danger' : 'info'
            }
        );

        select.value = currentStatus;
    }

    async function deleteOrder(id) {
        KapeKanto.confirm(`Delete Order #${id}? This permanently removes the record and returns stock.`, async () => {
            try {
                const res = await fetch(`/api/orders/${id}`, { method: 'DELETE' });
                const data = await res.json().catch(() => ({}));
                if (!res.ok) throw new Error(data.error || 'Failed to delete order.');
                selectedOrderIds.delete(id);
                KapeKanto.toast(`Order #${id} deleted.`, 'success');
                loadOrders();
            } catch (e) {
                KapeKanto.toast(e.message || 'Error communicating with server.', 'error');
            }
        }, { title: 'Delete Order', confirmText: 'Delete', type: 'danger' });
    }

    async function deleteSelectedOrders() {
        const ids = Array.from(selectedOrderIds);
        if (!ids.length) {
            KapeKanto.toast('Select at least one order to delete.', 'warning');
            return;
        }

        KapeKanto.confirm(`Delete ${ids.length} selected order${ids.length === 1 ? '' : 's'}? This permanently removes the selected records.`, async () => {
            let deleted = 0;
            let failed = 0;

            for (const id of ids) {
                try {
                    const res = await fetch(`/api/orders/${id}`, { method: 'DELETE' });
                    if (res.ok) {
                        deleted++;
                        selectedOrderIds.delete(id);
                    } else {
                        failed++;
                    }
                } catch (e) {
                    failed++;
                }
            }

            KapeKanto.toast(`Deleted ${deleted} order${deleted === 1 ? '' : 's'}${failed ? `, ${failed} failed` : ''}.`, failed ? 'warning' : 'success');
            loadOrders();
        }, { title: 'Delete Selected Orders', confirmText: 'Delete Selected', type: 'danger' });
    }

    function openRiderModal(orderId) {
        pendingDispatchId = orderId;
        document.getElementById('rider-order-id').textContent = '#' + orderId;
        document.getElementById('rider-name').value = '';
        document.getElementById('rider-contact').value = '';
        document.getElementById('rider-modal').classList.add('open');
    }

    function closeRiderModal() {
        document.getElementById('rider-modal').classList.remove('open');
        pendingDispatchId = null;
    }

    async function confirmDispatch() {
        if (!pendingDispatchId) return;
        const orderId = pendingDispatchId;
        const riderName = document.getElementById('rider-name').value.trim();
        const riderContact = document.getElementById('rider-contact').value.trim();
        if (!riderName) {
            KapeKanto.toast('Rider Name is required to dispatch the order!', 'warning');
            document.getElementById('rider-name').focus();
            return;
        }
        closeRiderModal();
        await updateStatus(orderId, 'out_for_delivery', riderName, riderContact);
    }

    document.getElementById('rider-modal').addEventListener('click', (e) => {
        if (e.target === document.getElementById('rider-modal')) closeRiderModal();
    });

    function openChatModal(orderId) {
        activeChatOrderId = orderId;
        document.getElementById('chat-order-id').textContent = orderId;
        document.getElementById('chat-modal').classList.add('open');
        loadStaffChatMessages();
        if (chatRefreshInterval) clearInterval(chatRefreshInterval);
        chatRefreshInterval = setInterval(loadStaffChatMessages, 5000);
    }

    function closeChatModal() {
        activeChatOrderId = null;
        document.getElementById('chat-modal').classList.remove('open');
        if (chatRefreshInterval) clearInterval(chatRefreshInterval);
    }

    async function loadStaffChatMessages() {
        if (!activeChatOrderId) return;
        try {
            const res = await fetch(`/api/orders/${activeChatOrderId}/messages`);
            if (!res.ok) return;
            const messages = await res.json();
            const container = document.getElementById('chat-messages');
            
            if (!messages.length) {
                container.innerHTML = '<div style="text-align:center; color:var(--text-light); font-size:0.85rem; padding:1rem;">No messages yet.</div>';
                return;
            }

            const isAtBottom = container.scrollHeight - container.scrollTop <= container.clientHeight + 50;

            container.innerHTML = messages.map(m => {
                const isCustomer = m.role === 'customer';
                const time = KapeKanto.formatChatMessageDate(m.created_at);
                const senderName = isCustomer ? (m.username || 'Customer') : 'You';
                return `
                <div class="chat-msg ${isCustomer ? 'customer' : 'staff'}">
                    <div>${m.message}</div>
                    <div class="chat-meta">${senderName} · ${time}</div>
                </div>`;
            }).join('');

            if (isAtBottom) {
                container.scrollTop = container.scrollHeight;
            }
        } catch (e) {
            console.error('Failed to load messages');
        }
    }

    async function sendStaffChatMessage(e) {
        e.preventDefault();
        if (!activeChatOrderId) return;
        const input = document.getElementById('chat-input');
        const message = input.value.trim();
        if (!message) return;

        input.value = '';
        input.disabled = true;

        try {
            const res = await fetch(`/api/orders/${activeChatOrderId}/messages`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message })
            });
            if (res.ok) {
                await loadStaffChatMessages();
                const container = document.getElementById('chat-messages');
                container.scrollTop = container.scrollHeight;
            } else {
                KapeKanto.toast('Failed to send message', 'error');
            }
        } catch (e) {
            KapeKanto.toast('Error sending message', 'error');
        } finally {
            input.disabled = false;
            input.focus();
        }
    }

    document.getElementById('chat-modal').addEventListener('click', (e) => {
        if (e.target === document.getElementById('chat-modal')) closeChatModal();
    });

    // View Details Logic
    async function viewDetails(id) {
        const order = allOrders.find(o => o.id === id);
        if (!order) return;

        document.getElementById('so-modal-title').textContent = `Order #${id} — ${order.username}`;
        document.getElementById('so-modal-body').innerHTML = '<p style="color:var(--text-light)"><i class="fa-solid fa-circle-notch fa-spin"></i> Loading…</p>';
        document.getElementById('so-modal').classList.add('open');

        try {
            const res = await fetch(`/api/orders/my/${id}`);
            if (!res.ok) throw new Error();
            const data = await res.json();
            renderModalBody(data);
        } catch(e) {
            renderModalBodyBasic(order);
        }
    }

    function renderModalBody(order) {
        const itemsHtml = order.items.map(i => {
            let customizationsHtml = '';
            try {
                const custs = i.customizations ? JSON.parse(i.customizations) : {};
                const entries = Object.entries(custs);
                if (entries.length > 0) {
                    customizationsHtml = `<small style="color:#888; font-size:0.75rem; margin-top:2px;">${entries.map(([k,v])=>k+': '+v).join(', ')}</small>`;
                }
            } catch (e) {
                customizationsHtml = '';
            }

            return `
            <div class="so-item-row">
                <div style="display:flex; flex-direction:column;">
                    <span style="font-weight:700; color:var(--primary-dark);">${i.quantity}x ${i.name || 'Deleted Item'}</span>
                    ${customizationsHtml}
                </div>
                <span style="font-weight:700; color:var(--primary);">&#8369;${i.subtotal.toFixed(2)}</span>
            </div>`;
        }).join('');

        const vatExemptDiscount = order.sc_discount_amount > 0 ? (order.subtotal - (order.subtotal / 1.12)) : 0;
        const badgeCls = BADGE_MAP[order.status] || '';
        const isDelivery = order.order_type === 'delivery';

        document.getElementById('so-modal-body').innerHTML = `
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; background:#fdfaf7; padding:1rem; border-radius:16px; border:1px solid #f0e6e0;">
                <div>
                    <span class="so-detail-label">Status</span>
                    <span class="so-badge ${badgeCls}">${statusLabel(order.status, order.order_type)}</span>
                </div>
                <div style="text-align:right;">
                    <div style="font-size: 0.7rem; color: #999; text-transform: uppercase; font-weight: 800; margin-bottom: 4px;">Order Type</div>
                    <span style="font-size: 0.85rem; font-weight: 800; color: var(--primary); background: rgba(111, 78, 55, 0.08); padding: 6px 12px; border-radius: 50px; display: inline-flex; align-items: center; gap: 8px;">
                        <i class="fa-solid fa-${order.order_type === 'delivery' ? 'truck-fast' : 'shop'}"></i>
                        ${order.order_type === 'delivery' ? 'Delivery' : 'Pickup'}
                    </span>
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; margin-bottom:1.5rem;">
                <div>
                    <span class="so-detail-label">Customer</span>
                    <div class="so-detail-value">${order.username || 'Deleted User'}</div>
                    <div style="font-size:0.8rem; color:#777;">${order.email || 'No email registered'}</div>
                </div>
                <div style="text-align:right;">
                    <span class="so-detail-label">Payment</span>
                    <div class="so-detail-value">${order.payment_method.toUpperCase()}</div>
                    <div style="font-size:0.8rem; color:#777; font-weight:700;">${order.payment_status.toUpperCase()}</div>
                </div>
            </div>

            <div>
                <span class="so-detail-label" style="margin-bottom:1rem;">Order Items</span>
                ${itemsHtml}
            </div>

            <div style="margin-top:1.5rem;">
                <span class="so-detail-label">Price Breakdown</span>
                <div class="so-breakdown-row"><span>Subtotal (Gross)</span><span>&#8369;${order.subtotal.toFixed(2)}</span></div>
                
                ${order.sc_discount_amount > 0 ? `
                    <div class="so-breakdown-row red"><span>VAT-Exempt Discount (12%)</span><span>-&#8369;${vatExemptDiscount.toFixed(2)}</span></div>
                    <div class="so-breakdown-row red"><span>SC/PWD Discount (20%)</span><span>-&#8369;${order.sc_discount_amount.toFixed(2)}</span></div>
                ` : `
                    <div class="so-breakdown-row"><span>VAT (12% Inclusive)</span><span>&#8369;${(order.vat_amount||0).toFixed(2)}</span></div>
                `}

                ${order.promo_discount_amount > 0 ? `
                    <div class="so-breakdown-row red"><span>🏷️ Promo Discount</span><span>-&#8369;${order.promo_discount_amount.toFixed(2)}</span></div>
                ` : ''}

                <div class="so-breakdown-row"><span>Delivery Fee</span><span>&#8369;${(order.delivery_fee||0).toFixed(2)}</span></div>
                <div class="so-breakdown-row total"><span>Amount Due</span><span>&#8369;${order.total.toFixed(2)}</span></div>
            </div>

            ${order.delivery_address ? `
                <div style="margin-top:1.5rem; background:#fff5f5; padding:1rem; border-radius:12px; border:1px solid #ffebeb;">
                    <span class="so-detail-label" style="color:var(--danger);">Delivery Address</span>
                    <div style="font-size:0.9rem; color:var(--primary-dark); font-weight:500;">${order.delivery_address}</div>
                </div>
            ` : ''}

            ${order.notes ? `
                <div style="margin-top:1rem; background:#f0f7ff; padding:1rem; border-radius:12px; border:1px solid #e0eeff;">
                    <span class="so-detail-label" style="color:#007bff;">Admin/Kitchen Notes</span>
                    <div style="font-size:0.9rem; color:var(--primary-dark); font-weight:500;">${order.notes}</div>
                </div>
            ` : ''}
        `;
    }

    function renderModalBodyBasic(order) {
        document.getElementById('so-modal-body').innerHTML = `
            <p><strong>Type:</strong> ${order.order_type}</p>
            <p><strong>Status:</strong> ${order.status}</p>
            <p><strong>Total:</strong> &#8369;${order.total.toFixed(2)}</p>
            ${order.delivery_address ? `<p><strong>Address:</strong> ${order.delivery_address}</p>` : ''}
            <p style="color:var(--text-light);font-size:0.85rem;margin-top:1rem;">Item details unavailable.</p>`;
    }

    function closeDetailsModal() {
        document.getElementById('so-modal').classList.remove('open');
    }

    document.getElementById('so-modal').addEventListener('click', (e) => {
        if (e.target === document.getElementById('so-modal')) closeDetailsModal();
    });

    document.addEventListener('DOMContentLoaded', () => {
        loadOrders();
        setInterval(loadOrders, 30000);

        window.addEventListener('kk-new-chat-message', (e) => {
            if (e.detail && String(e.detail.orderId) === String(activeChatOrderId)) {
                loadStaffChatMessages();
            }
        });

        window.addEventListener('kk-new-order', () => {
            loadOrders();
        });

        window.addEventListener('kk-order-updated', () => {
            loadOrders();
        });
    });
</script>

<%- include('../partials/footer') %>
