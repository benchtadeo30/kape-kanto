<%- include('../partials/header') %>

<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh; padding: 2rem 5%; background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);">
    <div class="card" style="width: 100%; max-width: 450px; padding: 3rem; border-radius: var(--radius-lg); box-shadow: 0 20px 60px rgba(0,0,0,0.3); background: rgba(255,255,255,0.97); backdrop-filter: blur(10px);">
        <div style="text-align: center; margin-bottom: 2.5rem;">
            <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #1a1a2e, #0f3460); color: #e9c46a; border-radius: 15px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.5rem; box-shadow: 0 8px 24px rgba(15,52,96,0.3);">
                <i class="fa-solid fa-shield-halved"></i>
            </div>
            <h1 style="font-size: 2rem; margin: 0; color: #1a1a2e;">Staff Portal</h1>
            <p style="color: var(--text-light); margin-top: 0.5rem; font-size: 0.9rem;">Authorized personnel only</p>
        </div>
        
        <form id="staff-login-form">
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label style="font-weight: 600; color: #1a1a2e; margin-bottom: 0.5rem; display: block;">Email Address</label>
                <input type="email" id="email" placeholder="Enter your staff email" required 
                    style="width: 100%; padding: 1rem; border-radius: 12px; border: 1.5px solid #e0e0e0; outline: none; transition: border-color 0.2s; background: #f8f9fa;">
            </div>
            
            <div class="form-group" style="margin-bottom: 1rem;">
                <label style="font-weight: 600; color: #1a1a2e; margin-bottom: 0.5rem; display: block;">Password</label>
                <div style="position: relative; display: flex; align-items: center;">
                    <input type="password" id="password" placeholder="••••••••" required 
                        style="width: 100%; padding: 1rem 3.5rem 1rem 1rem; border-radius: 12px; border: 1.5px solid #e0e0e0; outline: none; transition: all 0.2s; background: #f8f9fa;">
                    <div id="toggle-password" 
                        style="position: absolute; right: 1rem; cursor: pointer; color: #1a1a2e; z-index: 100; display: flex; align-items: center; justify-content: center; padding: 5px; width: 30px; height: 30px; transition: opacity 0.2s;">
                        <i class="fa-solid fa-eye" style="font-size: 1.1rem;"></i>
                    </div>
                </div>
            </div>
            
            <button type="submit" class="btn" style="width: 100%; padding: 1.2rem; font-size: 1.1rem; border-radius: 50px; margin-top: 1.5rem; background: linear-gradient(135deg, #1a1a2e, #0f3460); color: white; border: none; cursor: pointer; font-weight: 700; transition: all 0.3s; box-shadow: 0 4px 15px rgba(15,52,96,0.3);"
                onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(15,52,96,0.4)'"
                onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(15,52,96,0.3)'"
            >
                <i class="fa-solid fa-right-to-bracket" style="margin-right: 8px;"></i>Sign In
            </button>
        </form>
        
        <div style="text-align: center; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid #f0f0f0;">
            <p style="font-size: 0.85rem; color: var(--text-light);">
                <i class="fa-solid fa-circle-info" style="margin-right: 4px;"></i>
                This portal is for admin and staff accounts only.
            </p>
        </div>
    </div>
</div>

<script>
    document.getElementById('staff-login-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const email = document.getElementById('email').value.trim();
        const password = document.getElementById('password').value;
        const btn = e.target.querySelector('button[type="submit"]');
        
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Signing in...';

        try {
            const res = await fetch('/api/auth/staff-login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, password })
            });
            
            const data = await res.json();
            
            if (res.ok) {
                KapeKanto.toast('Welcome back!', 'success');
                setTimeout(() => {
                    if (data.role === 'admin') window.location.href = '/admin/dashboard';
                    else if (data.role === 'staff') window.location.href = '/staff/dashboard';
                    else window.location.href = '/';
                }, 1200);
            } else {
                KapeKanto.toast(data.error, 'error');
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-right-to-bracket" style="margin-right: 8px;"></i>Sign In';
            }
        } catch (error) {
            KapeKanto.toast('Network error occurred.', 'error');
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-right-to-bracket" style="margin-right: 8px;"></i>Sign In';
        }
    });

    // Toggle Password Visibility
    const togglePassword = document.getElementById('toggle-password');
    const passwordInput = document.getElementById('password');

    if (togglePassword && passwordInput) {
        togglePassword.addEventListener('click', () => {
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            const icon = togglePassword.querySelector('i');
            if (type === 'text') {
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        });
    }

    // Input focus animation
    document.querySelectorAll('input').forEach(input => {
        input.addEventListener('focus', () => input.style.borderColor = '#0f3460');
        input.addEventListener('blur', () => input.style.borderColor = '#e0e0e0');
    });
</script>

<%- include('../partials/footer') %>
