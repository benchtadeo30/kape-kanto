<style>
    .admin-modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(44, 34, 28, 0.6);
        backdrop-filter: blur(8px);
        z-index: 2000;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        animation: modalFadeIn 0.3s ease;
    }
    .modal-content {
        background: white;
        width: 100%;
        max-width: 500px;
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        animation: modalSlideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .modal-header {
        padding: 1.5rem 2rem;
        background: #fdfaf7;
        border-bottom: 1px solid #f0e6e0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .modal-body { padding: 2rem; }
    .modal-footer {
        padding: 1.5rem 2rem;
        background: #fcfcfc;
        border-top: 1px solid #eee;
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
    }
    @keyframes modalFadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes modalSlideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    
    .user-table th { color: #999; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1px; padding: 1rem; border-bottom: 1px solid #f0e6e0; }
    .user-row:hover { background: #fdfaf7 !important; }
</style>

<%- include('../partials/header') %>
<style>
    @media (max-width: 900px) {
        .user-header-row {
            flex-direction: column;
            align-items: stretch !important;
            gap: 1.5rem !important;
        }
        .user-controls {
            flex-direction: column;
            align-items: stretch !important;
            width: 100%;
        }
        .user-controls > div {
            width: 100% !important;
        }
        .hide-mobile {
            display: none;
        }
        .verification-header {
            flex-direction: column;
            align-items: stretch !important;
        }
        .verification-header > div {
            justify-content: flex-start !important;
            width: 100%;
        }
        .verification-header input {
            max-width: none !important;
        }
    }
    @media (min-width: 901px) {
        .hide-mobile {
            display: inline;
        }
    }
<div class="dashboard-layout">
    <%- include('../partials/admin-sidebar', { activePage: 'user' }) %>
    <main>
        <div class="admin-header-row">
            <div>
                <h1 style="margin: 0; font-size: 2.8rem; color: var(--primary-dark); font-weight: 800;">User Management</h1>
                <p style="color: var(--text-light); margin-top: 5px; font-size: 1.1rem; font-weight: 500;">Manage administrative staff and customer accounts.</p>
            </div>
            <button class="btn btn-primary" onclick="openCreateModal()" style="font-weight: 700; font-size: 1.1rem; padding: 14px 2rem; border-radius: 16px;">+ New Account</button>
        </div>

        <!-- Pending ID Verifications Section -->
        <div class="card" id="id-verifications-card" style="padding: 0; overflow: hidden; border: 1px solid #f0e6e0; margin-bottom: 2rem; display: none;">
            <div class="verification-header" style="padding: 1.5rem 2rem; background: linear-gradient(135deg, #fff8e1, #fff3e0); border-bottom: 1px solid #ffe082; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                <div style="display: flex; align-items: center; gap: 12px;">
                    <div style="width: 40px; height: 40px; border-radius: 12px; background: #f57f17; color: white; display: flex; align-items: center; justify-content: center; font-size: 1.1rem;">
                        <i class="fa-solid fa-id-card-clip"></i>
                    </div>
                    <div>
                        <h3 style="margin: 0; color: #e65100; font-size: 1.3rem;">Pending ID Verifications</h3>
                        <p style="margin: 0; font-size: 0.85rem; color: #bf360c;" id="pending-count-text">Loading...</p>
                    </div>
                </div>
                <div style="display: flex; align-items: center; gap: 10px; flex-grow: 1; justify-content: flex-end; min-width: 250px;">
                    <div style="position: relative; flex-grow: 1; max-width: 300px;">
                        <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #f57f17; opacity: 0.7;"></i>
                        <input type="text" id="verification-search" placeholder="Search ID number..." oninput="debounceVerificationSearch()"
                            style="width: 100%; padding: 10px 1rem 10px 2.5rem; border-radius: 12px; border: 1px solid #ffcc80; outline: none; font-size: 0.9rem; background: white;">
                    </div>
                    <button onclick="loadPendingVerifications()" style="background: white; border: 1px solid #ffcc80; padding: 10px 16px; border-radius: 12px; cursor: pointer; color: #e65100; font-weight: 600; font-size: 0.85rem; display: flex; align-items: center; gap: 6px;">
                        <i class="fa-solid fa-arrows-rotate"></i> <span class="hide-mobile">Refresh</span>
                    </button>
                </div>
            </div>
            <div id="pending-verifications-list" style="padding: 1.5rem;">
                <!-- Populated by JS -->
            </div>
            <div id="verification-pagination" style="display: flex; justify-content: center; gap: 8px; align-items: center; padding: 1.2rem; background: #fffcf5; border-top: 1px solid #ffe082;">
                <!-- Pagination buttons -->
            </div>
        </div>

        <!-- Image Lightbox -->
        <div id="image-lightbox" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 9999; justify-content: center; align-items: center; cursor: zoom-out;" onclick="this.style.display='none'">
            <img id="lightbox-img" src="" style="max-width: 90vw; max-height: 90vh; border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,0.5);">
        </div>

        <!-- Reject / Resubmit Reason Modal -->
        <div id="reason-modal" class="admin-modal">
            <div class="modal-content" style="max-width: 450px;">
                <div class="modal-header">
                    <h3 id="reason-modal-title"><i class="fa-solid fa-comment-dots" style="margin-right: 10px; color: var(--primary);"></i> Provide Reason</h3>
                    <button onclick="closeReasonModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #999;">&times;</button>
                </div>
                <div class="modal-body">
                    <label style="display: block; margin-bottom: 8px; font-weight: 600; color: #333;">Reason / Message to User</label>
                    <textarea id="reason-text" rows="4" placeholder="Explain why the ID was rejected or what needs to be resubmitted..."
                        style="width: 100%; padding: 12px 16px; border: 1px solid #e0d4c8; border-radius: 12px; font-size: 0.95rem; resize: vertical; outline: none; font-family: inherit;"></textarea>
                </div>
                <div class="modal-footer">
                    <button onclick="closeReasonModal()" style="padding: 10px 20px; border-radius: 10px; border: 1px solid #ddd; background: white; cursor: pointer; font-weight: 600;">Cancel</button>
                    <button id="reason-submit-btn" onclick="submitReason()" style="padding: 10px 20px; border-radius: 10px; border: none; color: white; cursor: pointer; font-weight: 700;">Submit</button>
                </div>
            </div>
        </div>

        <div class="card" style="padding: 0; overflow: hidden; border: 1px solid #f0e6e0;">
            <div class="table-header-row" style="padding: 1.5rem; background: #fdfaf7; border-bottom: 1px solid #f0e6e0; margin-bottom: 0;">
                <h3 style="margin: 0;">System Accounts</h3>
                <div style="position: relative; width: 100%; max-width: 300px;">
                    <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #999;"></i>
                    <input type="text" id="user-search" placeholder="Search accounts..." oninput="debounceSearch()"
                        style="width: 100%; padding: 12px 1rem 12px 2.5rem; border-radius: 12px; border: 1px solid #f0e6e0; outline: none; font-size: 1rem;">
                </div>
            </div>
            <div id="user-list">
                <!-- Content -->
            </div>
            <div id="user-pagination" style="display: flex; justify-content: center; gap: 8px; align-items: center; padding: 1.5rem; background: #fdfaf7; border-top: 1px solid #f0e6e0;"></div>
        </div>
    </main>
</div>

<!-- Create User Modal -->
<div id="create-modal" class="admin-modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fa-solid fa-user-plus" style="margin-right: 10px; color: var(--primary);"></i> Create New Account</h3>
            <button onclick="closeCreateModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #999;">&times;</button>
        </div>
        <form id="create-form" onsubmit="handleCreate(event)">
            <div class="modal-body">
                <div style="display: grid; gap: 1.5rem;">
                    <div>
                        <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Username</label>
                        <input type="text" id="new-username" required placeholder="e.g. jondoe" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee;">
                    </div>
                    <div>
                        <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Email Address</label>
                        <input type="email" id="new-email" required placeholder="e.g. jon@gmail.com" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee;">
                        <p id="new-email-hint" style="font-size: 0.75rem; color: var(--primary); margin-top: 5px; font-weight: 600;">
                            <i class="fa-solid fa-circle-info"></i> Customer accounts require @gmail.com
                        </p>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                        <div>
                            <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Role</label>
                            <select id="new-role" class="kk-select-modern" required>
                                <option value="customer" data-icon="fa-user">Customer</option>
                                <option value="staff" data-icon="fa-user-tie">Staff</option>
                                <option value="admin" data-icon="fa-user-shield">Admin</option>
                            </select>
                        </div>
                        <div>
                            <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Password</label>
                            <input type="password" id="new-password" required placeholder="••••••••" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee;">
                            <p style="font-size: 0.7rem; color: #888; margin-top: 5px; line-height: 1.3;">
                                <i class="fa-solid fa-circle-info"></i> 5+ chars, 1 upper, 2 numbers, 1 special.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeCreateModal()" style="background: #bca08d; border: none; color: white; font-weight: 600;">Cancel</button>
                <button type="submit" class="btn btn-primary" style="padding-left: 2rem; padding-right: 2rem;">Create Account</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit User Modal -->
<div id="edit-modal" class="admin-modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fa-solid fa-user-pen" style="margin-right: 10px; color: var(--primary);"></i> Edit Account</h3>
            <button onclick="closeEditModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #999;">&times;</button>
        </div>
        <form id="edit-form" onsubmit="handleUpdate(event)">
            <input type="hidden" id="edit-id">
            <div class="modal-body">
                <div style="display: grid; gap: 1.5rem;">
                    <div>
                        <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Username</label>
                        <input type="text" id="edit-username" required placeholder="e.g. jondoe" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee;">
                    </div>
                    <div>
                        <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Email Address</label>
                        <input type="email" id="edit-email" required style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee;">
                        <p id="edit-email-hint" style="font-size: 0.75rem; color: var(--primary); margin-top: 5px; font-weight: 600;"></p>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                        <div>
                            <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Role</label>
                            <select id="edit-role" class="kk-select-modern" required>
                                <option value="customer" data-icon="fa-user">Customer</option>
                                <option value="staff" data-icon="fa-user-tie">Staff</option>
                                <option value="admin" data-icon="fa-user-shield">Admin</option>
                            </select>
                        </div>
                        <div>
                            <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">New Password (Optional)</label>
                            <input type="password" id="edit-password" placeholder="Leave blank to keep current" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee;">
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeEditModal()" style="background: #bca08d; border: none; color: white; font-weight: 600;">Cancel</button>
                <button type="submit" class="btn btn-primary" style="padding-left: 2rem; padding-right: 2rem;">Update Account</button>
            </div>
        </form>
    </div>
</div>

<script>
    let userPage = 1;
    const PAGE_LIMIT = 10;
    let searchTimeout = null;

    function debounceSearch() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
            userPage = 1;
            loadData();
        }, 400);
    }

    async function loadData() {
        try {
            const search = document.getElementById('user-search').value.trim();
            const offset = (userPage - 1) * PAGE_LIMIT;
            const userRes = await fetch(`/api/users?limit=${PAGE_LIMIT}&offset=${offset}&search=${encodeURIComponent(search)}`);
            if (userRes.ok) {
                const data = await userRes.json();
                renderUsers(data.items);
                renderPagination(userPage, data.total);
            }
        } catch (e) {
            console.error(e);
        }
    }

    function renderPagination(current, total) {
        const container = document.getElementById('user-pagination');
        const totalPages = Math.ceil(total / PAGE_LIMIT);
        
        if (totalPages <= 1) {
            container.innerHTML = '';
            return;
        }

        const prevPage = current === 1 ? totalPages : current - 1;
        const nextPage = current === totalPages ? 1 : current + 1;

        let html = `
            <div style="display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap;">
                <button class="btn btn-secondary" style="width: 38px; height: 38px; padding: 0; border-radius: 10px; display: flex; align-items: center; justify-content: center;" onclick="changePage(${prevPage})">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>`;

        const limit = 10;
        let startPage = Math.max(1, current - Math.floor(limit / 2));
        let endPage = Math.min(totalPages, startPage + limit - 1);
        
        if (endPage - startPage < limit - 1) {
            startPage = Math.max(1, endPage - limit + 1);
        }

        for (let i = startPage; i <= endPage; i++) {
            html += `<button class="btn ${i === current ? 'btn-primary' : 'btn-outline'}" 
                             onclick="changePage(${i})" 
                             style="width: 36px; height: 36px; padding: 0; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700;">${i}</button>`;
        }

        html += `
                <button class="btn btn-secondary" style="width: 38px; height: 38px; padding: 0; border-radius: 10px; display: flex; align-items: center; justify-content: center;" onclick="changePage(${nextPage})">
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </div>
        `;
        
        container.innerHTML = html;
    }

    window.changePage = (p) => {
        userPage = p;
        loadData();
    };

    window.openCreateModal = () => {
        document.getElementById('create-modal').style.display = 'flex';
        document.getElementById('create-form').reset();
        updateEmailHint('new');
    };

    function updateEmailHint(prefix) {
        const role = document.getElementById(`${prefix}-role`).value;
        const hint = document.getElementById(`${prefix}-email-hint`);
        const input = document.getElementById(`${prefix}-email`);
        
        if (role === 'customer') {
            if (hint) hint.innerHTML = '<i class="fa-solid fa-circle-info"></i> Customer accounts require @gmail.com';
            if (hint) hint.style.color = 'var(--primary)';
            input.placeholder = 'e.g. user@gmail.com';
        } else {
            if (hint) hint.innerHTML = '<i class="fa-solid fa-building-user"></i> Internal accounts require @kapekantohub.com';
            if (hint) hint.style.color = '#2e7d32';
            input.placeholder = 'e.g. staff@kapekantohub.com';
        }
    }

    document.getElementById('new-role').addEventListener('change', () => updateEmailHint('new'));
    document.getElementById('edit-role').addEventListener('change', () => updateEmailHint('edit'));

    window.closeCreateModal = () => {
        document.getElementById('create-modal').style.display = 'none';
    };

    window.openEditModal = (id, username, email, role) => {
        document.getElementById('edit-id').value = id;
        document.getElementById('edit-username').value = username;
        document.getElementById('edit-email').value = email;
        document.getElementById('edit-role').value = role;
        document.getElementById('edit-password').value = '';
        updateEmailHint('edit');
        document.getElementById('edit-modal').style.display = 'flex';
    };

    window.closeEditModal = () => {
        document.getElementById('edit-modal').style.display = 'none';
    };

    window.handleCreate = async (e) => {
        e.preventDefault();
        const form = e.target;
        
        if (!KapeKanto.validate(form)) return;

        const username = document.getElementById('new-username').value.trim();
        const email = document.getElementById('new-email').value.trim().toLowerCase();
        const role = document.getElementById('new-role').value;
        const password = document.getElementById('new-password').value;

        // Domain Logic: Customers MUST use Gmail. Admin/Staff MUST use kapekantohub.com
        if (role === 'customer' && !email.endsWith('@gmail.com')) {
            KapeKanto.toast('Customer accounts require a valid @gmail.com address.', 'error');
            return;
        }

        if (role !== 'customer' && !email.endsWith('@kapekantohub.com')) {
            KapeKanto.toast('Internal accounts (Admin/Staff) must use @kapekantohub.com.', 'error');
            return;
        }

        const passwordRegex = /^(?=.*[A-Z])(?=.*[0-9].*[0-9])(?=.*[!@#$%^&*_])(?=.{5,})/;
        if (!passwordRegex.test(password)) {
            KapeKanto.toast('Password needs 5+ chars, 1 uppercase, 2 numbers, 1 special char (including _).', 'error');
            return;
        }

        try {
            const res = await fetch('/api/users', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, email, role, password })
            });

            const data = await res.json();
            if (res.ok) {
                KapeKanto.toast('Account created successfully!', 'success');
                closeCreateModal();
                loadData();
            } else {
                KapeKanto.toast(data.error || 'Failed to create account', 'error');
            }
        } catch (err) {
            KapeKanto.toast('Connection error', 'error');
        }
    };

    window.handleUpdate = async (e) => {
        e.preventDefault();
        const id = document.getElementById('edit-id').value;
        const username = document.getElementById('edit-username').value.trim();
        const email = document.getElementById('edit-email').value.trim().toLowerCase();
        const role = document.getElementById('edit-role').value;
        const password = document.getElementById('edit-password').value;

        // Domain Logic
        if (role === 'customer' && !email.endsWith('@gmail.com')) {
            KapeKanto.toast('Customer accounts require a valid @gmail.com address.', 'error');
            return;
        }
        if (role !== 'customer' && !email.endsWith('@kapekantohub.com')) {
            KapeKanto.toast('Internal accounts (Admin/Staff) must use @kapekantohub.com.', 'error');
            return;
        }

        const payload = { username, email, role };
        if (password) {
            const passwordRegex = /^(?=.*[A-Z])(?=.*[0-9].*[0-9])(?=.*[!@#$%^&*_])(?=.{5,})/;
            if (!passwordRegex.test(password)) {
                KapeKanto.toast('Password needs 5+ chars, 1 uppercase, 2 numbers, 1 special char.', 'error');
                return;
            }
            payload.password = password;
        }

        try {
            const res = await fetch(`/api/users/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (res.ok) {
                KapeKanto.toast('Account updated successfully', 'success');
                closeEditModal();
                loadData();
            } else {
                const data = await res.json();
                KapeKanto.toast(data.error || 'Update failed', 'error');
            }
        } catch (e) {
            KapeKanto.toast('Network error', 'error');
        }
    };

    function renderUsers(users) {
        const container = document.getElementById('user-list');
        if (users.length === 0) {
            container.innerHTML = '<p style="text-align: center; padding: 4rem; color: #999;">No accounts found.</p>';
            return;
        }

        let html = `
            <table class="user-table" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr>
                        <th style="text-align: left; padding-left: 2rem;">User Identity</th>
                        <th style="text-align: left;">Role</th>
                        <th style="text-align: right; padding-right: 2rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>`;
        
        users.forEach(u => {
            const roleClass = u.role === 'admin' ? 'var(--primary)' : (u.role === 'staff' ? '#2e7d32' : '#666');
            const roleBg = u.role === 'admin' ? '#fdfaf7' : (u.role === 'staff' ? '#e8f5e9' : '#f5f5f5');

            // Robust Avatar Logic: Use uploaded image or fallback to first letter
            const avatarHtml = (u.profile_image && u.profile_image.trim() !== '') 
                ? `<img src="/uploads/profiles/${u.profile_image}" alt="${u.username}" style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px;">`
                : `<span style="font-size: 1.2rem;">${(u.username || 'U').charAt(0).toUpperCase()}</span>`;

            html += `
                <tr class="user-row" style="border-bottom: 1px solid #fcfcfc;">
                    <td data-label="User Identity" style="padding: 1.2rem 2rem;">
                        <div style="display: flex; align-items: center; gap: 15px;">
                            <div style="width: 48px; height: 48px; border-radius: 14px; background: #f7f2ef; display: flex; align-items: center; justify-content: center; color: var(--primary); font-weight: 800; border: 1.5px solid #eee; text-transform: uppercase; overflow: hidden; flex-shrink: 0; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);">
                                ${avatarHtml}
                            </div>
                            <div style="overflow: hidden;">
                                <div style="font-weight: 700; color: var(--admin-primary); white-space: nowrap; text-overflow: ellipsis; overflow: hidden; font-size: 1.15rem;">${u.username}</div>
                                <div style="font-size: 0.95rem; color: #999; white-space: nowrap; text-overflow: ellipsis; overflow: hidden;">${u.email}</div>
                            </div>
                        </div>
                    </td>
                    <td data-label="Role">
                        <span style="display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; border-radius: 50px; background: ${roleBg}; color: ${roleClass}; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; border: 1px solid rgba(0,0,0,0.05);">
                            <i class="fa-solid fa-${u.role === 'admin' ? 'user-shield' : (u.role === 'staff' ? 'user-tie' : 'user')}"></i>
                            ${u.role}
                        </span>
                    </td>
                    <td data-label="Actions" style="text-align: right; padding-right: 2rem;">
                        <button class="btn btn-outline" style="padding: 8px 12px; border-radius: 10px; margin-right: 5px;" onclick="openEditModal(${u.id}, '${escapeJs(u.username)}', '${escapeJs(u.email)}', '${u.role}')">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button class="btn btn-danger" style="background: transparent; color: #f44336; border: 1px solid #ffebee; padding: 8px 12px; border-radius: 10px;" onclick="deleteUser(${u.id})">
                            <i class="fa-solid fa-trash-can"></i>
                        </button>
                    </td>
                </tr>`;
        });
        
        html += '</tbody></table>';
        container.innerHTML = html;
    }

    function escapeJs(str) {
        if (!str) return '';
        return str.replace(/'/g, "\\'");
    }

    async function deleteUser(id) {
        KapeKanto.confirm('Are you sure you want to delete this user? This action cannot be undone.', async () => {
            try {
                const res = await fetch(`/api/users/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    KapeKanto.toast('User deleted successfully', 'success');
                    loadData();
                } else {
                    const data = await res.json();
                    KapeKanto.toast(data.error || 'Failed to delete user', 'error');
                }
            } catch(e) { 
                KapeKanto.toast('Server error while deleting user', 'error'); 
            }
        }, { title: 'Delete User', confirmText: 'Yes, Delete', type: 'danger' });
    }

    // ── ID Verification Admin Logic ─────────────────────────────────

    let reasonAction = null;
    let reasonUserId = null;
    let currentVerificationPage = 0;
    const verificationLimit = 5;
    let verificationSearchTimeout = null;

    function debounceVerificationSearch() {
        clearTimeout(verificationSearchTimeout);
        verificationSearchTimeout = setTimeout(() => {
            currentVerificationPage = 0;
            loadPendingVerifications();
        }, 400);
    }

    async function loadPendingVerifications() {
        try {
            const search = document.getElementById('verification-search').value;
            const offset = currentVerificationPage * verificationLimit;
            
            const res = await fetch(`/api/users/id-verifications/pending?limit=${verificationLimit}&offset=${offset}&search=${encodeURIComponent(search)}`);
            const data = await res.json();
            
            const card = document.getElementById('id-verifications-card');
            const list = document.getElementById('pending-verifications-list');
            const countText = document.getElementById('pending-count-text');

            if (!data.items || (data.items.length === 0 && !search && currentVerificationPage === 0)) {
                card.style.display = 'none';
                return;
            }

            card.style.display = 'block';
            countText.textContent = `${data.total} total submission${data.total !== 1 ? 's' : ''}`;

            if (data.items.length === 0) {
                list.innerHTML = `<div style="text-align: center; padding: 3rem; color: #999;">
                    <i class="fa-solid fa-magnifying-glass" style="font-size: 2rem; margin-bottom: 1rem; display: block; opacity: 0.3;"></i>
                    No matching verifications found.
                </div>`;
                document.getElementById('verification-pagination').innerHTML = '';
                return;
            }

            list.innerHTML = data.items.map(u => {
                let notes = {};
                try { notes = JSON.parse(u.id_verification_notes || '{}'); } catch(e) {}
                const idType = notes.id_type || (u.senior_id_image ? 'senior' : 'pwd');
                const idLabel = idType === 'senior' ? 'Senior Citizen' : 'PWD';
                const idImage = u.senior_id_image || u.pwd_id_image;
                
                // Formatted date with AM/PM
                const submittedAt = notes.submitted_at ? new Date(notes.submitted_at).toLocaleString('en-US', { 
                    month: 'short', day: 'numeric', year: 'numeric', 
                    hour: '2-digit', minute: '2-digit', hour12: true 
                }) : 'Unknown';

                return `
                <div style="border: 1px solid #f0e6e0; border-radius: 16px; padding: 1.5rem; margin-bottom: 1rem; background: white; transition: box-shadow 0.3s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,0.08)'" onmouseout="this.style.boxShadow='none'">
                    <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: flex-start;">
                        
                        <!-- User Info -->
                        <div style="flex: 1; min-width: 200px;">
                            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                                <div style="width: 44px; height: 44px; border-radius: 12px; background: #f7f2ef; display: flex; align-items: center; justify-content: center; color: var(--primary); font-weight: 800; font-size: 1.1rem;">
                                    ${(u.username || 'U').charAt(0).toUpperCase()}
                                </div>
                                <div>
                                    <div style="font-weight: 700; font-size: 1.1rem; color: #333;">${u.username}</div>
                                    <div style="font-size: 0.85rem; color: #999;">${u.email}</div>
                                </div>
                            </div>
                            <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px;">
                                <span style="padding: 4px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 700; background: ${idType === 'senior' ? '#e3f2fd' : '#f3e5f5'}; color: ${idType === 'senior' ? '#1565c0' : '#7b1fa2'};">
                                    <i class="fa-solid fa-${idType === 'senior' ? 'person-cane' : 'wheelchair'}"></i> ${idLabel} ID
                                </span>
                                ${u.id_number ? `<span style="padding: 4px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 600; background: #f5f5f5; color: #666; font-family: monospace;">ID# ${u.id_number}</span>` : ''}
                            </div>
                            <div style="font-size: 0.8rem; color: #aaa;">
                                <i class="fa-regular fa-clock"></i> Submitted: ${submittedAt}
                            </div>
                            ${u.duplicate_warning ? `
                            <div style="margin-top: 10px; padding: 8px 12px; background: #fff3e0; border: 1px solid #ffcc80; border-radius: 10px;">
                                <p style="margin: 0; font-size: 0.8rem; color: #e65100; font-weight: 600;">
                                    <i class="fa-solid fa-triangle-exclamation"></i> ${u.duplicate_warning}
                                </p>
                            </div>` : ''}
                        </div>

                        <!-- ID Image -->
                        <div style="text-align: center;">
                            <p style="margin: 0 0 6px 0; font-size: 0.7rem; text-transform: uppercase; color: #999; font-weight: 600; letter-spacing: 0.5px;">ID Photo</p>
                            ${idImage ? `<img src="${idImage}" style="width: 130px; height: 90px; object-fit: cover; border-radius: 10px; border: 2px solid #f0e6e0; cursor: pointer; transition: transform 0.2s;" onclick="openLightbox('${idImage}')" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">` : '<div style="width: 130px; height: 90px; background: #f5f5f5; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #ccc;"><i class="fa-solid fa-image" style="font-size: 1.5rem;"></i></div>'}
                        </div>

                        <!-- Selfie Image -->
                        <div style="text-align: center;">
                            <p style="margin: 0 0 6px 0; font-size: 0.7rem; text-transform: uppercase; color: #999; font-weight: 600; letter-spacing: 0.5px;">Selfie</p>
                            ${u.selfie_image ? `<img src="${u.selfie_image}" style="width: 130px; height: 90px; object-fit: cover; border-radius: 10px; border: 2px solid #f0e6e0; cursor: pointer; transition: transform 0.2s;" onclick="openLightbox('${u.selfie_image}')" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">` : '<div style="width: 130px; height: 90px; background: #f5f5f5; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #ccc;"><i class="fa-solid fa-image" style="font-size: 1.5rem;"></i></div>'}
                        </div>

                        <!-- Action Buttons -->
                        <div style="display: flex; flex-direction: column; gap: 8px; min-width: 140px; flex-grow: 1;">
                            <button onclick="approveId(${u.id})" style="padding: 10px 16px; border-radius: 10px; border: none; background: #2e7d32; color: white; font-weight: 700; cursor: pointer; font-size: 0.85rem; transition: background 0.2s;" onmouseover="this.style.background='#1b5e20'" onmouseout="this.style.background='#2e7d32'">
                                <i class="fa-solid fa-check"></i> Approve
                            </button>
                            <button onclick="openReasonModal(${u.id}, 'reject')" style="padding: 10px 16px; border-radius: 10px; border: 1px solid #ef5350; background: white; color: #c62828; font-weight: 700; cursor: pointer; font-size: 0.85rem; transition: all 0.2s;" onmouseover="this.style.background='#ffebee'" onmouseout="this.style.background='white'">
                                <i class="fa-solid fa-xmark"></i> Reject
                            </button>
                            <button onclick="openReasonModal(${u.id}, 'resubmit')" style="padding: 10px 16px; border-radius: 10px; border: 1px solid #ff9800; background: white; color: #e65100; font-weight: 700; cursor: pointer; font-size: 0.85rem; transition: all 0.2s;" onmouseover="this.style.background='#fff3e0'" onmouseout="this.style.background='white'">
                                <i class="fa-solid fa-rotate-right"></i> Resubmit
                            </button>
                        </div>
                    </div>
                </div>`;
            }).join('');

            renderVerificationPagination(data.total);
        } catch (err) {
            console.error('Failed to load pending verifications:', err);
        }
    }

    function renderVerificationPagination(total) {
        const container = document.getElementById('verification-pagination');
        const totalPages = Math.ceil(total / verificationLimit);
        
        if (totalPages <= 1) {
            container.innerHTML = '';
            return;
        }

        let html = '';
        
        // Previous Button
        html += `<button onclick="changeVerificationPage(${currentVerificationPage - 1})" class="btn-page" ${currentVerificationPage === 0 ? 'disabled' : ''} style="padding: 8px 12px; border-radius: 8px; border: 1px solid #ffcc80; background: white; color: #e65100; cursor: pointer; opacity: ${currentVerificationPage === 0 ? '0.5' : '1'}"><i class="fa-solid fa-chevron-left"></i></button>`;
        
        // Page Info
        html += `<span style="font-weight: 600; color: #e65100; font-size: 0.9rem;">Page ${currentVerificationPage + 1} of ${totalPages}</span>`;
        
        // Next Button
        html += `<button onclick="changeVerificationPage(${currentVerificationPage + 1})" class="btn-page" ${currentVerificationPage >= totalPages - 1 ? 'disabled' : ''} style="padding: 8px 12px; border-radius: 8px; border: 1px solid #ffcc80; background: white; color: #e65100; cursor: pointer; opacity: ${currentVerificationPage >= totalPages - 1 ? '0.5' : '1'}"><i class="fa-solid fa-chevron-right"></i></button>`;
        
        container.innerHTML = html;
    }

    function changeVerificationPage(page) {
        currentVerificationPage = page;
        loadPendingVerifications();
        document.getElementById('id-verifications-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function openLightbox(src) {
        const lb = document.getElementById('image-lightbox');
        document.getElementById('lightbox-img').src = src;
        lb.style.display = 'flex';
    }

    async function approveId(userId) {
        KapeKanto.confirm('Are you sure you want to approve this ID? The user will receive a 20% discount.', async () => {
            try {
                const res = await fetch(`/api/users/${userId}/approve-id`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                const data = await res.json();
                if (res.ok) {
                    KapeKanto.toast(data.message, 'success');
                    loadPendingVerifications();
                } else {
                    KapeKanto.toast(data.error, 'error');
                }
            } catch(e) { KapeKanto.toast('Server error', 'error'); }
        }, { title: 'Approve ID', confirmText: 'Yes, Approve', type: 'success' });
    }

    function openReasonModal(userId, action) {
        reasonUserId = userId;
        reasonAction = action;
        const modal = document.getElementById('reason-modal');
        const title = document.getElementById('reason-modal-title');
        const btn = document.getElementById('reason-submit-btn');
        document.getElementById('reason-text').value = '';

        if (action === 'reject') {
            title.innerHTML = '<i class="fa-solid fa-ban" style="margin-right: 10px; color: #c62828;"></i> Reject Verification';
            btn.style.background = '#c62828';
            btn.textContent = 'Reject';
        } else {
            title.innerHTML = '<i class="fa-solid fa-rotate-right" style="margin-right: 10px; color: #e65100;"></i> Request Resubmission';
            btn.style.background = '#e65100';
            btn.textContent = 'Request Resubmission';
        }
        modal.style.display = 'flex';
    }

    function closeReasonModal() {
        document.getElementById('reason-modal').style.display = 'none';
        reasonUserId = null;
        reasonAction = null;
    }

    async function submitReason() {
        const reason = document.getElementById('reason-text').value.trim();
        if (!reason) {
            KapeKanto.toast('Please provide a reason.', 'warning');
            return;
        }

        try {
            const endpoint = reasonAction === 'reject' ? 'reject-id' : 'resubmit-id';
            const res = await fetch(`/api/users/${reasonUserId}/${endpoint}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason })
            });
            const data = await res.json();
            if (res.ok) {
                KapeKanto.toast(data.message, 'success');
                closeReasonModal();
                loadPendingVerifications();
            } else {
                KapeKanto.toast(data.error, 'error');
            }
        } catch(e) { KapeKanto.toast('Server error', 'error'); }
    }

    document.addEventListener('DOMContentLoaded', () => {
        loadData();
        loadPendingVerifications();
    });
</script>

<%- include('../partials/footer') %>
