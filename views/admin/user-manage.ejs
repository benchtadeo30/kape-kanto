<style>
    .admin-modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(44, 34, 28, 0.6);
        backdrop-filter: blur(8px);
        z-index: 2000;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        animation: modalFadeIn 0.3s ease;
    }
    .modal-content {
        background: white;
        width: 100%;
        max-width: 500px;
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        animation: modalSlideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .modal-header {
        padding: 1.5rem 2rem;
        background: #fdfaf7;
        border-bottom: 1px solid #f0e6e0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .modal-body { padding: 2rem; }
    .modal-footer {
        padding: 1.5rem 2rem;
        background: #fcfcfc;
        border-top: 1px solid #eee;
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
    }
    @keyframes modalFadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes modalSlideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    
    .user-table th { color: #999; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1px; padding: 1rem; border-bottom: 1px solid #f0e6e0; }
    .user-row:hover { background: #fdfaf7 !important; }
</style>

<%- include('../partials/header') %>
<div class="dashboard-layout">
    <%- include('../partials/admin-sidebar', { activePage: 'user' }) %>
    <main>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem;">
            <div>
                <h1 style="margin: 0; font-size: 2.2rem; color: var(--primary-dark);">User Management</h1>
                <p style="color: var(--text-light); margin-top: 5px;">Manage administrative staff and customer accounts.</p>
            </div>
            <div style="display: flex; gap: 1rem;">
                <div style="position: relative; width: 300px;">
                    <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #999;"></i>
                    <input type="text" id="user-search" placeholder="Search accounts..." oninput="debounceSearch()"
                        style="width: 100%; padding: 10px 1rem 10px 2.5rem; border-radius: 12px; border: 1px solid #f0e6e0; outline: none;">
                </div>
                <button class="btn btn-primary" onclick="openCreateModal()">+ New Account</button>
            </div>
        </div>

        <div class="card" style="padding: 0; overflow: hidden; border: 1px solid #f0e6e0;">
            <div id="user-list">
                <!-- Content -->
            </div>
            <div id="user-pagination" style="display: flex; justify-content: center; gap: 8px; align-items: center; padding: 1.5rem; background: #fdfaf7; border-top: 1px solid #f0e6e0;"></div>
        </div>
    </main>
</div>

<!-- Create User Modal -->
<div id="create-modal" class="admin-modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fa-solid fa-user-plus" style="margin-right: 10px; color: var(--primary);"></i> Create New Account</h3>
            <button onclick="closeCreateModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #999;">&times;</button>
        </div>
        <form id="create-form" onsubmit="handleCreate(event)">
            <div class="modal-body">
                <div style="display: grid; gap: 1.5rem;">
                    <div>
                        <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Username</label>
                        <input type="text" id="new-username" required placeholder="e.g. jondoe" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee;">
                    </div>
                    <div>
                        <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Email Address</label>
                        <input type="email" id="new-email" required placeholder="e.g. jon@kapekanto.ph" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee;">
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                        <div>
                            <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Role</label>
                            <select id="new-role" required style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee; background: white;">
                                <option value="customer">Customer</option>
                                <option value="staff">Staff</option>
                                <option value="admin">Admin</option>
                            </select>
                        </div>
                        <div>
                            <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Password</label>
                            <input type="password" id="new-password" required placeholder="••••••••" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee;">
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeCreateModal()" style="background: #bca08d; border: none; color: white; font-weight: 600;">Cancel</button>
                <button type="submit" class="btn btn-primary" style="padding-left: 2rem; padding-right: 2rem;">Create Account</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit User Modal -->
<div id="edit-modal" class="admin-modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fa-solid fa-user-pen" style="margin-right: 10px; color: var(--primary);"></i> Edit Account</h3>
            <button onclick="closeEditModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #999;">&times;</button>
        </div>
        <form id="edit-form" onsubmit="handleUpdate(event)">
            <input type="hidden" id="edit-id">
            <div class="modal-body">
                <div style="display: grid; gap: 1.5rem;">
                    <div>
                        <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Username</label>
                        <input type="text" id="edit-username" required placeholder="e.g. jondoe" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee;">
                    </div>
                    <div>
                        <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Email Address</label>
                        <input type="email" id="edit-email" required placeholder="e.g. jon@kapekanto.ph" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee;">
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                        <div>
                            <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">Role</label>
                            <select id="edit-role" required style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee; background: white;">
                                <option value="customer">Customer</option>
                                <option value="staff">Staff</option>
                                <option value="admin">Admin</option>
                            </select>
                        </div>
                        <div>
                            <label style="font-weight: 600; font-size: 0.9rem; color: #666; display: block; margin-bottom: 8px;">New Password (Optional)</label>
                            <input type="password" id="edit-password" placeholder="Leave blank to keep current" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #eee;">
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeEditModal()" style="background: #bca08d; border: none; color: white; font-weight: 600;">Cancel</button>
                <button type="submit" class="btn btn-primary" style="padding-left: 2rem; padding-right: 2rem;">Update Account</button>
            </div>
        </form>
    </div>
</div>

<style>
    @keyframes modalIn {
        from { opacity: 0; transform: translateY(30px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
</style>

<script>
    let userPage = 1;
    const PAGE_LIMIT = 10;
    let searchTimeout = null;

    function debounceSearch() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
            userPage = 1;
            loadData();
        }, 400);
    }

    async function loadData() {
        try {
            const search = document.getElementById('user-search').value.trim();
            const offset = (userPage - 1) * PAGE_LIMIT;
            const userRes = await fetch(`/api/users?limit=${PAGE_LIMIT}&offset=${offset}&search=${encodeURIComponent(search)}`);
            if (userRes.ok) {
                const data = await userRes.json();
                renderUsers(data.items);
                renderPagination(userPage, data.total);
            }
        } catch (e) {
            console.error(e);
        }
    }

    function renderPagination(current, total) {
        const container = document.getElementById('user-pagination');
        const totalPages = Math.ceil(total / PAGE_LIMIT);
        
        if (totalPages <= 1) {
            container.innerHTML = '';
            return;
        }

        const prevPage = current === 1 ? totalPages : current - 1;
        const nextPage = current === totalPages ? 1 : current + 1;

        let html = `
            <div style="display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap;">
                <button class="btn btn-secondary" style="width: 38px; height: 38px; padding: 0; border-radius: 10px; display: flex; align-items: center; justify-content: center;" onclick="changePage(${prevPage})">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>`;

        const limit = 10;
        let startPage = Math.max(1, current - Math.floor(limit / 2));
        let endPage = Math.min(totalPages, startPage + limit - 1);
        
        if (endPage - startPage < limit - 1) {
            startPage = Math.max(1, endPage - limit + 1);
        }

        if (startPage > 1) {
            html += `<button class="btn btn-outline" onclick="changePage(1)" style="width: 36px; height: 36px; padding: 0; border-radius: 10px;">1</button>`;
            if (startPage > 2) {
                html += `<span style="cursor: pointer; padding: 0 5px; color: #999; display: flex; align-items: center;" onclick="changePage(${Math.max(1, startPage - 1)})" title="Previous 10 pages">...</span>`;
            }
        }

        for (let i = startPage; i <= endPage; i++) {
            html += `<button class="btn ${i === current ? 'btn-primary' : 'btn-outline'}" 
                             onclick="changePage(${i})" 
                             style="width: 36px; height: 36px; padding: 0; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700;">${i}</button>`;
        }

        if (endPage < totalPages) {
            if (endPage < totalPages - 1) {
                html += `<span style="cursor: pointer; padding: 0 5px; color: #999; display: flex; align-items: center;" onclick="changePage(${Math.min(totalPages, endPage + 1)})" title="Next 10 pages">...</span>`;
            }
            html += `<button class="btn btn-outline" onclick="changePage(${totalPages})" style="width: 36px; height: 36px; padding: 0; border-radius: 10px;">${totalPages}</button>`;
        }

        html += `
                <button class="btn btn-secondary" style="width: 38px; height: 38px; padding: 0; border-radius: 10px; display: flex; align-items: center; justify-content: center;" onclick="changePage(${nextPage})">
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </div>
        `;
        
        container.innerHTML = html;
    }

    window.changePage = (p) => {
        userPage = p;
        loadData();
    };

    window.openCreateModal = () => {
        document.getElementById('create-modal').style.display = 'flex';
        document.getElementById('create-form').reset();
    };

    window.closeCreateModal = () => {
        document.getElementById('create-modal').style.display = 'none';
    };

    window.handleCreate = async (e) => {
        e.preventDefault();
        const form = e.target;
        
        if (!KapeKanto.validate(form)) return;

        const username = document.getElementById('new-username').value.trim();
        const email = document.getElementById('new-email').value.trim().toLowerCase();
        const role = document.getElementById('new-role').value;
        const password = document.getElementById('new-password').value;

        if (!email.endsWith('@gmail.com')) {
            KapeKanto.toast('Only Gmail addresses are allowed for accounts.', 'error');
            return;
        }

        const passwordRegex = /^(?=.*[A-Z])(?=.*[0-9].*[0-9])(?=.*[!@#$%^&*])(?=.{5,})/;
        if (!passwordRegex.test(password)) {
            KapeKanto.toast('Password needs 5+ chars, 1 uppercase, 2 numbers, 1 special char.', 'error');
            return;
        }

        try {
            const res = await fetch('/api/users', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, email, role, password })
            });

            const data = await res.json();
            if (res.ok) {
                KapeKanto.toast('Account created successfully!', 'success');
                closeCreateModal();
                loadData();
            } else {
                KapeKanto.toast(data.error || 'Failed to create account', 'error');
            }
        } catch (err) {
            KapeKanto.toast('Connection error', 'error');
        }
    };

      function renderUsers(users) {
        const container = document.getElementById('user-list');
        if (users.length === 0) {
            container.innerHTML = '<p style="text-align: center; padding: 4rem; color: #999;">No accounts found.</p>';
            return;
        }

        let html = `
            <table class="user-table" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr>
                        <th style="text-align: left; padding-left: 2rem;">User Identity</th>
                        <th style="text-align: left;">Role</th>
                        <th style="text-align: right; padding-right: 2rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>`;
        
        users.forEach(u => {
            const roleClass = u.role === 'admin' ? 'var(--primary)' : (u.role === 'staff' ? '#2e7d32' : '#666');
            const roleBg = u.role === 'admin' ? '#fdfaf7' : (u.role === 'staff' ? '#e8f5e9' : '#f5f5f5');

            html += `
                <tr class="user-row" style="border-bottom: 1px solid #fcfcfc;">
                    <td style="padding: 1.2rem 2rem;">
                        <div style="display: flex; align-items: center; gap: 15px;">
                            <div style="width: 45px; height: 45px; border-radius: 14px; background: #f7f2ef; display: flex; align-items: center; justify-content: center; color: var(--primary); font-weight: 800; border: 1px solid #eee; text-transform: uppercase;">
                                ${u.username.charAt(0)}
                            </div>
                            <div>
                                <div style="font-weight: 700; color: var(--admin-primary);">${u.username}</div>
                                <div style="font-size: 0.85rem; color: #999;">${u.email}</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 50px; background: ${roleBg}; color: ${roleClass}; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; border: 1px solid rgba(0,0,0,0.05);">
                            <i class="fa-solid fa-${u.role === 'admin' ? 'user-shield' : (u.role === 'staff' ? 'user-tie' : 'user')}"></i>
                            ${u.role}
                        </span>
                    </td>
                    <td style="text-align: right; padding-right: 2rem;">
                        <button class="btn btn-danger" style="background: transparent; color: #f44336; border: 1px solid #ffebee; padding: 8px 12px; border-radius: 10px;" onclick="deleteUser(${u.id})">
                            <i class="fa-solid fa-trash-can"></i>
                        </button>
                    </td>
                </tr>`;
        });
        
        html += '</tbody></table>';
        container.innerHTML = html;
    }

    function escapeHtml(unsafe) {
        if (!unsafe) return '';
        return unsafe
             .replace(/&/g, "&amp;")
             .replace(/</g, "&lt;")
             .replace(/>/g, "&gt;")
             .replace(/"/g, "&quot;")
             .replace(/'/g, "&#039;");
    }



    async function deleteUser(id) {
        KapeKanto.confirm('Are you sure you want to delete this user? This action cannot be undone.', async () => {
            try {
                const res = await fetch(`/api/users/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    KapeKanto.toast('User deleted successfully', 'success');
                    loadData();
                } else {
                    const data = await res.json();
                    KapeKanto.toast(data.error || 'Failed to delete user', 'error');
                }
            } catch(e) { 
                KapeKanto.toast('Server error while deleting user', 'error'); 
            }
        }, { title: 'Delete User', confirmText: 'Yes, Delete', type: 'danger' });
    }

    document.addEventListener('DOMContentLoaded', loadData);
</script>

<%- include('../partials/footer') %>
