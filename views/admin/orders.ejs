<%- include('../partials/header') %>

<style>
    /* Modern Order Card */
    .ao-card { 
        background: white; 
        border-radius: 20px; 
        padding: 1.5rem; 
        margin-bottom: 1.2rem; 
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        border: 1px solid #f0e6e0; 
        display: grid;
        grid-template-columns: auto 1fr auto auto;
        align-items: center; 
        gap: 2rem;
        position: relative;
        transition: all 0.3s;
        border-left: 6px solid #eee;
    }
    .ao-card:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(111, 78, 55, 0.08); }
    .ao-card.active-dropdown { z-index: 1001 !important; }
    
    .ao-card.status-pending { border-left-color: #ff9800; }
    .ao-card.status-preparing { border-left-color: #fbc02d; }
    .ao-card.status-ready { border-left-color: #4caf50; }
    .ao-card.status-out_for_delivery { border-left-color: #2196f3; }
    .ao-card.status-completed { border-left-color: #2e7d32; }
    .ao-card.status-cancelled { border-left-color: #f44336; }
    .ao-card.status-awaiting_payment { border-left-color: #9e9e9e; }

    .ao-id-wrap { display: flex; flex-direction: column; align-items: center; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); padding: 1rem 1.5rem; border-radius: 16px; color: white; min-width: 100px; box-shadow: 0 8px 20px rgba(111, 78, 55, 0.15); }
    .ao-id { font-weight: 900; font-size: 1.4rem; color: white; margin: 0; }
    .ao-id-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: rgba(255, 255, 255, 0.8); font-weight: 700; }

    .ao-info h4 { margin: 0 0 0.4rem 0; font-size: 1.3rem; color: var(--primary); }
    .ao-meta { font-size: 1rem; color: #777; margin: 0; display: flex; align-items: center; gap: 8px; }
    .ao-meta i { font-size: 0.9rem; color: var(--accent); }

    .ao-stats { display: flex; flex-direction: column; align-items: flex-end; gap: 0.6rem; }
    .ao-total { font-weight: 900; color: var(--primary); font-size: 1.5rem; margin: 0; }

    /* Dropdown UI */
    .ao-dropdown { position: relative; }
    .ao-drop-btn {
        background: var(--primary);
        color: white;
        border: none;
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 10px rgba(111, 78, 55, 0.2);
        font-size: 1.1rem;
    }
    .ao-drop-btn:hover { background: var(--primary-dark); transform: scale(1.05); }

    .ao-dropdown-menu {
        display: none;
        position: absolute;
        right: 0;
        top: calc(100% + 10px);
        background: white;
        min-width: 0;
        width: 260px;
        border-radius: 16px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        border: 1px solid #f0e6e0;
        z-index: 1000;
        padding: 0.75rem;
        animation: dropdownSlide 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    @keyframes dropdownSlide {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .ao-dropdown-menu.show { display: block; }

    .ao-drop-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        color: #444;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 10px;
        cursor: pointer;
        transition: 0.2s;
        width: 100%;
        border: none;
        background: none;
        text-align: left;
    }
    .ao-drop-item:hover { background: #f7f2ef; color: var(--admin-primary); }
    .ao-drop-item.danger:hover { background: #fff5f5; color: #f44336; }
    
    .ao-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 50px; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; }
    .badge-pending    { background:#fff3e0; color:#e65100; }
    .badge-preparing  { background:#fff8e1; color:#f57f17; }
    .badge-ready      { background:#e8f5e9; color:#2e7d32; }
    .badge-delivery   { background:#e3f2fd; color:#1565c0; }
    .badge-completed  { background:#c8e6c9; color:#1b5e20; }
    .badge-cancelled  { background:#ffebee; color:#b71c1c; }
    .badge-awaiting   { background:#f5f5f5; color:#616161; }

    .ao-type { font-size: 0.85rem; font-weight: 600; padding: 6px 14px; border-radius: 50px; background: #f7f2ef; color: var(--admin-primary); border: 1px solid #f0e6e0; }

    .ao-drop-divider { height: 1px; background: #f0e6e0; margin: 0.5rem 0; }
    .ao-drop-header { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #999; font-weight: 800; padding: 6px 16px; }


    @media (max-width: 900px) {
        .ao-card { grid-template-columns: 1fr !important; gap: 1.2rem; padding: 1.2rem; align-items: stretch; }
        .ao-id-wrap { flex-direction: row; justify-content: space-between; padding: 1rem 1.5rem; min-width: 0; }
        .ao-stats { align-items: stretch; border-top: 1px solid #f0e6e0; padding-top: 1rem; margin-top: 0.5rem; }
        .ao-total { font-size: 1.5rem; text-align: right; }
    }

    /* Tabs */
    .ao-tabs { display: flex; gap: 10px; margin-bottom: 2.5rem; flex-wrap: wrap; }
    .ao-tab { padding: 12px 24px; border-radius: 50px; border: 1.5px solid #eee; background: white; font-weight: 700; font-size: 1.1rem; cursor: pointer; transition: all 0.2s; color: var(--text-light); }
    .ao-tab.active { background: var(--primary); color: white; border-color: var(--primary); }

    /* Details modal */
    #ao-modal { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:9999; align-items:center; justify-content:center; }
    #ao-modal.open { display: flex; }
    .ao-modal-box { 
        background: white; 
        border-radius: 24px; 
        padding: 2.5rem; 
        width: 100%; 
        max-width: 520px; 
        max-height: calc(100vh - 40px); /* Limit height */
        display: flex;
        flex-direction: column;
        overflow: hidden !important; 
        box-shadow: 0 20px 60px rgba(0,0,0,0.2); 
        animation: popIn 0.3s cubic-bezier(0.34,1.56,0.64,1); 
    }
    #ao-modal-body { 
        flex: 1;
        overflow-y: auto !important;
        min-height: 0;
        padding-top: 0.5rem; 
    }
    .ao-modal-close {
        background: none;
        border: none;
        font-size: 2.2rem;
        cursor: pointer;
        color: #999;
        transition: all 0.2s ease;
        line-height: 1;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }
    @media (min-width: 1024px) {
        .ao-modal-close {
            width: 60px;
            height: 60px;
            font-size: 3.2rem;
        }
    }
    .ao-modal-close:hover {
        background: #fdfaf7;
        color: var(--primary);
        transform: rotate(90deg);
    }

    @media (max-width: 380px) {
        .ao-modal-box { padding: 1.5rem !important; }
        .responsive-grid { grid-template-columns: 1fr !important; gap: 1rem !important; }
        .ao-item-row { font-size: 1rem !important; }
        .ao-total { font-size: 1.2rem !important; }
    }

    #chat-modal { display:none; position:fixed; inset:0; background:rgba(44,26,14,0.6); z-index:9999; align-items:center; justify-content:center; padding:1rem; backdrop-filter: blur(4px); }
    #chat-modal.open { display:flex; }
    .chat-modal-box { 
        background:white; 
        border-radius:24px; 
        width:100%; 
        max-width:500px; 
        height: 85vh;
        max-height: 700px;
        box-shadow:0 30px 90px rgba(0,0,0,0.3); 
        display:flex; 
        flex-direction:column; 
        overflow:hidden; 
        animation: modalPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @keyframes modalPop {
        from { transform: scale(0.9) translateY(20px); opacity: 0; }
        to { transform: scale(1) translateY(0); opacity: 1; }
    }
    .chat-modal-header { padding:1.25rem 1.5rem; border-bottom:1px solid #f0e6e0; display:flex; justify-content:space-between; align-items:center; background:#fdfaf7; }
    .chat-modal-title { margin:0; font-size:1.15rem; font-weight:800; color:var(--primary-dark); display:flex; align-items:center; gap:10px; }
    .chat-modal-close { 
        background:rgba(0,0,0,0.05); 
        border:none; 
        color:var(--text-light); 
        width: 32px; 
        height: 32px; 
        border-radius: 50%; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        cursor:pointer; 
        transition: 0.2s;
    }
    .chat-modal-close:hover { background: var(--danger); color: white; transform: rotate(90deg); }
    
    .chat-modal-messages { 
        flex: 1;
        padding:1.5rem; 
        overflow-y:auto; 
        display:flex; 
        flex-direction:column; 
        gap:1.25rem; 
        background:#fffcf9;
        scroll-behavior: smooth;
    }
    
    .chat-msg { 
        max-width:85%; 
        padding:0.9rem 1.25rem; 
        border-radius:18px; 
        font-size:0.92rem; 
        line-height: 1.5;
        position:relative; 
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .chat-msg.staff { 
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color:white; 
        align-self:flex-end; 
        border-bottom-right-radius:4px; 
    }
    .chat-msg.customer { 
        background:white; 
        color:var(--primary-dark); 
        align-self:flex-start; 
        border:1px solid #ede1d7; 
        border-bottom-left-radius:4px; 
    }
    .chat-meta { font-size:0.68rem; margin-top:6px; font-weight: 700; opacity:0.75; }
    .chat-msg.staff .chat-meta { text-align:right; color: rgba(255,255,255,0.9); }
    .chat-msg.customer .chat-meta { color:var(--text-light); }
    
    .chat-input-area { padding:1.25rem 1.5rem; border-top:1px solid #f0e6e0; display:flex; gap:12px; background:white; align-items: center; }
    .chat-input { 
        flex:1; 
        padding:0.85rem 1.25rem; 
        border-radius:50px; 
        border:1px solid #ede1d7; 
        font-family:var(--font-body); 
        font-size:0.95rem; 
        outline:none; 
        transition: all 0.2s; 
        background: #fdfaf7;
    }
    .chat-input:focus { border-color:var(--primary); background: white; box-shadow: 0 0 0 4px rgba(111,78,55,0.1); }
    .chat-send { 
        width:48px; 
        height:48px; 
        border-radius:50%; 
        background:var(--primary); 
        color:white; 
        border:none; 
        display:flex; 
        align-items:center; 
        justify-content:center; 
        cursor:pointer; 
        transition:all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
        flex-shrink:0; 
        box-shadow: 0 4px 12px rgba(111,78,55,0.2);
    }
    .order-search-input:focus {
        border-color: var(--primary) !important;
        box-shadow: 0 0 0 4px rgba(111,78,55,0.1) !important;
        background: white;
    }

    </style>

    <div class="dashboard-layout">
    <%- include('../partials/admin-sidebar', { activePage: 'orders' }) %>

    <!-- Main -->
    <main>
        <div class="admin-header-row">
            <div>
                <h1 style="margin: 0; font-size: 2.8rem; font-weight: 800; color: var(--primary-dark);">Customer Orders</h1>
                <p style="color: var(--text-light); font-size: 1.1rem; font-weight: 500; margin-top: 5px;">Review and manage all café orders in real-time.</p>
            </div>
        </div>

        <div class="ao-tabs">
            <button class="ao-tab active" onclick="filterOrders('all', this)"><i class="fa-solid fa-list"></i> All Statuses</button>
            <button class="ao-tab" onclick="filterOrders('pending', this)"><i class="fa-solid fa-clock"></i> Pending</button>
            <button class="ao-tab" onclick="filterOrders('preparing', this)"><i class="fa-solid fa-fire"></i> Preparing</button>
            <button class="ao-tab" onclick="filterOrders('ready', this)"><i class="fa-solid fa-circle-check"></i> Ready</button>
            <button class="ao-tab" onclick="filterOrders('out_for_delivery', this)"><i class="fa-solid fa-truck-fast"></i> Out for Delivery</button>
            <button class="ao-tab" onclick="filterOrders('completed', this)"><i class="fa-solid fa-flag-checkered"></i> Delivered / Picked Up</button>
        </div>

        <!-- Search and Filter Bar Row -->
        <div style="display: flex; gap: 1.5rem; margin-bottom: 2rem; align-items: center; justify-content: space-between; flex-wrap: wrap;">
            <!-- Search bar -->
            <div style="position: relative; flex: 1; min-width: 280px;">
                <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 20px; top: 50%; transform: translateY(-50%); color: var(--text-light); font-size: 1.05rem;"></i>
                <input type="text" id="order-search" class="order-search-input" oninput="handleSearch(this.value)" placeholder="Search Order ID, Customer Name, Email, Address, Payment Status..." 
                       style="width: 100%; padding: 14px 20px 14px 50px; border-radius: 50px; border: 1.5px solid #ede1d7; font-family: var(--font-body); font-size: 1rem; outline: none; transition: all 0.25s; background: white; box-shadow: 0 4px 10px rgba(0,0,0,0.02);">
            </div>
            
            <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                <!-- Filter Type Panel -->
                <div style="display: flex; align-items: center; gap: 1rem; background: white; padding: 0.5rem 1rem; border-radius: 50px; border: 1.5px solid #ede1d7; height: 52px; box-shadow: 0 4px 10px rgba(0,0,0,0.02);">
                    <span style="font-weight: 800; color: var(--primary-dark); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; white-space: nowrap; margin-left: 5px;">Type:</span>
                    <div style="display: flex; gap: 4px;">
                        <button class="btn btn-outline" id="type-all" onclick="filterType('all')" style="padding: 6px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 700; border-color: var(--primary); background: var(--primary); color: white; transition: 0.2s;">All</button>
                        <button class="btn btn-outline" id="type-delivery" onclick="filterType('delivery')" style="padding: 6px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 700; transition: 0.2s;">Delivery</button>
                        <button class="btn btn-outline" id="type-pickup" onclick="filterType('pickup')" style="padding: 6px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 700; transition: 0.2s;">Pickup</button>
                    </div>
                </div>

                <!-- Filter Schedule Panel -->
                <div style="display: flex; align-items: center; gap: 1rem; background: white; padding: 0.5rem 1rem; border-radius: 50px; border: 1.5px solid #ede1d7; height: 52px; box-shadow: 0 4px 10px rgba(0,0,0,0.02);">
                    <span style="font-weight: 800; color: var(--primary-dark); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; white-space: nowrap; margin-left: 5px;">Schedule:</span>
                    <div style="display: flex; gap: 4px;">
                        <button class="btn btn-outline" id="sched-all" onclick="filterSched('all')" style="padding: 6px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 700; border-color: var(--primary); background: var(--primary); color: white; transition: 0.2s;">All</button>
                        <button class="btn btn-outline" id="sched-asap" onclick="filterSched('asap')" style="padding: 6px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 700; transition: 0.2s;"><i class="fa-solid fa-bolt" style="margin-right: 4px;"></i> ASAP</button>
                        <button class="btn btn-outline" id="sched-scheduled" onclick="filterSched('scheduled')" style="padding: 6px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 700; transition: 0.2s;"><i class="fa-regular fa-clock" style="margin-right: 4px;"></i> Scheduled</button>
                    </div>
                </div>
            </div>
        </div>

        <div style="font-size:0.85rem;color:var(--text-light);margin-bottom:1rem;" id="ao-count">Loading…</div>
        <div id="orders-container"></div>
        <div id="ao-pagination" style="display: flex; justify-content: center; gap: 1rem; align-items: center; padding: 2rem 0; border-top: 1px solid #f0e6e0; margin-top: 2rem;"></div>
    </main>
</div>

<!-- Details modal -->
<div id="ao-modal">
    <div class="ao-modal-box">
        <div class="flex-stack-mobile" style="margin-bottom:1.5rem; align-items: center; justify-content: space-between;">
            <h3 id="ao-modal-title" style="margin:0;">Order Details</h3>
            <button onclick="closeModal()" class="ao-modal-close">&times;</button>
        </div>
        <div id="ao-modal-body"></div>
    </div>
</div>

<div id="chat-modal">
    <div class="chat-modal-box">
        <div class="chat-modal-header">
            <h3 class="chat-modal-title"><i class="fa-solid fa-comments" style="color:var(--primary)"></i> Chat - Order #<span id="chat-order-id"></span></h3>
            <button class="chat-modal-close" onclick="closeChatModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div id="chat-messages" class="chat-modal-messages">
            <div style="text-align:center; color:var(--text-light); font-size:0.85rem; padding:1rem;">Loading messages...</div>
        </div>
        <form id="chat-form" class="chat-input-area" onsubmit="sendStaffChatMessage(event)">
            <input type="text" id="chat-input" class="chat-input" placeholder="Type a message to customer..." autocomplete="off" required>
            <button type="submit" class="chat-send"><i class="fa-solid fa-paper-plane"></i></button>
        </form>
    </div>
</div>

<script>
    let allOrders = [];
    let currentFilter = 'all';
    let currentType = 'all';
    let currentSched = 'all';
    let currentPage = 1;
    let activeChatOrderId = null;
    let chatRefreshInterval = null;
    let searchQuery = '';
    let searchTimeout = null;
    const PAGE_LIMIT = 10;

    const BADGE_MAP = {
        pending:'badge-pending', preparing:'badge-preparing',
        ready:'badge-ready', out_for_delivery:'badge-delivery',
        completed:'badge-completed', cancelled:'badge-cancelled',
        awaiting_payment:'badge-awaiting'
    };

    const ALL_STATUSES = ['pending','preparing','ready','out_for_delivery','completed','cancelled'];

    function getStatusLabel(status, orderType) {
        if (status === 'completed') return orderType === 'delivery' ? 'Delivered' : 'Picked Up';
        return status.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase());
    }

    function getFilteredOrders() {
        return allOrders.filter(o => {
            const matchesStatus = currentFilter === 'all' || o.status === currentFilter;
            if (!matchesStatus) return false;

            const matchesType = currentType === 'all' || o.order_type === currentType;
            if (!matchesType) return false;

            const matchesSched = currentSched === 'all' || o.schedule_mode === currentSched;
            if (!matchesSched) return false;

            if (!searchQuery) return true;

            const haystack = [
                o.id,
                o.username,
                o.email,
                o.status,
                o.order_type,
                o.payment_method,
                o.payment_status,
                o.total,
                o.delivery_address || ''
            ].join(' ').toLowerCase();

            return haystack.includes(searchQuery);
        });
    }

    async function loadOrders() {
        try {
            const res = await fetch(`/api/orders/all`);
            if (res.ok) { 
                allOrders = await res.json();
                renderOrders();

                // Handle Deep Link to Chat
                const urlParams = new URLSearchParams(window.location.search);
                const openChatId = urlParams.get('openChat');
                if (openChatId) {
                    window.history.replaceState({}, document.title, window.location.pathname);
                    openChatModal(Number(openChatId));
                }
            }
        } catch(e) { console.error(e); }
    }

    function filterType(type) {
        currentType = type;
        currentPage = 1;
        
        // Update UI
        ['all', 'delivery', 'pickup'].forEach(t => {
            const btn = document.getElementById(`type-${t}`);
            if (t === type) {
                btn.style.background = 'var(--primary)';
                btn.style.color = 'white';
                btn.style.borderColor = 'var(--primary)';
            } else {
                btn.style.background = 'white';
                btn.style.color = 'var(--primary-dark)';
                btn.style.borderColor = '#eee';
            }
        });
        
        renderOrders();
    }

    function filterSched(sched) {
        currentSched = sched;
        currentPage = 1;
        
        // Update UI
        ['all', 'asap', 'scheduled'].forEach(s => {
            const btn = document.getElementById(`sched-${s}`);
            if (s === sched) {
                btn.style.background = 'var(--primary)';
                btn.style.color = 'white';
                btn.style.borderColor = 'var(--primary)';
            } else {
                btn.style.background = 'white';
                btn.style.color = 'var(--primary-dark)';
                btn.style.borderColor = '#eee';
            }
        });
        
        renderOrders();
    }

    function filterOrders(status, btn) {
        currentFilter = status;
        currentPage = 1; // Reset to page 1 on filter change
        document.querySelectorAll('.ao-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        renderOrders();
    }

    function handleSearch(val) {
        searchQuery = val.trim().toLowerCase();
        currentPage = 1;
        renderOrders();
    }

    function renderOrders() {
        const filtered = getFilteredOrders();
        const totalPages = Math.ceil(filtered.length / PAGE_LIMIT);
        currentPage = totalPages > 0 ? Math.min(Math.max(currentPage, 1), totalPages) : 1;
        const startIndex = (currentPage - 1) * PAGE_LIMIT;
        const pagedOrders = filtered.slice(startIndex, startIndex + PAGE_LIMIT);

        document.getElementById('ao-count').textContent = `Showing ${pagedOrders.length} of ${filtered.length} order${filtered.length !== 1 ? 's' : ''}`;

        const c = document.getElementById('orders-container');
        if (!filtered.length) {
            c.innerHTML = `<div style="text-align:center;padding:3rem;color:var(--text-light);">
                <i class="fa-solid fa-inbox" style="font-size:2.5rem;margin-bottom:1rem;"></i><p>No orders here.</p></div>`;
            document.getElementById('ao-pagination').innerHTML = '';
            return;
        }
        c.innerHTML = pagedOrders.map(o => buildCard(o)).join('');
        renderPagination(currentPage, filtered.length);
    }

    function renderPagination(current, total) {
        const container = document.getElementById('ao-pagination');
        const totalPages = Math.ceil(total / PAGE_LIMIT);
        
        if (totalPages <= 1) {
            container.innerHTML = '';
            return;
        }

        const prev = current === 1 ? totalPages : current - 1;
        const next = current === totalPages ? 1 : current + 1;

        let html = `
            <button class="btn btn-secondary" style="width: 40px; height: 40px; padding: 0; border-radius: 10px; display: flex; align-items: center; justify-content: center;" onclick="changePage(${prev})">
                <i class="fa-solid fa-chevron-left"></i>
            </button>
            <div id="page-numbers-container" style="display: flex; gap: 6px; align-items: center;">`;

        const limit = 10;
        let startPage = Math.max(1, current - Math.floor(limit / 2));
        let endPage = Math.min(totalPages, startPage + limit - 1);
        if (endPage - startPage < limit - 1) {
            startPage = Math.max(1, endPage - limit + 1);
        }

        if (startPage > 1) {
            html += `<span style="cursor: pointer; padding: 0 12px; color: #999; display: inline-flex; align-items: center; justify-content: center; font-weight: 800; white-space: nowrap; letter-spacing: 2px; min-width: 30px; font-size: 0.9rem;" onclick="changePage(${startPage - 1})" title="Previous 10 pages">...</span>`;
        }

        for (let i = startPage; i <= endPage; i++) {
            html += `<button class="btn ${i === current ? 'btn-primary' : 'btn-outline'}" 
                             onclick="changePage(${i})" 
                             style="width: 38px; height: 38px; padding: 0; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700;">${i}</button>`;
        }

        if (endPage < totalPages) {
            html += `<span style="cursor: pointer; padding: 0 12px; color: #999; display: inline-flex; align-items: center; justify-content: center; font-weight: 800; white-space: nowrap; letter-spacing: 2px; min-width: 30px; font-size: 0.9rem;" onclick="changePage(${endPage + 1})" title="Next 10 pages">...</span>`;
        }

        html += `
            </div>
            <button class="btn btn-secondary" style="width: 38px; height: 38px; padding: 0; border-radius: 10px; display: flex; align-items: center; justify-content: center;" onclick="changePage(${next})">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        `;
        
        container.innerHTML = html;
    }

    function changePage(p) {
        currentPage = p;
        renderOrders();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function buildCard(o) {
        const date = KapeKanto.parseUTCDate(o.created_at).toLocaleDateString('en-PH', {month:'short',day:'numeric',hour:'2-digit',minute:'2-digit',hour12:true});
        const badgeCls = BADGE_MAP[o.status] || '';
        const isDelivery = o.order_type === 'delivery';

        const statusOptions = ALL_STATUSES
            .filter(s => isDelivery || s !== 'out_for_delivery')
            .map(s => `
                <button class="ao-drop-item ${s === o.status ? 'active' : ''}" onclick="updateStatus(${o.id}, '${s}')">
                    <i class="fa-solid ${s === 'completed' ? 'fa-check-double' : s === 'cancelled' ? 'fa-xmark' : 'fa-circle-dot'}" style="font-size:0.7rem; opacity:0.6;"></i>
                    Mark as ${getStatusLabel(s, o.order_type)}
                </button>
            `).join('');

        const riderInfo = o.status === 'out_for_delivery' && o.rider_name
            ? `<div class="ao-meta" style="color:#1565c0; margin-top:5px;"><i class="fa-solid fa-motorcycle"></i> Rider: ${o.rider_name}</div>` : '';

        return `
        <div class="ao-card status-${o.status}">
            <div class="ao-id-wrap" data-label="Order ID">
                <span class="ao-id-label">Order</span>
                <h3 class="ao-id">#${o.id}</h3>
            </div>

            <div class="ao-info" data-label="Customer Details">
                <h4>${o.username}</h4>
                <p class="ao-meta"><i class="fa-solid fa-envelope"></i> ${o.email}</p>
                <p class="ao-meta"><i class="fa-solid fa-clock"></i> ${date}</p>
                ${riderInfo}
            </div>

            <div class="ao-stats" data-label="Status & Amount">
                <span class="ao-type" style="margin-bottom:0.3rem; display:inline-flex; align-items:center; gap:8px;">
                    <i class="fa-solid fa-${isDelivery ? 'truck-fast' : 'shop'}"></i>
                    ${isDelivery ? 'Delivery' : 'Pickup'}
                </span>
                <span class="ao-type" style="margin-bottom:0.3rem; display:inline-flex; align-items:center; gap:8px; ${o.schedule_mode === 'asap' ? 'background: #e8f5e9; color: #2e7d32; border-color: #c8e6c9;' : 'background: #f8f9fa; color: #495057; border-color: #e9ecef;'}">
                    <i class="fa-solid fa-${o.schedule_mode === 'asap' ? 'bolt' : 'calendar-days'}"></i>
                    ${o.schedule_mode === 'asap' ? 'ASAP' : 'Scheduled'}
                </span>
                <span class="ao-badge ${badgeCls}">${getStatusLabel(o.status, o.order_type)}</span>
                <p class="ao-total">&#8369;${o.total.toFixed(2)}</p>
            </div>

            <div class="ao-dropdown" data-label="Actions">
                <button class="ao-drop-btn" onclick="toggleOrderDropdown(event, ${o.id})">
                    <i class="fa-solid fa-chevron-down"></i>
                </button>
                <div id="drop-${o.id}" class="ao-dropdown-menu">
                    <div class="ao-drop-header">Actions</div>
                    <button class="ao-drop-item" onclick="viewDetails(${o.id})">
                        <i class="fa-solid fa-eye"></i> View Full Details
                    </button>

                    <div class="ao-drop-divider"></div>
                    <div class="ao-drop-header">Update Status</div>
                    ${statusOptions}

                    <div class="ao-drop-divider"></div>
                    <button class="ao-drop-item" onclick="openChatModal(${o.id})">
                        <i class="fa-solid fa-comments"></i> Chat with Customer
                    </button>

                    <div class="ao-drop-divider"></div>
                    <button class="ao-drop-item danger" onclick="deleteOrder(${o.id})">
                        <i class="fa-solid fa-trash-can"></i> Delete Order Permanently
                    </button>
                </div>
            </div>
        </div>`;    }

    function toggleOrderDropdown(e, id) {
        e.stopPropagation();
        const menu = document.getElementById(`drop-${id}`);
        const card = menu.closest('.ao-card');
        const isShowing = menu.classList.contains('show');
        
        // Close all other menus and reset z-indices
        document.querySelectorAll('.ao-dropdown-menu').forEach(m => m.classList.remove('show'));
        document.querySelectorAll('.ao-card').forEach(c => c.classList.remove('active-dropdown'));
        
        if (!isShowing) {
            menu.classList.add('show');
            card.classList.add('active-dropdown');
        }
    }

    // Close dropdowns when clicking outside
    window.addEventListener('click', () => {
        document.querySelectorAll('.ao-dropdown-menu').forEach(m => m.classList.remove('show'));
        document.querySelectorAll('.ao-card').forEach(c => c.classList.remove('active-dropdown'));
    });

    async function updateStatus(id, status, selectEl) {
        const performUpdate = async () => {
            try {
                const res = await fetch(`/api/orders/${id}/status`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });
                if (res.ok) {
                    const order = allOrders.find(o => Number(o.id) === Number(id));
                    const label = getStatusLabel(status, order?.order_type || 'delivery');
                    KapeKanto.toast(`Order #${id} → ${label}`, 'success');
                    currentPage = 1;
                    loadOrders();
                } else {
                    const d = await res.json();
                    KapeKanto.toast(d.error, 'error');
                    if (selectEl) loadOrders(); // Reset select if failed
                }
            } catch(e) {
                KapeKanto.toast('Failed to update.', 'error');
                if (selectEl) loadOrders();
            }
        };

        if (status === 'cancelled') {
            KapeKanto.confirm(`Are you sure you want to CANCEL Order #${id}?`, performUpdate, { 
                type: 'danger', 
                confirmText: 'Yes, Cancel' 
            });
            // Reset select immediately so it doesn't show cancelled while modal is open
            if (selectEl) loadOrders();
        } else {
            performUpdate();
        }
    }

    async function deleteOrder(id) {
        KapeKanto.confirm(`PERMANENTLY DELETE Order #${id}? \nThis will REMOVE it from the database forever and return items to stock.`, async () => {
            try {
                const res = await fetch(`/api/orders/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    KapeKanto.toast(`Order #${id} deleted permanently`, 'success');
                    loadOrders();
                } else {
                    const d = await res.json();
                    KapeKanto.toast(d.error || 'Failed to delete.', 'error');
                }
            } catch(e) {
                KapeKanto.toast('Error communicating with server.', 'error');
            }
        }, { title: 'Delete Order', confirmText: 'Delete Permanently', type: 'danger' });
    }

    async function viewDetails(id) {
        // Find order in cached list for basic info
        const order = allOrders.find(o => o.id === id);
        if (!order) return;

        document.getElementById('ao-modal-title').textContent = `Order #${id} — ${order.username}`;
        document.getElementById('ao-modal-body').innerHTML = '<p style="color:var(--text-light)"><i class="fa-solid fa-circle-notch fa-spin"></i> Loading…</p>';
        document.getElementById('ao-modal').classList.add('open');

        try {
            // Use the admin-accessible full list data + per-user endpoint fallback
            const res = await fetch(`/api/orders/my/${id}`);
            if (!res.ok) throw new Error();
            const data = await res.json();
            renderModalBody(data);
        } catch(e) {
            // If the my/:id endpoint blocks admin, show summary from cached data
            renderModalBodyBasic(order);
        }
    }

    function renderModalBody(order) {
        const itemsHtml = order.items.map(i => {
            let customizationsHtml = '';
            try {
                const custs = i.customizations ? JSON.parse(i.customizations) : {};
                const entries = Object.entries(custs);
                if (entries.length > 0) {
                    customizationsHtml = `<small style="color:#888; font-size:0.75rem; margin-top:2px;">${entries.map(([k,v])=>k+': '+v).join(', ')}</small>`;
                }
            } catch (e) {
                customizationsHtml = '';
            }

            return `
            <div class="ao-item-row">
                <div style="display:flex; flex-direction:column;">
                    <span style="font-weight:700; color:var(--primary-dark);">${i.quantity}x ${i.name || 'Deleted Item'}</span>
                    ${customizationsHtml}
                </div>
                <span style="font-weight:700; color:var(--primary);">&#8369;${i.subtotal.toFixed(2)}</span>
            </div>`;
        }).join('');

        const vatExemptDiscount = order.sc_discount_amount > 0 ? (order.subtotal - (order.subtotal / 1.12)) : 0;
        const badgeCls = BADGE_MAP[order.status] || '';
        const isDelivery = order.order_type === 'delivery';
        const statusLabel = getStatusLabel(order.status, order.order_type);

        document.getElementById('ao-modal-body').innerHTML = `
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; background:#fdfaf7; padding:1rem; border-radius:16px; border:1px solid #f0e6e0;">
                <div>
                    <span class="ao-detail-label">Status</span>
                    <span class="ao-badge ${badgeCls}">${statusLabel}</span>
                </div>
                <div style="text-align:right;">
                    <div style="font-size: 0.7rem; color: #999; text-transform: uppercase; font-weight: 800; margin-bottom: 4px;">Order Type</div>
                    <span style="font-size: 0.85rem; font-weight: 800; color: var(--primary); background: rgba(111, 78, 55, 0.08); padding: 6px 12px; border-radius: 50px; display: inline-flex; align-items: center; gap: 8px;">
                        <i class="fa-solid fa-${order.order_type === 'delivery' ? 'truck-fast' : 'shop'}"></i>
                        ${order.order_type === 'delivery' ? 'Delivery' : 'Pickup'}
                    </span>
                </div>
            </div>

            <div class="responsive-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; margin-bottom:1.5rem;">
                <div class="ao-detail-section">
                    <span class="ao-detail-label">Customer</span>
                    <div class="ao-detail-value">${order.username || 'Deleted User'}</div>
                    <div style="font-size:0.8rem; color:#777;">${order.email || 'No email registered'}</div>
                </div>
                <div class="ao-detail-section" style="text-align:right;">
                    <span class="ao-detail-label">Payment</span>
                    <div class="ao-detail-value">${order.payment_method.toUpperCase()}</div>
                    <div style="font-size:0.8rem; color:#777; font-weight:700;">${order.payment_status.toUpperCase()}</div>
                </div>
            </div>

            <div class="ao-items-list">
                <span class="ao-detail-label" style="margin-bottom:1rem;">Order Items</span>
                ${itemsHtml}
            </div>

            <div class="ao-detail-section">
                <span class="ao-detail-label">Price Breakdown</span>
                <div class="ao-breakdown-row"><span>Subtotal (Gross)</span><span>&#8369;${order.subtotal.toFixed(2)}</span></div>
                
                ${order.sc_discount_amount > 0 ? `
                    <div class="ao-breakdown-row red"><span>VAT-Exempt Discount (12%)</span><span>-&#8369;${vatExemptDiscount.toFixed(2)}</span></div>
                    <div class="ao-breakdown-row red"><span>SC/PWD Discount (20%)</span><span>-&#8369;${order.sc_discount_amount.toFixed(2)}</span></div>
                ` : `
                    <div class="ao-breakdown-row"><span>VAT (12% Inclusive)</span><span>&#8369;${(order.vat_amount||0).toFixed(2)}</span></div>
                `}

                ${order.promo_discount_amount > 0 ? `
                    <div class="ao-breakdown-row red"><span>🏷️ Promo Discount</span><span>-&#8369;${order.promo_discount_amount.toFixed(2)}</span></div>
                ` : ''}

                <div class="ao-breakdown-row"><span>Delivery Fee</span><span>&#8369;${(order.delivery_fee||0).toFixed(2)}</span></div>
                <div class="ao-breakdown-row total"><span>Amount Due</span><span>&#8369;${order.total.toFixed(2)}</span></div>
            </div>

            ${order.delivery_address ? `
                <div class="ao-detail-section" style="background:#fff5f5; padding:1rem; border-radius:12px; border:1px solid #ffebeb;">
                    <span class="ao-detail-label" style="color:var(--danger);">Delivery Address</span>
                    <div style="font-size:0.9rem; color:var(--primary-dark); font-weight:500;">${order.delivery_address}</div>
                </div>
            ` : ''}

            ${order.notes ? `
                <div class="ao-detail-section" style="margin-top:1rem; background:#f0f7ff; padding:1rem; border-radius:12px; border:1px solid #e0eeff;">
                    <span class="ao-detail-label" style="color:#007bff;">Admin/Kitchen Notes</span>
                    <div style="font-size:0.9rem; color:var(--primary-dark); font-weight:500;">${order.notes}</div>
                </div>
            ` : ''}
        `;
    }

    function renderModalBodyBasic(order) {
        document.getElementById('ao-modal-body').innerHTML = `
            <p><strong>Type:</strong> ${order.order_type}</p>
            <p><strong>Status:</strong> ${order.status}</p>
            <p><strong>Total:</strong> &#8369;${order.total.toFixed(2)}</p>
            ${order.delivery_address ? `<p><strong>Address:</strong> ${order.delivery_address}</p>` : ''}
            <p style="color:var(--text-light);font-size:0.85rem;margin-top:1rem;">Item details require the admin single-order API endpoint.</p>`;
    }

    function closeModal() {
        document.getElementById('ao-modal').classList.remove('open');
    }
    document.getElementById('ao-modal').addEventListener('click', e => {
        if (e.target === document.getElementById('ao-modal')) closeModal();
    });



    function openChatModal(orderId) {
        activeChatOrderId = orderId;
        document.getElementById('chat-order-id').textContent = orderId;
        document.getElementById('chat-modal').classList.add('open');
        loadStaffChatMessages();
        if (chatRefreshInterval) clearInterval(chatRefreshInterval);
        chatRefreshInterval = setInterval(loadStaffChatMessages, 5000);
    }

    function closeChatModal() {
        activeChatOrderId = null;
        document.getElementById('chat-modal').classList.remove('open');
        if (chatRefreshInterval) clearInterval(chatRefreshInterval);
    }

    async function loadStaffChatMessages() {
        if (!activeChatOrderId) return;
        try {
            const res = await fetch(`/api/orders/${activeChatOrderId}/messages`);
            if (!res.ok) return;
            const messages = await res.json();
            const container = document.getElementById('chat-messages');
            
            if (!messages.length) {
                container.innerHTML = '<div style="text-align:center; color:var(--text-light); font-size:0.85rem; padding:1rem;">No messages yet.</div>';
                return;
            }

            const isAtBottom = container.scrollHeight - container.scrollTop <= container.clientHeight + 50;

            container.innerHTML = messages.map(m => {
                const isCustomer = m.role === 'customer';
                const time = KapeKanto.formatChatMessageDate(m.created_at);
                const senderName = isCustomer ? (m.username || 'Customer') : 'Admin';
                return `
                <div class="chat-msg ${isCustomer ? 'customer' : 'staff'}">
                    <div>${m.message}</div>
                    <div class="chat-meta">${senderName} · ${time}</div>
                </div>`;
            }).join('');

            if (isAtBottom) {
                container.scrollTop = container.scrollHeight;
            }
        } catch (e) {
            console.error('Failed to load messages');
        }
    }

    async function sendStaffChatMessage(e) {
        e.preventDefault();
        if (!activeChatOrderId) return;
        const input = document.getElementById('chat-input');
        const message = input.value.trim();
        if (!message) return;

        input.value = '';
        input.disabled = true;

        try {
            const res = await fetch(`/api/orders/${activeChatOrderId}/messages`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message })
            });
            if (res.ok) {
                await loadStaffChatMessages();
                const container = document.getElementById('chat-messages');
                container.scrollTop = container.scrollHeight;
            } else {
                KapeKanto.toast('Failed to send message', 'error');
            }
        } catch (e) {
            KapeKanto.toast('Error sending message', 'error');
        } finally {
            input.disabled = false;
            input.focus();
        }
    }

    document.getElementById('chat-modal').addEventListener('click', (e) => {
        if (e.target === document.getElementById('chat-modal')) closeChatModal();
    });

    document.addEventListener('DOMContentLoaded', () => {
        loadOrders();
        setInterval(loadOrders, 30000); // refresh list every 30s

        window.addEventListener('kk-new-chat-message', (e) => {
            if (e.detail && String(e.detail.orderId) === String(activeChatOrderId)) {
                loadStaffChatMessages();
            }
        });

        window.addEventListener('kk-new-order', () => {
            loadOrders();
        });

        window.addEventListener('kk-order-updated', () => {
            loadOrders();
        });
    });
</script>

