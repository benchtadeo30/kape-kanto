<%- include('../partials/header') %>

<style>
    /* Modern Order Card */
    .ao-card { 
        background: white; 
        border-radius: 20px; 
        padding: 1.5rem; 
        margin-bottom: 1.2rem; 
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        border: 1px solid #f0e6e0; 
        display: grid;
        grid-template-columns: auto 1fr auto auto;
        align-items: center; 
        gap: 2rem;
        position: relative;
        transition: all 0.3s;
        border-left: 6px solid #eee;
    }
    .ao-card:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(111, 78, 55, 0.08); }
    .ao-card.active-dropdown { z-index: 1001 !important; }
    
    .ao-card.status-pending { border-left-color: #ff9800; }
    .ao-card.status-preparing { border-left-color: #fbc02d; }
    .ao-card.status-ready { border-left-color: #4caf50; }
    .ao-card.status-out_for_delivery { border-left-color: #2196f3; }
    .ao-card.status-completed { border-left-color: #2e7d32; }
    .ao-card.status-cancelled { border-left-color: #f44336; }
    .ao-card.status-awaiting_payment { border-left-color: #9e9e9e; }

    .ao-id-wrap { display: flex; flex-direction: column; align-items: center; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); padding: 1rem 1.5rem; border-radius: 16px; color: white; min-width: 100px; box-shadow: 0 8px 20px rgba(111, 78, 55, 0.15); }
    .ao-id { font-weight: 900; font-size: 1.4rem; color: white; margin: 0; }
    .ao-id-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: rgba(255, 255, 255, 0.8); font-weight: 700; }

    .ao-info h4 { margin: 0 0 0.4rem 0; font-size: 1.3rem; color: var(--primary); }
    .ao-meta { font-size: 1rem; color: #777; margin: 0; display: flex; align-items: center; gap: 8px; }
    .ao-meta i { font-size: 0.9rem; color: var(--accent); }

    .ao-stats { display: flex; flex-direction: column; align-items: flex-end; gap: 0.6rem; }
    .ao-total { font-weight: 900; color: var(--primary); font-size: 1.5rem; margin: 0; }

    /* Dropdown UI */
    .ao-dropdown { position: relative; }
    .ao-drop-btn {
        background: var(--primary);
        color: white;
        border: none;
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 10px rgba(111, 78, 55, 0.2);
        font-size: 1.1rem;
    }
    .ao-drop-btn:hover { background: var(--primary-dark); transform: scale(1.05); }

    .ao-dropdown-menu {
        display: none;
        position: absolute;
        right: 0;
        top: calc(100% + 10px);
        background: white;
        min-width: 0;
        width: 260px;
        border-radius: 16px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        border: 1px solid #f0e6e0;
        z-index: 1000;
        padding: 0.75rem;
        animation: dropdownSlide 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    @keyframes dropdownSlide {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .ao-dropdown-menu.show { display: block; }

    .ao-drop-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        color: #444;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 10px;
        cursor: pointer;
        transition: 0.2s;
        width: 100%;
        border: none;
        background: none;
        text-align: left;
    }
    .ao-drop-item:hover { background: #f7f2ef; color: var(--admin-primary); }
    .ao-drop-item.danger:hover { background: #fff5f5; color: #f44336; }
    
    .ao-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 50px; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; }
    .badge-pending    { background:#fff3e0; color:#e65100; }
    .badge-preparing  { background:#fff8e1; color:#f57f17; }
    .badge-ready      { background:#e8f5e9; color:#2e7d32; }
    .badge-delivery   { background:#e3f2fd; color:#1565c0; }
    .badge-completed  { background:#c8e6c9; color:#1b5e20; }
    .badge-cancelled  { background:#ffebee; color:#b71c1c; }
    .badge-awaiting   { background:#f5f5f5; color:#616161; }

    .ao-type { font-size: 0.85rem; font-weight: 600; padding: 6px 14px; border-radius: 50px; background: #f7f2ef; color: var(--admin-primary); border: 1px solid #f0e6e0; }

    .ao-drop-divider { height: 1px; background: #f0e6e0; margin: 0.5rem 0; }
    .ao-drop-header { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #999; font-weight: 800; padding: 6px 16px; }


    @media (max-width: 900px) {
        .ao-card { grid-template-columns: 1fr !important; gap: 1.2rem; padding: 1.2rem; align-items: stretch; }
        .ao-id-wrap { flex-direction: row; justify-content: space-between; padding: 1rem 1.5rem; min-width: 0; }
        .ao-stats { align-items: stretch; border-top: 1px solid #f0e6e0; padding-top: 1rem; margin-top: 0.5rem; }
        .ao-total { font-size: 1.5rem; text-align: right; }
    }

    /* Tabs */
    .ao-tabs { display: flex; gap: 10px; margin-bottom: 2.5rem; flex-wrap: wrap; }
    .ao-tab { padding: 12px 24px; border-radius: 50px; border: 1.5px solid #eee; background: white; font-weight: 700; font-size: 1.1rem; cursor: pointer; transition: all 0.2s; color: var(--text-light); }
    .ao-tab.active { background: var(--primary); color: white; border-color: var(--primary); }

    /* Details modal */
    #ao-modal { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:9999; align-items:center; justify-content:center; }
    #ao-modal.open { display: flex; }
    .ao-modal-box { background: white; border-radius: 24px; padding: 2.5rem; width: 100%; max-width: 520px; max-height: 85vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,0.2); animation: popIn 0.3s cubic-bezier(0.34,1.56,0.64,1); }
    @keyframes popIn { from { transform: scale(0.9); opacity:0; } }

    .ao-items-list { border-radius: 16px; background: #fdfaf7; padding: 1.8rem; margin: 1.5rem 0; border: 1px solid #f0e6e0; }
    .ao-item-row { display: flex; justify-content: space-between; padding: 1.2rem 0; border-bottom: 1px dashed #f0e6e0; font-size: 1.2rem; align-items: center; }
    .ao-item-row:last-child { border: none; }
    .ao-breakdown-row { display: flex; justify-content: space-between; font-size: 1.1rem; color: #666; padding: 0.6rem 0; }
    .ao-breakdown-row.total { font-weight: 900; color: var(--primary); border-top: 2px solid #f0e6e0; margin-top: 1.2rem; padding-top: 1.2rem; font-size: 1.6rem; }
    .ao-breakdown-row.red { color: var(--danger); font-weight: 600; }

    .ao-detail-section { margin-bottom: 2rem; }
    .ao-detail-label { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; color: #999; font-weight: 700; margin-bottom: 0.8rem; display: block; }
    .ao-detail-value { font-size: 1.2rem; color: var(--primary-dark); font-weight: 600; }

    #ao-modal-body { padding-top: 0.5rem; }

    @media (max-width: 380px) {
        .ao-modal-box { padding: 1.5rem !important; }
        .responsive-grid { grid-template-columns: 1fr !important; gap: 1rem !important; }
        .ao-item-row { font-size: 1rem !important; }
        .ao-total { font-size: 1.2rem !important; }
    }
    </style>

    <div class="dashboard-layout">
    <%- include('../partials/admin-sidebar', { activePage: 'orders' }) %>

    <!-- Main -->
    <main>
        <div class="admin-header-row">
            <div>
                <h1 style="margin: 0; font-size: 2.8rem; font-weight: 800; color: var(--primary-dark);">Customer Orders</h1>
                <p style="color: var(--text-light); font-size: 1.1rem; font-weight: 500; margin-top: 5px;">Review and manage all café orders in real-time.</p>
            </div>
        </div>

        <div class="ao-tabs">
            <button class="ao-tab active" onclick="filterOrders('all', this)"><i class="fa-solid fa-list"></i> All Statuses</button>
            <button class="ao-tab" onclick="filterOrders('pending', this)"><i class="fa-solid fa-clock"></i> Pending</button>
            <button class="ao-tab" onclick="filterOrders('preparing', this)"><i class="fa-solid fa-fire"></i> Preparing</button>
            <button class="ao-tab" onclick="filterOrders('ready', this)"><i class="fa-solid fa-circle-check"></i> Ready</button>
            <button class="ao-tab" onclick="filterOrders('out_for_delivery', this)"><i class="fa-solid fa-truck-fast"></i> Out for Delivery</button>
            <button class="ao-tab" onclick="filterOrders('completed', this)"><i class="fa-solid fa-flag-checkered"></i> Completed</button>
        </div>

        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; background: white; padding: 1rem 1.5rem; border-radius: 16px; border: 1px solid #f0e6e0;">
            <span style="font-weight: 800; color: var(--primary-dark); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Filter by Type:</span>
            <div style="display: flex; gap: 8px;">
                <button class="btn btn-outline" id="type-all" onclick="filterType('all')" style="padding: 8px 16px; border-radius: 50px; font-size: 0.85rem; font-weight: 700; border-color: var(--primary); background: var(--primary); color: white;">All Types</button>
                <button class="btn btn-outline" id="type-delivery" onclick="filterType('delivery')" style="padding: 8px 16px; border-radius: 50px; font-size: 0.85rem; font-weight: 700;">Delivery Only</button>
                <button class="btn btn-outline" id="type-pickup" onclick="filterType('pickup')" style="padding: 8px 16px; border-radius: 50px; font-size: 0.85rem; font-weight: 700;">Pickup Only</button>
            </div>
        </div>

        <div style="font-size:0.85rem;color:var(--text-light);margin-bottom:1rem;" id="ao-count">Loading…</div>
        <div id="orders-container"></div>
        <div id="ao-pagination" style="display: flex; justify-content: center; gap: 1rem; align-items: center; padding: 2rem 0; border-top: 1px solid #f0e6e0; margin-top: 2rem;"></div>
    </main>
</div>

<!-- Details modal -->
<div id="ao-modal">
    <div class="ao-modal-box">
        <div class="flex-stack-mobile" style="margin-bottom:1rem;">
            <h3 id="ao-modal-title">Order Details</h3>
            <button onclick="closeModal()" style="background:none;border:none;font-size:1.3rem;cursor:pointer;color:var(--text-light);">&times;</button>
        </div>
        <div id="ao-modal-body"></div>
    </div>
</div>

<script>
    let allOrders = [];
    let currentFilter = 'all';
    let currentType = 'all';
    let currentPage = 1;
    const PAGE_LIMIT = 10;

    const BADGE_MAP = {
        pending:'badge-pending', preparing:'badge-preparing',
        ready:'badge-ready', out_for_delivery:'badge-delivery',
        completed:'badge-completed', cancelled:'badge-cancelled',
        awaiting_payment:'badge-awaiting'
    };

    const ALL_STATUSES = ['pending','preparing','ready','out_for_delivery','completed','cancelled'];

    async function loadOrders() {
        try {
            const offset = (currentPage - 1) * PAGE_LIMIT;
            const res = await fetch(`/api/orders/all?limit=${PAGE_LIMIT}&offset=${offset}&status=${currentFilter}`);
            if (res.ok) { 
                const data = await res.json();
                let filtered = data.items;
                
                if (currentType !== 'all') {
                    filtered = filtered.filter(o => o.order_type === currentType);
                }

                allOrders = data.items; // Store original for details
                renderOrders(filtered, currentType === 'all' ? data.total : filtered.length);
            }
        } catch(e) { console.error(e); }
    }

    function filterType(type) {
        currentType = type;
        currentPage = 1;
        
        // Update UI
        ['all', 'delivery', 'pickup'].forEach(t => {
            const btn = document.getElementById(`type-${t}`);
            if (t === type) {
                btn.style.background = 'var(--primary)';
                btn.style.color = 'white';
                btn.style.borderColor = 'var(--primary)';
            } else {
                btn.style.background = 'white';
                btn.style.color = 'var(--primary-dark)';
                btn.style.borderColor = '#eee';
            }
        });
        
        loadOrders();
    }

    function filterOrders(status, btn) {
        currentFilter = status;
        currentPage = 1; // Reset to page 1 on filter change
        document.querySelectorAll('.ao-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        loadOrders();
    }

    function renderOrders(items, total) {
        document.getElementById('ao-count').textContent = `Showing ${items.length} of ${total} order${total !== 1 ? 's' : ''}`;

        const c = document.getElementById('orders-container');
        if (!items.length) {
            c.innerHTML = `<div style="text-align:center;padding:3rem;color:var(--text-light);">
                <i class="fa-solid fa-inbox" style="font-size:2.5rem;margin-bottom:1rem;"></i><p>No orders here.</p></div>`;
            document.getElementById('ao-pagination').innerHTML = '';
            return;
        }
        c.innerHTML = items.map(o => buildCard(o)).join('');
        renderPagination(currentPage, total);
    }

    function renderPagination(current, total) {
        const container = document.getElementById('ao-pagination');
        const totalPages = Math.ceil(total / PAGE_LIMIT);
        
        if (totalPages <= 1) {
            container.innerHTML = '';
            return;
        }

        const prev = current === 1 ? totalPages : current - 1;
        const next = current === totalPages ? 1 : current + 1;

        let html = `
            <button class="btn btn-secondary" style="width: 40px; height: 40px; padding: 0; border-radius: 10px; display: flex; align-items: center; justify-content: center;" onclick="changePage(${prev})">
                <i class="fa-solid fa-chevron-left"></i>
            </button>
            <div id="page-numbers-container" style="display: flex; gap: 6px; align-items: center;">`;

        const limit = 10;
        let startPage = Math.max(1, current - Math.floor(limit / 2));
        let endPage = Math.min(totalPages, startPage + limit - 1);
        
        if (endPage - startPage < limit - 1) {
            startPage = Math.max(1, endPage - limit + 1);
        }

        if (startPage > 1) {
            html += `<button class="btn btn-outline" onclick="changePage(1)" style="width: 38px; height: 38px; padding: 0; border-radius: 10px;">1</button>`;
            if (startPage > 2) {
                html += `<span style="cursor: pointer; padding: 0 5px; color: #999; display: flex; align-items: center;" onclick="changePage(${Math.max(1, startPage - 1)})" title="Previous 10 pages">...</span>`;
            }
        }

        for (let i = startPage; i <= endPage; i++) {
            html += `<button class="btn ${i === current ? 'btn-primary' : 'btn-outline'}" 
                             onclick="changePage(${i})" 
                             style="width: 38px; height: 38px; padding: 0; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700;">${i}</button>`;
        }

        if (endPage < totalPages) {
            if (endPage < totalPages - 1) {
                html += `<span style="cursor: pointer; padding: 0 5px; color: #999; display: flex; align-items: center;" onclick="changePage(${Math.min(totalPages, endPage + 1)})" title="Next 10 pages">...</span>`;
            }
            html += `<button class="btn btn-outline" onclick="changePage(${totalPages})" style="width: 38px; height: 38px; padding: 0; border-radius: 10px;">${totalPages}</button>`;
        }

        html += `
            </div>
            <button class="btn btn-secondary" style="width: 38px; height: 38px; padding: 0; border-radius: 10px; display: flex; align-items: center; justify-content: center;" onclick="changePage(${next})">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        `;
        
        container.innerHTML = html;
    }

    function changePage(p) {
        currentPage = p;
        loadOrders();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function buildCard(o) {
        const date = new Date(o.created_at).toLocaleDateString('en-PH', {month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});
        const badgeCls = BADGE_MAP[o.status] || '';
        const statusLabel = o.status.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase());
        const isDelivery = o.order_type === 'delivery';

        const statusOptions = ALL_STATUSES
            .filter(s => isDelivery || s !== 'out_for_delivery')
            .map(s => `
                <button class="ao-drop-item ${s === o.status ? 'active' : ''}" onclick="updateStatus(${o.id}, '${s}')">
                    <i class="fa-solid ${s === 'completed' ? 'fa-check-double' : s === 'cancelled' ? 'fa-xmark' : 'fa-circle-dot'}" style="font-size:0.7rem; opacity:0.6;"></i>
                    Move to ${s.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase())}
                </button>
            `).join('');

        const riderInfo = o.status === 'out_for_delivery' && o.rider_name
            ? `<div class="ao-meta" style="color:#1565c0; margin-top:5px;"><i class="fa-solid fa-motorcycle"></i> Rider: ${o.rider_name}</div>` : '';

        return `
        <div class="ao-card status-${o.status}">
            <div class="ao-id-wrap" data-label="Order ID">
                <span class="ao-id-label">Order</span>
                <h3 class="ao-id">#${o.id}</h3>
            </div>

            <div class="ao-info" data-label="Customer Details">
                <h4>${o.username}</h4>
                <p class="ao-meta"><i class="fa-solid fa-envelope"></i> ${o.email}</p>
                <p class="ao-meta"><i class="fa-solid fa-clock"></i> ${date}</p>
                ${riderInfo}
            </div>

            <div class="ao-stats" data-label="Status & Amount">
                <span class="ao-type" style="margin-bottom:0.3rem; display:inline-flex; align-items:center; gap:8px;">
                    <i class="fa-solid fa-${isDelivery ? 'truck-fast' : 'shop'}"></i>
                    ${isDelivery ? 'Delivery' : 'Pickup'}
                </span>
                <span class="ao-badge ${badgeCls}">${statusLabel}</span>
                <p class="ao-total">₱${o.total.toFixed(2)}</p>
            </div>

            <div class="ao-dropdown" data-label="Actions">
                <button class="ao-drop-btn" onclick="toggleOrderDropdown(event, ${o.id})">
                    <i class="fa-solid fa-chevron-down"></i>
                </button>
                <div id="drop-${o.id}" class="ao-dropdown-menu">
                    <div class="ao-drop-header">Actions</div>
                    <button class="ao-drop-item" onclick="viewDetails(${o.id})">
                        <i class="fa-solid fa-eye"></i> View Full Details
                    </button>

                    <div class="ao-drop-divider"></div>
                    <div class="ao-drop-header">Update Status</div>
                    ${statusOptions}

                    <div class="ao-drop-divider"></div>
                    <button class="ao-drop-item danger" onclick="deleteOrder(${o.id})">
                        <i class="fa-solid fa-trash-can"></i> Delete Order Permanently
                    </button>
                </div>
            </div>
        </div>`;    }

    function toggleOrderDropdown(e, id) {
        e.stopPropagation();
        const menu = document.getElementById(`drop-${id}`);
        const card = menu.closest('.ao-card');
        const isShowing = menu.classList.contains('show');
        
        // Close all other menus and reset z-indices
        document.querySelectorAll('.ao-dropdown-menu').forEach(m => m.classList.remove('show'));
        document.querySelectorAll('.ao-card').forEach(c => c.classList.remove('active-dropdown'));
        
        if (!isShowing) {
            menu.classList.add('show');
            card.classList.add('active-dropdown');
        }
    }

    // Close dropdowns when clicking outside
    window.addEventListener('click', () => {
        document.querySelectorAll('.ao-dropdown-menu').forEach(m => m.classList.remove('show'));
        document.querySelectorAll('.ao-card').forEach(c => c.classList.remove('active-dropdown'));
    });

    async function updateStatus(id, status, selectEl) {
        const performUpdate = async () => {
            try {
                const res = await fetch(`/api/orders/${id}/status`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });
                if (res.ok) {
                    KapeKanto.toast(`Order #${id} → ${status.replace(/_/g,' ')}`, 'success');
                    loadOrders();
                } else {
                    const d = await res.json();
                    KapeKanto.toast(d.error, 'error');
                    if (selectEl) loadOrders(); // Reset select if failed
                }
            } catch(e) {
                KapeKanto.toast('Failed to update.', 'error');
                if (selectEl) loadOrders();
            }
        };

        if (status === 'cancelled') {
            KapeKanto.confirm(`Are you sure you want to CANCEL Order #${id}?`, performUpdate, { 
                type: 'danger', 
                confirmText: 'Yes, Cancel' 
            });
            // Reset select immediately so it doesn't show cancelled while modal is open
            if (selectEl) loadOrders();
        } else {
            performUpdate();
        }
    }

    async function deleteOrder(id) {
        KapeKanto.confirm(`PERMANENTLY DELETE Order #${id}? \nThis will REMOVE it from the database forever and return items to stock.`, async () => {
            try {
                const res = await fetch(`/api/orders/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    KapeKanto.toast(`Order #${id} deleted permanently`, 'success');
                    loadOrders();
                } else {
                    const d = await res.json();
                    KapeKanto.toast(d.error || 'Failed to delete.', 'error');
                }
            } catch(e) {
                KapeKanto.toast('Error communicating with server.', 'error');
            }
        }, { title: 'Delete Order', confirmText: 'Delete Permanently', type: 'danger' });
    }

    async function viewDetails(id) {
        // Find order in cached list for basic info
        const order = allOrders.find(o => o.id === id);
        if (!order) return;

        document.getElementById('ao-modal-title').textContent = `Order #${id} — ${order.username}`;
        document.getElementById('ao-modal-body').innerHTML = '<p style="color:var(--text-light)"><i class="fa-solid fa-circle-notch fa-spin"></i> Loading…</p>';
        document.getElementById('ao-modal').classList.add('open');

        try {
            // Use the admin-accessible full list data + per-user endpoint fallback
            const res = await fetch(`/api/orders/my/${id}`);
            if (!res.ok) throw new Error();
            const data = await res.json();
            renderModalBody(data);
        } catch(e) {
            // If the my/:id endpoint blocks admin, show summary from cached data
            renderModalBodyBasic(order);
        }
    }

    function renderModalBody(order) {
        const itemsHtml = order.items.map(i =>
            `<div class="ao-item-row">
                <div style="display:flex; flex-direction:column;">
                    <span style="font-weight:700; color:var(--primary-dark);">${i.quantity}x ${i.name}</span>
                    ${i.customizations ? `<small style="color:#888; font-size:0.75rem; margin-top:2px;">${Object.entries(JSON.parse(i.customizations||'{}')).map(([k,v])=>k+': '+v).join(', ')}</small>` : ''}
                </div>
                <span style="font-weight:700; color:var(--primary);">₱${i.subtotal.toFixed(2)}</span>
            </div>`
        ).join('');

        const vatExemptDiscount = order.sc_discount_amount > 0 ? (order.subtotal - (order.subtotal / 1.12)) : 0;
        const badgeCls = BADGE_MAP[order.status] || '';
        const statusLabel = order.status.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase());

        document.getElementById('ao-modal-body').innerHTML = `
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; background:#fdfaf7; padding:1rem; border-radius:16px; border:1px solid #f0e6e0;">
                <div>
                    <span class="ao-detail-label">Status</span>
                    <span class="ao-badge ${badgeCls}">${statusLabel}</span>
                </div>
                <div style="text-align:right;">
                    <div style="font-size: 0.7rem; color: #999; text-transform: uppercase; font-weight: 800; margin-bottom: 4px;">Order Type</div>
                    <span style="font-size: 0.85rem; font-weight: 800; color: var(--primary); background: rgba(111, 78, 55, 0.08); padding: 6px 12px; border-radius: 50px; display: inline-flex; align-items: center; gap: 8px;">
                        <i class="fa-solid fa-${order.order_type === 'delivery' ? 'truck-fast' : 'shop'}"></i>
                        ${order.order_type === 'delivery' ? 'Delivery' : 'Pickup'}
                    </span>
                </div>
            </div>

            <div class="responsive-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; margin-bottom:1.5rem;">
                <div class="ao-detail-section">
                    <span class="ao-detail-label">Customer</span>
                    <div class="ao-detail-value">${order.username}</div>
                    <div style="font-size:0.8rem; color:#777;">${order.email}</div>
                </div>
                <div class="ao-detail-section" style="text-align:right;">
                    <span class="ao-detail-label">Payment</span>
                    <div class="ao-detail-value">${order.payment_method.toUpperCase()}</div>
                    <div style="font-size:0.8rem; color:#777; font-weight:700;">${order.payment_status.toUpperCase()}</div>
                </div>
            </div>

            <div class="ao-items-list">
                <span class="ao-detail-label" style="margin-bottom:1rem;">Order Items</span>
                ${itemsHtml}
            </div>

            <div class="ao-detail-section">
                <span class="ao-detail-label">Price Breakdown</span>
                <div class="ao-breakdown-row"><span>Subtotal (Gross)</span><span>₱${order.subtotal.toFixed(2)}</span></div>
                
                ${order.sc_discount_amount > 0 ? `
                    <div class="ao-breakdown-row red"><span>VAT-Exempt Discount (12%)</span><span>-₱${vatExemptDiscount.toFixed(2)}</span></div>
                    <div class="ao-breakdown-row red"><span>SC/PWD Discount (20%)</span><span>-₱${order.sc_discount_amount.toFixed(2)}</span></div>
                ` : `
                    <div class="ao-breakdown-row"><span>VAT (12% Inclusive)</span><span>₱${(order.vat_amount||0).toFixed(2)}</span></div>
                `}

                ${order.promo_discount_amount > 0 ? `
                    <div class="ao-breakdown-row red"><span>🏷️ Promo Discount</span><span>-₱${order.promo_discount_amount.toFixed(2)}</span></div>
                ` : ''}

                <div class="ao-breakdown-row"><span>Delivery Fee</span><span>₱${(order.delivery_fee||0).toFixed(2)}</span></div>
                <div class="ao-breakdown-row total"><span>Amount Due</span><span>₱${order.total.toFixed(2)}</span></div>
            </div>

            ${order.delivery_address ? `
                <div class="ao-detail-section" style="background:#fff5f5; padding:1rem; border-radius:12px; border:1px solid #ffebeb;">
                    <span class="ao-detail-label" style="color:var(--danger);">Delivery Address</span>
                    <div style="font-size:0.9rem; color:var(--primary-dark); font-weight:500;">${order.delivery_address}</div>
                </div>
            ` : ''}

            ${order.notes ? `
                <div class="ao-detail-section" style="margin-top:1rem; background:#f0f7ff; padding:1rem; border-radius:12px; border:1px solid #e0eeff;">
                    <span class="ao-detail-label" style="color:#007bff;">Admin/Kitchen Notes</span>
                    <div style="font-size:0.9rem; color:var(--primary-dark); font-weight:500;">${order.notes}</div>
                </div>
            ` : ''}
        `;
    }

    function renderModalBodyBasic(order) {
        document.getElementById('ao-modal-body').innerHTML = `
            <p><strong>Type:</strong> ${order.order_type}</p>
            <p><strong>Status:</strong> ${order.status}</p>
            <p><strong>Total:</strong> ₱${order.total.toFixed(2)}</p>
            ${order.delivery_address ? `<p><strong>Address:</strong> ${order.delivery_address}</p>` : ''}
            <p style="color:var(--text-light);font-size:0.85rem;margin-top:1rem;">Item details require the admin single-order API endpoint.</p>`;
    }

    function closeModal() {
        document.getElementById('ao-modal').classList.remove('open');
    }
    document.getElementById('ao-modal').addEventListener('click', e => {
        if (e.target === document.getElementById('ao-modal')) closeModal();
    });

    document.addEventListener('DOMContentLoaded', () => {
        loadOrders();
        setInterval(loadOrders, 30000);
    });
</script>

<%- include('../partials/footer') %>
