                <h3 style="color:#666;margin:0 0 10px 0;">${searchTerm ? 'No matching campaigns' : 'No Active Campaigns'}</h3>
                <p style="color:#999;margin:0;">${searchTerm ? 'Try adjusting your search terms.' : 'Start by creating your first promotion or loyalty task.'}</p>
            </div>`;
            return;
        }

        container.innerHTML = items.map(item => {
            const isTask = item.type === 'task';
            const imgUrl = item.image ? (item.image.startsWith('http') || item.image.startsWith('/') || item.image.startsWith('data:') ? item.image : '/uploads/promos/' + item.image) : (isTask ? 'https://images.unsplash.com/photo-1559496417-e7f25cb247f3?auto=format&fit=crop&q=80&w=600' : 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&q=80&w=600');
            const typeLabel = isTask ? 'Loyalty Task' : 'Public Promo';
            const deadline = item.end_date ? new Date(item.end_date.replace(' ', 'T')) : null;
            const startTime = item.start_date ? new Date(item.start_date.replace(' ', 'T')) : null;
            const now = new Date();
            const isExpired = deadline && deadline < now;
            const isUpcoming = startTime && startTime > now;
            
            let statusText = item.is_active ? 'Active' : 'Paused';
            let badgeClass = item.is_active ? 'badge-success' : '';
            
            if (isExpired) {
                statusText = 'Expired';
                badgeClass = 'badge-danger';
            } else if (isUpcoming && item.is_active) {
                const timeStr = startTime.toLocaleString([], { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
                statusText = 'Upcoming';
                badgeClass = 'badge-secondary';
                badgeClass += ' upcoming-badge';
            }

            return `
                <div class="campaign-card ${isTask ? 'task' : ''}">
                    <div style="width: 140px; height: 100px; border-radius: 12px; overflow: hidden; flex-shrink: 0; background: #fdfaf7; display: flex; align-items: center; justify-content: center; border: 1px solid #eee;">
                        <img src="${imgUrl}" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                        <div style="width: 100%; height: 100%; background: #fff5f5; display: none; align-items: center; justify-content: center; color: #e57373; flex-direction: column; gap: 4px;">
                            <i class="fa-solid fa-image-slash" style="font-size: 1.2rem;"></i>
                            <span style="font-size: 0.6rem; font-weight: 700; text-transform: uppercase;">File Missing</span>
                        </div>
                    </div>
                    <div style="flex: 1;">
                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                            <span style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; color: ${isTask ? 'var(--success)' : 'var(--primary)'}; font-weight: 700;">${typeLabel}</span>
                            <span class="badge ${badgeClass}" style="font-size: 0.75rem;">${statusText}</span>
                        </div>
                        <h4 style="margin: 0 0 6px 0; font-size: 1.3rem; color: var(--primary-dark);">${item.title}</h4>
                        ${(item.description || item.customer_description) ? `<p style="margin: 0 0 12px 0; color: var(--text-light); font-size: 1.05rem; line-height: 1.5;">${item.description || item.customer_description}</p>` : ''}
                        
                        <div class="campaign-meta-row" style="display: flex; align-items: center; gap: 25px; flex-wrap: nowrap; font-size: 0.85rem; color: #555; font-weight: 600; background: #f8f8f8; padding: 12px 20px; border-radius: 12px; width: fit-content; max-width: 100%; overflow-x: auto; scrollbar-width: none;">
                            <div style="display: flex; align-items: center; gap: 15px;">
                                <span style="white-space: nowrap;"><i class="fa-solid fa-tag" style="color: var(--primary);"></i> ${item.discount_percent > 0 ? (item.discount_percent + '%') : ('&#8369;' + (item.discount_amount || 0))} OFF</span>
                                <span style="white-space: nowrap;"><i class="fa-solid fa-ticket" style="color: var(--primary);"></i> ${item.promo_code || 'No Code'}</span>
                            </div>

                            ${(startTime || deadline) ? `
                            <div style="display: flex; flex-direction: column; gap: 4px; border-left: 2px solid #e0e0e0; padding-left: 15px; min-width: 250px;">
                                ${startTime ? `<span style="white-space: nowrap; font-size: 0.75rem;"><i class="fa-solid fa-calendar-days" style="color: var(--success); width: 16px;"></i> Starts: ${startTime.toLocaleString([], { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' })}</span>` : ''}
                                ${deadline ? `<span style="white-space: nowrap; font-size: 0.75rem;"><i class="fa-solid fa-clock" style="color: var(--danger); width: 16px;"></i> Ends: ${deadline.toLocaleString([], { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' })}</span>` : ''}
                            </div>` : ''}
                        </div>
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 8px; justify-content: center;">
                        <button class="btn btn-outline" style="padding: 0.5rem; width: 40px; height: 40px; border-radius: 10px; border-color: #ddd;" onclick="openEditModal(${item.id}, '${item.type}')"><i class="fa-solid fa-pen-to-square"></i></button>
                        <button class="btn btn-secondary" style="padding: 0.5rem; width: 40px; height: 40px; border-radius: 10px;" onclick="handleAction(${item.id}, '${item.type}', 'toggle')"><i class="fa-solid fa-${item.is_active ? 'pause' : 'play'}"></i></button>
                        <button class="btn btn-danger" style="padding: 0.5rem; width: 40px; height: 40px; border-radius: 10px; background: rgba(255,0,0,0.05); border: 1px solid rgba(255,0,0,0.1); color: var(--danger);" onclick="handleAction(${item.id}, '${item.type}', 'delete')"><i class="fa-solid fa-trash"></i></button>
                    </div>
                </div>
            `;
        }).join('');
    }

    function toggleTaskFields(show) {
        document.getElementById('loyalty-fields').style.display = show ? 'block' : 'none';
        document.getElementById('tab-task').classList.toggle('active', show);
        document.getElementById('tab-promo').classList.toggle('active', !show);
        document.getElementById('tab-task').style.color = show ? 'var(--primary-dark)' : '#666';
        document.getElementById('tab-promo').style.color = !show ? 'var(--primary-dark)' : '#666';
    }

    function toggleTaskSubFields() {
        const type = document.getElementById('task-type').value;
        document.getElementById('subfield-item').style.display = (type === 'buy_specific_item') ? 'block' : 'none';
        document.getElementById('subfield-category').style.display = (type === 'buy_from_category') ? 'block' : 'none';
        document.getElementById('subfield-amount').style.display = (type === 'minimum_spend') ? 'block' : 'none';
        document.getElementById('subfield-quantity').style.display = (['buy_specific_item', 'buy_from_category', 'order_count'].includes(type)) ? 'block' : 'none';
        
        const labels = {
            buy_specific_item: 'Required Quantity',
            buy_from_category: 'Required Quantity',
            minimum_spend: 'Quantity (Times to Spend)',
            order_count: 'Required Orders'
        };
        document.getElementById('label-quantity').innerText = labels[type] || 'Quantity';
