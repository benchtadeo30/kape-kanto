    function toggleDiscountFields() {
        const type = document.getElementById('discount-type-select').value;
        document.getElementById('percent-field').style.display = (type === 'percent') ? 'block' : 'none';
        document.getElementById('flat-field').style.display = (type === 'flat') ? 'block' : 'none';
