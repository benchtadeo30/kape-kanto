    function adjustQty(n) {
        const input = document.getElementById('task-quantity');
        input.value = Math.max(1, parseInt(input.value) + n);
    }

    function openModal() {
        document.getElementById('campaign-form').reset();
        document.getElementById('campaign-id').value = '';
        document.getElementById('campaign-type').value = '';
        
        // Re-enable type switching when creating new
        document.querySelectorAll('input[name="is_loyalty_task"]').forEach(el => el.disabled = false);
        document.getElementById('tab-promo').style.opacity = '1';
        document.getElementById('tab-task').style.opacity = '1';
        document.querySelector('input[name="is_loyalty_task"][value="0"]').checked = true;
        
        document.getElementById('modal-title').innerText = 'Build Campaign';
        document.getElementById('campaign-file-display').innerText = 'Click to upload banner';
        document.getElementById('campaign-image-preview').style.display = 'none';
        document.getElementById('campaign-upload-icon').style.display = 'block';
        
        // Reset Custom Selects
        syncCustomSelects();

        // Reset Toggles
        document.getElementById('no-start-toggle').checked = false;
        document.getElementById('no-end-toggle').checked = false;
        toggleDateInput('start');
        toggleDateInput('end');
        
        // Reset selections
        selectedAppCategoryIds = [];
        selectedAppMenuItemIds = [];
        selectedTaskMenuItemId = null;
        selectedTaskCategoryId = null;
        tempSelections = [];
        
        updateSelectionSummary('item', 'campaign');
        updateSelectionSummary('category', 'campaign');
        updateSelectionSummary('item', 'task');
        updateSelectionSummary('category', 'task');

        toggleTaskFields(false);
        toggleTaskSubFields();
        document.getElementById('campaign-modal').style.display = 'flex';
    }

    function openEditModal(id, type) {
        const item = allCampaigns.find(i => i.id === id && i.type === type);
        if (!item) return;

        openModal();
        
        // Disable type switching when editing
        document.querySelectorAll('input[name="is_loyalty_task"]').forEach(el => el.disabled = true);
        document.getElementById('tab-promo').style.opacity = '0.5';
        document.getElementById('tab-task').style.opacity = '0.5';
        document.getElementById(`tab-${type}`).style.opacity = '1';
        
        document.getElementById('modal-title').innerText = 'Edit Campaign';
        document.getElementById('campaign-id').value = item.id;
        document.getElementById('campaign-type').value = item.type;
        
        document.getElementById('campaign-title').value = item.title || '';
        document.getElementById('campaign-desc').value = item.description || item.customer_description || '';
        
        if (item.image) {
            const preview = document.getElementById('campaign-image-preview');
            preview.style.display = 'block';
            preview.querySelector('img').src = item.image;
            document.getElementById('campaign-upload-icon').style.display = 'none';
            document.getElementById('campaign-file-display').innerText = 'Change banner image';
        }
        
        const hasPercent = (item.discount_percent || item.reward_discount || 0) > 0;
        if (hasPercent) {
            document.getElementById('discount-type-select').value = 'percent';
            document.getElementById('campaign-discount').value = item.discount_percent || item.reward_discount;
            document.getElementById('campaign-flat-discount').value = '';
        } else {
            document.getElementById('discount-type-select').value = 'flat';
            document.getElementById('campaign-flat-discount').value = item.discount_amount || 0;
            document.getElementById('campaign-discount').value = '';
        }
        toggleDiscountFields();

        document.getElementById('campaign-code').value = item.promo_code || '';
        document.getElementById('campaign-usage-limit').value = item.usage_limit || 1;
        
        // Handle Toggles & Dates
        if (!item.start_date || item.start_date === '') {
            document.getElementById('no-start-toggle').checked = true;
        } else {
            document.getElementById('no-start-toggle').checked = false;
            const startInput = document.getElementById('campaign-start');
            if (startInput._flatpickr) startInput._flatpickr.setDate(item.start_date);
            else startInput.value = item.start_date;
        }
        
        if (!item.end_date || item.end_date === '') {
            document.getElementById('no-end-toggle').checked = true;
        } else {
            document.getElementById('no-end-toggle').checked = false;
            const endInput = document.getElementById('campaign-end');
            if (endInput._flatpickr) endInput._flatpickr.setDate(item.end_date);
            else endInput.value = item.end_date;
        }
        
        toggleDateInput('start');
        toggleDateInput('end');

        // Handle Loyalty Fields
        const isTask = item.type === 'task';
        document.querySelector(`input[name="is_loyalty_task"][value="${isTask ? '1' : '0'}"]`).checked = true;
        
        if (isTask) {
            document.getElementById('task-type').value = item.task_type || 'buy_specific_item';
        }
        syncCustomSelects();
        
        toggleTaskFields(isTask);
        
        if (isTask) {
            document.getElementById('task-type').value = item.task_type || 'buy_specific_item';
            document.getElementById('task-quantity').value = item.required_quantity || 1;
            selectedTaskMenuItemId = item.required_menu_item_id || null;
            selectedTaskCategoryId = item.required_category_id || null;
            document.getElementById('task-amount').value = item.min_order_amount || '';
        } else {
            try {
                selectedAppCategoryIds = JSON.parse(item.applicable_category_ids || '[]');
                selectedAppMenuItemIds = JSON.parse(item.applicable_menu_item_ids || '[]');
            } catch(e) {
                selectedAppCategoryIds = [];
                selectedAppMenuItemIds = [];
            }
        }
        
        updateSelectionSummary('item', 'campaign');
        updateSelectionSummary('category', 'campaign');
        updateSelectionSummary('item', 'task');
        updateSelectionSummary('category', 'task');
        toggleTaskSubFields();
    }

    function closeModal() {
        const modal = document.getElementById('campaign-modal');
        modal.style.opacity = '0';
        setTimeout(() => {
            modal.style.display = 'none';
            modal.style.opacity = '1';
        }, 300);
    }

    document.getElementById('campaign-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const isLoyalty = document.querySelector('input[name="is_loyalty_task"]:checked').value === '1';
        const formData = new FormData();
        
        formData.append('title', document.getElementById('campaign-title').value);
        formData.append('description', document.getElementById('campaign-desc').value);
        
        const dType = document.getElementById('discount-type-select').value;
        if (dType === 'percent') {
            formData.append('discount_percent', document.getElementById('campaign-discount').value);
            formData.append('discount_amount', 0);
        } else {
            formData.append('discount_percent', 0);
            formData.append('discount_amount', document.getElementById('campaign-flat-discount').value);
        }
        
        const promoCode = document.getElementById('campaign-code').value;
        if (!promoCode || !promoCode.trim()) {
            KapeKanto.toast('Promo code is required.', 'error');
            return;
        }
        
        formData.append('promo_code', promoCode);
        formData.append('applicable_category_ids', JSON.stringify(selectedAppCategoryIds));
        formData.append('applicable_menu_item_ids', JSON.stringify(selectedAppMenuItemIds));
        formData.append('usage_limit', document.getElementById('campaign-usage-limit').value);
        
        const startVal = document.getElementById('no-start-toggle').checked ? '' : document.getElementById('campaign-start').value;
        const endVal = document.getElementById('no-end-toggle').checked ? '' : document.getElementById('campaign-end').value;
        
        formData.append('start_date', startVal.replace('T', ' '));
        formData.append('end_date', endVal.replace('T', ' '));
        formData.append('is_active', 1);
        
        if (isLoyalty) {
            formData.append('is_loyalty_task', 1);
            formData.append('task_type', document.getElementById('task-type').value);
            formData.append('required_quantity', document.getElementById('task-quantity').value);
            formData.append('required_menu_item_id', selectedTaskMenuItemId || '');
            formData.append('required_category_id', selectedTaskCategoryId || '');
            formData.append('min_order_amount', document.getElementById('task-amount').value);
            formData.append('task_end_date', endVal); // Sync task end with promo end
        }

        const imageFile = document.getElementById('campaign-image').files[0];
        if (imageFile) {
            try {
                const optimized = await KapeKanto.optimizeImage(imageFile, 1000, 0.8);
                formData.append('image', optimized.blob, 'promo.jpg');
            } catch (err) {
                console.error('Image optimization failed:', err);
                formData.append('image', imageFile); // Fallback to original
            }
        }

        const id = document.getElementById('campaign-id').value;
        const originalType = document.getElementById('campaign-type').value;
        if (originalType) formData.append('original_type', originalType);
        
        const endpoint = id ? `/api/promos/${id}` : '/api/promos';
        const method = id ? 'PUT' : 'POST';

        try {
            const res = await fetch(endpoint, { method, body: formData });
            const data = await res.json();
            if (res.ok) {
                KapeKanto.toast(data.message, 'success');
                closeModal();
                loadData();
            } else {
                KapeKanto.toast(data.error, 'error');
            }
        } catch (error) {
            KapeKanto.toast('Server connection failed.', 'error');
        }
    });

    async function handleCleanup() {
        KapeKanto.confirm('This will permanently delete all EXPIRED and INACTIVE campaigns, including related user coupons and progress. Continue?', async () => {
            try {
                const res = await fetch('/api/promos/cleanup', { method: 'DELETE' });
                const data = await res.json();
                if (res.ok) {
                    KapeKanto.toast(data.message, 'success');
                    loadData();
                } else {
                    KapeKanto.toast(data.error, 'error');
                }
            } catch (e) {
                KapeKanto.toast('Cleanup failed.', 'error');
            }
        }, { title: 'Cleanup Promos', confirmText: 'Yes, Cleanup', type: 'danger' });
    }

    async function handleToggleAll() {
        const anyActive = allCampaigns.some(c => c.is_active);
        const action = anyActive ? 'pause' : 'resume';
        const confirmMsg = anyActive 
            ? 'This will PAUSE all active promotions and loyalty tasks. Continue?' 
            : 'This will ACTIVATE all promotions and loyalty tasks. Continue?';

        KapeKanto.confirm(confirmMsg, async () => {
            try {
                const res = await fetch('/api/promos/toggle-all', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action })
                });
                const data = await res.json();
                if (res.ok) {
                    KapeKanto.toast(data.message, 'success');
                    loadData();
                } else {
                    KapeKanto.toast(data.error, 'error');
                }
            } catch (e) {
                KapeKanto.toast('Bulk action failed.', 'error');
            }
        }, { 
            title: anyActive ? 'Pause All' : 'Resume All', 
            confirmText: 'Yes, Proceed', 
            type: anyActive ? 'danger' : 'success' 
        });
    }

    async function handleAction(id, type, action) {
        const isTask = type === 'task';
        const endpoint = isTask ? `/api/promos/tasks/${id}` : `/api/promos/${id}`;
        
        if (action === 'delete') {
            KapeKanto.confirm('Permanently remove this campaign?', async () => {
                try {
                    const res = await fetch(endpoint, { method: 'DELETE' });
                    if (res.ok) { KapeKanto.toast('Campaign removed.', 'success'); loadData(); }
                } catch (e) { KapeKanto.toast('Delete failed.', 'error'); }
            }, { title: 'Delete Campaign', confirmText: 'Yes, Remove', type: 'danger' });
        } else if (action === 'toggle') {
            try {
                const res = await fetch(`${endpoint}/toggle`, { method: 'PATCH' });
                if (res.ok) { loadData(); }
            } catch (e) { KapeKanto.toast('Action failed.', 'error'); }
        }
    }

    function toggleDateInput(type) {
        const isToggled = document.getElementById(`no-${type}-toggle`).checked;
        const container = document.getElementById(`${type}-date-container`);
        const toggleContainer = document.getElementById(`toggle-${type}-container`);
        const input = document.getElementById(`campaign-${type}`);
        
        if (isToggled) {
            container.style.opacity = '0.4';
            container.style.pointerEvents = 'none';
            toggleContainer.classList.add('active');
            if (input._flatpickr) input._flatpickr.clear();
        } else {
            container.style.opacity = '1';
            container.style.pointerEvents = 'all';
            toggleContainer.classList.remove('active');
        }
    }

    function syncCustomSelects() {
        document.querySelectorAll('select.kk-select-modern').forEach(select => {
            const wrapper = document.getElementById(`kk-container-${select.id}`);
            if (wrapper) {
                const trigger = wrapper.querySelector('.kk-select-trigger');
                const currentOption = select.options[select.selectedIndex];
                if (currentOption) {
                    const icon = currentOption.dataset.icon ? `<i class="fa-solid ${currentOption.dataset.icon}"></i>` : '';
                    trigger.innerHTML = `<span>${icon} ${currentOption.text}</span><i class="fa-solid fa-chevron-down"></i>`;
                    wrapper.querySelectorAll('.kk-select-option').forEach((optDiv, idx) => {
                        optDiv.classList.toggle('selected', idx === select.selectedIndex);
                    });
                }
            }
        });
    }

    function updateServerClock() {
        const now = new Date();
        const clock = document.getElementById('server-clock');
        if (clock) {
            clock.innerText = now.toLocaleTimeString([], { hour12: true, hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        loadData();
        
        // Initialize Server Clock
        updateServerClock();
        setInterval(updateServerClock, 1000);

        // Initialize Flatpickr for beautiful date/time picking
        flatpickr(".premium-picker", {
            enableTime: true,
            altInput: true,
            altFormat: "F j, Y h:i K",
            dateFormat: "Y-m-d H:i",
            time_24hr: false,
            minDate: "today",
            disableMobile: "true",
            locale: {
                firstDayOfWeek: 1
            }
        });
    });

    function handleImageChange(input) {
        const file = input.files[0];
        if (file) {
            document.getElementById('campaign-file-display').innerText = file.name;
            const reader = new FileReader();
            reader.onload = (e) => {
                const preview = document.getElementById('campaign-image-preview');
                preview.style.display = 'block';
                preview.querySelector('img').src = e.target.result;
                document.getElementById('campaign-upload-icon').style.display = 'none';
            };
            reader.readAsDataURL(file);
        }
    }
</script>

