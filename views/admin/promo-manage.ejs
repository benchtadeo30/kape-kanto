<script>
    let contextData = { menuItems: [], categories: [] };
    let currentItemPage = 1;
    const itemsPerPage = 10;
    let selectedAppCategoryIds = [];
    let selectedAppMenuItemIds = [];
    let selectedTaskMenuItemId = null;
    let selectedTaskCategoryId = null;
    let tempSelections = []; 
    let currentSelectorType = ''; // 'item' or 'category'
    let currentSelectorContext = 'campaign'; // 'campaign' or 'task'
    let searchTimeout = null;
    let cachedPromos = [];
    let allCampaigns = [];
    let currentOffset = 0;
    const limit = 8;
    let currentPage = 1;
    const campaignsPerPage = 6;

    async function loadCampaigns() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
            currentPage = 1;
            renderPaginatedList();
        }, 300);
    }

    function debounceSearch() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
            currentPage = 1;
            renderPaginatedList();
        }, 300);
    }

    async function loadData() {
        try {
            const [promosRes, tasksRes, contextRes] = await Promise.all([
                fetch('/api/promos/all'),
                fetch('/api/promos/tasks'),
                fetch('/api/promos/context')
            ]);

            if (promosRes.status === 401 || tasksRes.status === 401 || contextRes.status === 401) {
                KapeKanto.toast('Session expired. Please log in again.', 'warning');
                window.location.href = '/login';
                return;
            }

            if (!promosRes.ok || !tasksRes.ok || !contextRes.ok) {
                throw new Error('Failed to fetch campaign data');
            }

            const promos = await promosRes.json();
            const tasks = await tasksRes.json();
            contextData = await contextRes.json();
            
            // Safety check for contextData
            if (!contextData.menuItems) contextData.menuItems = [];
            if (!contextData.categories) contextData.categories = [];

            populateSelects();
            updateStats(promos, tasks);
            
            // Combine and sort all campaigns for the unified list
            allCampaigns = [
                ...promos.map(p => ({ ...p, type: 'promo' })),
                ...tasks.map(t => ({ ...t, type: 'task' }))
            ].sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
            
            renderPaginatedList();
        } catch (e) {
            console.error('Sync error:', e);
            KapeKanto.toast(e.message || 'Failed to sync campaign data.', 'error');
            renderPaginatedList(); // Show empty/cached state
        }
    }

    function populateSelects() {
        const itemSelect = document.getElementById('task-menu-item');
        if (itemSelect && contextData.menuItems) {
            itemSelect.innerHTML = contextData.menuItems.map(i => `<option value="${i.id}">${i.name}</option>`).join('');
        }
        
        const catSelect = document.getElementById('task-category');
        if (catSelect && contextData.categories) {
            catSelect.innerHTML = contextData.categories.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
        }
    }

    // --- Selector Modal Logic ---

    function openItemSelector(context = 'campaign') {
        currentSelectorType = 'item';
        currentSelectorContext = context;
        if (context === 'campaign') {
            tempSelections = [...selectedAppMenuItemIds];
        } else {
            tempSelections = selectedTaskMenuItemId ? [selectedTaskMenuItemId] : [];
        }
        currentItemPage = 1;
        document.getElementById('item-selector-modal').style.display = 'flex';
        renderItemSelector();
    }

    function openCategorySelector(context = 'campaign') {
        currentSelectorType = 'category';
        currentSelectorContext = context;
        if (context === 'campaign') {
            tempSelections = [...selectedAppCategoryIds];
        } else {
            tempSelections = selectedTaskCategoryId ? [selectedTaskCategoryId] : [];
        }
        document.getElementById('category-selector-modal').style.display = 'flex';
        renderCategorySelector();
    }

    function closeSelector(type) {
        const modal = document.getElementById(`${type}-selector-modal`);
        modal.classList.add('animate-out');
        setTimeout(() => {
            modal.style.display = 'none';
            modal.classList.remove('animate-out');
            tempSelections = [];
        }, 300);
    }

    function renderItemSelector() {
        const grid = document.getElementById('item-selector-grid');
        const search = document.getElementById('item-selector-search').value.toLowerCase();
        
        // Dynamic Filter: If categories are selected in the campaign form, 
        // filter items to only show those from the targeted categories.
        let filtered = contextData.menuItems;
        
        const activeCategoryFilters = currentSelectorContext === 'campaign' 
            ? (selectedAppCategoryIds || []) 
            : (selectedTaskCategoryId ? [selectedTaskCategoryId.toString()] : []);

        if (activeCategoryFilters.length > 0) {
            filtered = filtered.filter(item => {
                // Handle cases where category_id might be missing or different types
                if (item.category_id === undefined || item.category_id === null) return false;
                const catIdStr = item.category_id.toString();
                return activeCategoryFilters.some(filterId => filterId.toString() === catIdStr);
            });
        }

        if (search) {
            filtered = filtered.filter(item => 
                item.name.toLowerCase().includes(search)
            );
        }

        const totalPages = Math.ceil(filtered.length / itemsPerPage) || 1;
        if (currentItemPage > totalPages) currentItemPage = totalPages;

        const start = (currentItemPage - 1) * itemsPerPage;
        const pageItems = filtered.slice(start, start + itemsPerPage);

        grid.innerHTML = pageItems.map(item => {
            const isSelected = tempSelections.includes(item.id.toString());
            const imgUrl = item.image 
                ? (item.image.startsWith('http') ? item.image : `/uploads/menu/${item.image}`) 
                : 'https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&q=80&w=200';
            
            return `
                <div class="selector-card ${isSelected ? 'selected' : ''}" onclick="toggleSelectorItem('${item.id}')" style="display: flex; flex-direction: column; height: 100%; min-height: 150px; justify-content: flex-start; align-items: center;">
                    <div style="width: 100%; padding-top: 75%; position: relative; border-radius: 8px; overflow: hidden; margin-bottom: 8px; flex-shrink: 0; background: #f0f0f0;">
                        <img src="${imgUrl}" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;" alt="${item.name || 'Menu Item'}">
                    </div>
                    <div style="width: 100%; padding: 4px; text-align: center; flex-grow: 1; display: flex; flex-direction: column; justify-content: center;">
                        <span style="font-size: 0.9rem; font-weight: 800; color: #000; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-shadow: 0px 0px 1px rgba(0,0,0,0.1);">
                            ${item.name || 'Unnamed Item'}
                        </span>
                    </div>
                </div>
            `;
        }).join('');

        renderSelectorPagination(totalPages);
        document.getElementById('item-selection-count').innerText = tempSelections.length;
    }

    function renderSelectorPagination(totalPages) {
        const controls = document.getElementById('item-selector-pagination');
        const pageNumbers = document.getElementById('item-page-numbers');
        
        if (totalPages <= 1) {
            controls.style.display = 'none';
            return;
        }
        
        controls.style.display = 'flex';
        document.getElementById('item-prev-btn').disabled = currentItemPage === 1;
        document.getElementById('item-next-btn').disabled = currentItemPage === totalPages;
        
        let pagesHtml = '';
        const limit = 10;
        
        let startPage = Math.max(1, currentItemPage - Math.floor(limit / 2));
        let endPage = Math.min(totalPages, startPage + limit - 1);
        
        if (endPage - startPage < limit - 1) {
            startPage = Math.max(1, endPage - limit + 1);
        }

        if (startPage > 1) {
            pagesHtml += `<button class="btn btn-outline" onclick="goToSelectorPage(1)" style="width: 35px; height: 35px; padding: 0;">1</button>`;
            if (startPage > 2) {
                pagesHtml += `<span style="cursor: pointer; padding: 0 5px; color: #999;" onclick="goToSelectorPage(${Math.max(1, startPage - 1)})">...</span>`;
            }
        }

        for (let i = startPage; i <= endPage; i++) {
            pagesHtml += `<button class="btn ${i === currentItemPage ? 'btn-primary' : 'btn-outline'}" 
                                 onclick="goToSelectorPage(${i})" 
                                 style="width: 35px; height: 35px; padding: 0; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700;">${i}</button>`;
        }

        if (endPage < totalPages) {
            if (endPage < totalPages - 1) {
                pagesHtml += `<span style="cursor: pointer; padding: 0 5px; color: #999;" onclick="goToSelectorPage(${Math.min(totalPages, endPage + 1)})">...</span>`;
            }
            pagesHtml += `<button class="btn btn-outline" onclick="goToSelectorPage(${totalPages})" style="width: 35px; height: 35px; padding: 0;">${totalPages}</button>`;
        }

        pageNumbers.innerHTML = pagesHtml;
    }

    function goToSelectorPage(page) {
        currentItemPage = page;
        renderItemSelector();
    }

    function renderCategorySelector() {
        const list = document.getElementById('category-selector-list');
        
        list.innerHTML = contextData.categories.map(cat => {
            const isSelected = tempSelections.includes(cat.id.toString());
            
            return `
                <div class="category-selector-item ${isSelected ? 'selected' : ''}" onclick="toggleSelectorItem('${cat.id}')">
                    <span style="font-size: 1rem; font-weight: 600;">${cat.name}</span>
                    ${isSelected ? '<i class="fa-solid fa-check" style="margin-left: auto;"></i>' : ''}
                </div>
            `;
        }).join('');

        if (document.getElementById('category-selection-count')) {
            document.getElementById('category-selection-count').innerText = tempSelections.length;
        }
    }

    function toggleSelectorItem(id) {
        const idx = tempSelections.indexOf(id.toString());
        
        if (currentSelectorContext === 'task') {
            // Single selection for tasks
            if (idx > -1) {
                tempSelections = [];
            } else {
                tempSelections = [id.toString()];
            }
        } else {
            // Multiple selection for campaigns
            if (idx > -1) {
                tempSelections.splice(idx, 1);
            } else {
                tempSelections.push(id.toString());
            }
        }
        
        if (currentSelectorType === 'item') renderItemSelector();
        else renderCategorySelector();
    }

    function changeSelectorPage(type, delta) {
        if (type === 'item') {
            currentItemPage += delta;
            if (currentItemPage < 1) currentItemPage = 1;
            renderItemSelector();
        }
    }

    function confirmSelection(type) {
        if (type === 'item') {
            if (currentSelectorContext === 'campaign') {
                selectedAppMenuItemIds = [...tempSelections];
                updateSelectionSummary('item', 'campaign');
            } else {
                selectedTaskMenuItemId = tempSelections[0] || null;
                updateSelectionSummary('item', 'task');
            }
        } else {
            if (currentSelectorContext === 'campaign') {
                selectedAppCategoryIds = [...tempSelections];
                updateSelectionSummary('category', 'campaign');
            } else {
                selectedTaskCategoryId = tempSelections[0] || null;
                updateSelectionSummary('category', 'task');
            }
        }
        closeSelector(type);
    }

    function selectEverything(type) {
        tempSelections = [];
        confirmSelection(type);
    }

    function updateSelectionSummary(type, context = 'campaign') {
        if (type === 'item') {
            if (context === 'campaign') {
                const count = selectedAppMenuItemIds.length;
                document.getElementById('selected-items-summary').innerText = count === 0 ? 'All Items' : `${count} Items Selected`;
            } else {
                const item = contextData.menuItems.find(i => i.id == selectedTaskMenuItemId);
                document.getElementById('selected-task-item-summary').innerText = item ? item.name : 'Select Item';
            }
        } else {
            if (context === 'campaign') {
                const count = selectedAppCategoryIds.length;
                document.getElementById('selected-cats-summary').innerText = count === 0 ? 'All Categories' : `${count} Categories Selected`;
            } else {
                const cat = contextData.categories.find(c => c.id == selectedTaskCategoryId);
                document.getElementById('selected-task-cat-summary').innerText = cat ? cat.name : 'Select Category';
            }
        }
    }

    function updateStats(promos, tasks) {
        const activeCount = promos.filter(p => p.is_active).length + tasks.filter(t => t.is_active).length;
        document.getElementById('stat-promos').innerText = promos.filter(p => p.is_active).length;
        document.getElementById('stat-tasks').innerText = tasks.filter(t => t.is_active).length;
        
        // Update Global Toggle Button
        const globalBtn = document.getElementById('global-toggle-btn');
        if (globalBtn) {
            if (activeCount > 0) {
                globalBtn.innerHTML = '<i class="fa-solid fa-power-off"></i>';
                globalBtn.style.color = 'var(--danger)';
                globalBtn.style.borderColor = 'var(--danger)';
                globalBtn.title = 'Pause All Campaigns';
            } else {
                globalBtn.innerHTML = '<i class="fa-solid fa-play"></i>';
                globalBtn.style.color = 'var(--success)';
                globalBtn.style.borderColor = 'var(--success)';
                globalBtn.title = 'Resume All Campaigns';
            }
        }

        const now = new Date();
        const expired = promos.filter(p => p.end_date && new Date(p.end_date) < now).length + 
                        tasks.filter(t => t.end_date && new Date(t.end_date) < now).length;
        document.getElementById('stat-expired').innerText = expired;
    }

    function renderPaginatedList() {
        const searchTerm = document.getElementById('campaign-search').value.toLowerCase().trim();
        
        let filtered = allCampaigns;
        if (searchTerm) {
            filtered = allCampaigns.filter(item => 
                item.title.toLowerCase().includes(searchTerm) || 
                (item.description && item.description.toLowerCase().includes(searchTerm)) ||
                (item.promo_code && item.promo_code.toLowerCase().includes(searchTerm))
            );
        }

        const totalPages = Math.ceil(filtered.length / campaignsPerPage);
        if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;

        const startIndex = (currentPage - 1) * campaignsPerPage;
        const endIndex = startIndex + campaignsPerPage;
        const pagedData = filtered.slice(startIndex, endIndex);

        renderUnifiedList(pagedData);
        renderPaginationControls(totalPages);
    }

    function renderPaginationControls(totalPages) {
        const controls = document.getElementById('pagination-controls');
        const pageNumbers = document.getElementById('page-numbers');
        
        if (totalPages <= 1) {
            controls.style.display = 'none';
            return;
        }
        
        controls.style.display = 'flex';
        document.getElementById('prev-btn').disabled = false;
        document.getElementById('next-btn').disabled = false;
        
        let pagesHtml = '';
        const limit = 10;
        
        let startPage = Math.max(1, currentPage - Math.floor(limit / 2));
        let endPage = Math.min(totalPages, startPage + limit - 1);
        
        if (endPage - startPage < limit - 1) {
            startPage = Math.max(1, endPage - limit + 1);
        }

        // Add dots and jump if start is not 1
        if (startPage > 1) {
            pagesHtml += `<button class="btn btn-outline" onclick="goToPage(1)" style="width: 35px; height: 35px; padding: 0;">1</button>`;
            if (startPage > 2) {
                pagesHtml += `<span style="cursor: pointer; padding: 0 8px; color: #999; display: flex; align-items: center;" onclick="goToPage(${Math.max(1, startPage - 1)})" title="Previous 10 pages">...</span>`;
            }
        }

        for (let i = startPage; i <= endPage; i++) {
            pagesHtml += `<button class="btn ${i === currentPage ? 'btn-primary' : 'btn-outline'}" 
                                 onclick="goToPage(${i})" 
                                 style="width: 35px; height: 35px; padding: 0; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700;">${i}</button>`;
        }

        // Add dots and jump if end is not totalPages
        if (endPage < totalPages) {
            if (endPage < totalPages - 1) {
                pagesHtml += `<span style="cursor: pointer; padding: 0 8px; color: #999; display: flex; align-items: center;" onclick="goToPage(${Math.min(totalPages, endPage + 1)})" title="Next 10 pages">...</span>`;
            }
            pagesHtml += `<button class="btn btn-outline" onclick="goToPage(${totalPages})" style="width: 35px; height: 35px; padding: 0;">${totalPages}</button>`;
        }

        pageNumbers.innerHTML = pagesHtml;
    }

    function changePage(delta) {
        const searchTerm = document.getElementById('campaign-search').value.toLowerCase().trim();
        const filtered = allCampaigns.filter(item => {
            return item.title.toLowerCase().includes(searchTerm) || 
                   (item.description || item.customer_description || '').toLowerCase().includes(searchTerm) ||
                   (item.promo_code || '').toLowerCase().includes(searchTerm);
        });
        const totalPages = Math.ceil(filtered.length / campaignsPerPage);

        if (totalPages <= 1) return;

        currentPage += delta;
        if (currentPage < 1) currentPage = totalPages;
        if (currentPage > totalPages) currentPage = 1;

        renderPaginatedList();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function goToPage(page) {
        currentPage = page;
        renderPaginatedList();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function renderUnifiedList(items) {
