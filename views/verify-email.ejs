<%- include('partials/header') %>

<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh; padding: 2rem 5%;">
    <div class="card" style="width: 100%; max-width: 600px; text-align: center; padding: 3rem;">

        <div style="width: 80px; height: 80px; background: rgba(111,78,55,0.1); color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 2rem; font-size: 2rem;">
            <i class="fa-solid fa-envelope-circle-check"></i>
        </div>

        <h1 style="font-size: 2rem; margin-bottom: 0.5rem;">Verify Your Email</h1>
        <p style="color: var(--text-light); margin-bottom: 2rem;">
            We've sent a 6-digit code to <strong><%= email %></strong>. Enter it below to activate your account.
        </p>

        <form id="verify-form">
            <input type="hidden" id="verify-email" value="<%= email %>">

            <!-- OTP Boxes -->
            <div class="otp-inputs" id="otp-inputs">
                <input type="text" class="otp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" id="otp-0">
                <input type="text" class="otp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" id="otp-1">
                <input type="text" class="otp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" id="otp-2">
                <input type="text" class="otp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" id="otp-3">
                <input type="text" class="otp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" id="otp-4">
                <input type="text" class="otp-digit" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="off" id="otp-5">
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.05rem; border-radius: 50px;" id="verify-btn">
                <i class="fa-solid fa-check-circle"></i> Verify Account
            </button>
        </form>

        <div style="margin-top: 1.8rem;">
            <p style="font-size: 0.9rem; color: var(--text-light); margin-bottom: 0.5rem;">
                Didn't receive the code?
                <a href="#" id="resend-link" style="color: var(--primary); font-weight: bold;">Resend Code</a>
            </p>
            <% if (typeof user !== 'undefined' && user && user.pending_email) { %>
                <p style="font-size: 0.9rem; color: var(--text-light); margin-top: 1rem;">
                    Changed your mind? <a href="#" id="cancel-change-link" style="color: var(--danger); font-weight: bold;">Cancel and keep old email</a>
                </p>
            <% } %>
        </div>
    </div>
</div>

<script>
    // ── OTP Box Behaviour ─────────────────────────────────────────
    const digits = document.querySelectorAll('.otp-digit');

    digits.forEach((input, idx) => {
        input.addEventListener('input', (e) => {
            const val = e.target.value.replace(/\D/g, '');
            e.target.value = val;
            if (val) {
                e.target.classList.add('otp-filled');
                if (idx < digits.length - 1) {
                    digits[idx + 1].focus();
                } else {
                    // ALL DIGITS FILLED - Auto-submit!
                    const code = getOtpValue();
                    if (code.length === 6) {
                        document.getElementById('verify-form').dispatchEvent(new Event('submit'));
                    }
                }
            } else {
                e.target.classList.remove('otp-filled');
            }
        });

        input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace' && !e.target.value && idx > 0) {
                digits[idx - 1].focus();
                digits[idx - 1].value = '';
                digits[idx - 1].classList.remove('otp-filled');
            }
        });

        input.addEventListener('paste', (e) => {
            e.preventDefault();
            const pasted = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '').slice(0, 6);
            pasted.split('').forEach((ch, i) => {
                if (digits[i]) {
                    digits[i].value = ch;
                    digits[i].classList.add('otp-filled');
                }
            });
            const nextEmpty = [...digits].findIndex(d => !d.value);
            if (nextEmpty !== -1) digits[nextEmpty].focus();
            else digits[digits.length - 1].focus();
        });
    });

    function getOtpValue() {
        return [...digits].map(d => d.value).join('');
    }

    // ── Verify Form ───────────────────────────────────────────────
    document.getElementById('verify-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('verify-email').value;
        const code = getOtpValue();
        const btn = document.getElementById('verify-btn');

        if (code.length < 6) {
            KapeKanto.toast('Please enter all 6 digits.', 'warning');
            digits[0].focus();
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Verifying…';

        try {
            const res = await fetch('/api/auth/verify-email', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, code })
            });

            const data = await res.json();
            if (res.ok) {
                KapeKanto.toast('Email verified! Welcome to Kape Kanto Hub ☕', 'success');
                setTimeout(() => window.location.href = '/', 1500);
            } else {
                KapeKanto.toast(data.error || 'Invalid code. Please try again.', 'error');
                digits.forEach(d => { d.value = ''; d.classList.remove('otp-filled'); });
                digits[0].focus();
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-check-circle"></i> Verify Account';
            }
        } catch (error) {
            KapeKanto.toast('An error occurred. Please try again.', 'error');
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-check-circle"></i> Verify Account';
        }
    });

    // ── Resend Code ───────────────────────────────────────────────
    document.getElementById('resend-link').addEventListener('click', async (e) => {
        e.preventDefault();
        const email = document.getElementById('verify-email').value;
        const link = e.target;

        if (link.style.pointerEvents === 'none') return;

        link.style.pointerEvents = 'none';
        link.style.opacity = '0.5';
        link.innerText = 'Sending…';

        try {
            const res = await fetch('/api/auth/resend-code', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email })
            });

            const data = await res.json();
            if (res.ok) {
                KapeKanto.toast('New code sent! Check your inbox.', 'success');
                digits.forEach(d => { d.value = ''; d.classList.remove('otp-filled'); });
                digits[0].focus();
            } else {
                KapeKanto.toast(data.error || 'Failed to resend code.', 'error');
            }
        } catch (error) {
            KapeKanto.toast('Failed to resend code.', 'error');
        } finally {
            // Short delay before allowing resend again
            setTimeout(() => {
                link.style.pointerEvents = 'auto';
                link.style.opacity = '1';
                link.innerText = 'Resend Code';
            }, 5000); // 5s cooldown
        }
    });

    // Focus first box on load
    document.addEventListener('DOMContentLoaded', () => digits[0].focus());
    
    // ── Cancel Email Change ───────────────────────────────────────
    const cancelLink = document.getElementById('cancel-change-link');
    if (cancelLink) {
        cancelLink.addEventListener('click', async (e) => {
            e.preventDefault();
            KapeKanto.confirm('Discard changes and keep your current email?', async () => {
                try {
                    const res = await fetch('/api/auth/cancel-email-change', { method: 'POST' });
                    if (res.ok) {
                        KapeKanto.toast('Email change cancelled.', 'info');
                        window.location.href = '/profile';
                    }
                } catch (e) {
                    KapeKanto.toast('Failed to cancel request.', 'error');
                }
            }, { title: 'Cancel Request', confirmText: 'Yes, Discard', type: 'warning' });
        });
    }
</script>

<%- include('partials/footer') %>
