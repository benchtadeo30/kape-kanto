<%- include('partials/header') %>

    <style>
        :root {
            --contact-primary: #6f4e37;
            --contact-accent: #d2b48c;
            --contact-bg: #fafafa;
            --contact-card-bg: #ffffff;
            --contact-text: #2d2d2d;
            --contact-text-light: #666;
            --contact-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        .contact-wrapper {
            padding: 3rem 5%;
            max-width: 800px;
            margin: 0 auto;
            min-height: 80vh;
        }

        .contact-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .contact-header h1 {
            font-size: 2.5rem;
            color: var(--contact-primary);
            font-weight: 800;
            margin-bottom: 1rem;
        }

        .contact-header p {
            color: var(--contact-text-light);
            font-size: 1.1rem;
        }

        .contact-card {
            background: var(--contact-card-bg);
            border-radius: 15px;
            box-shadow: var(--contact-shadow);
            padding: 2.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: var(--contact-text);
        }

        .form-control {
            width: 100%;
            padding: 0.8rem 1rem;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-family: inherit;
            font-size: 1rem;
            transition: border-color 0.3s;
            box-sizing: border-box;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--contact-primary);
        }

        textarea.form-control {
            resize: vertical;
            min-height: 150px;
        }

        .submit-btn {
            background: var(--contact-primary);
            color: white;
            border: none;
            padding: 1rem 2rem;
            font-size: 1.1rem;
            font-weight: 600;
            border-radius: 8px;
            cursor: pointer;
            width: 100%;
            transition: background 0.3s, transform 0.2s;
        }

        .submit-btn:hover {
            background: #5a3f2d;
            transform: translateY(-2px);
        }

        .success-alert {
            background: #d4edda;
            color: #155724;
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 2rem;
            border: 1px solid #c3e6cb;
            text-align: center;
            font-weight: 600;
        }

        @media (max-width: 768px) {
            .contact-card {
                padding: 1.5rem;
            }
        }

        /* Modern Custom Select Styles */
        .custom-select-container {
            position: relative;
            user-select: none;
        }

        .custom-select-trigger {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.8rem 1.2rem;
            background: white;
            border: 1px solid #ddd;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-size: 1rem;
            color: var(--contact-text);
        }

        .custom-select-trigger:hover {
            border-color: var(--contact-primary);
            box-shadow: 0 4px 12px rgba(111, 78, 55, 0.1);
        }

        .custom-select-container.open .custom-select-trigger {
            border-color: var(--contact-primary);
            border-bottom-left-radius: 0;
            border-bottom-right-radius: 0;
            box-shadow: 0 4px 12px rgba(111, 78, 55, 0.1);
        }

        .custom-select-trigger i {
            font-size: 0.8rem;
            transition: transform 0.3s;
            color: var(--contact-primary);
        }

        .custom-select-container.open .custom-select-trigger i {
            transform: rotate(180deg);
        }

        .custom-options {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border: 1px solid var(--contact-primary);
            border-top: none;
            border-bottom-left-radius: 12px;
            border-bottom-right-radius: 12px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 100;
            overflow: hidden;
        }

        .custom-select-container.open .custom-options {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .custom-option {
            padding: 0.8rem 1.2rem;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--contact-text-light);
        }

        .custom-option i {
            width: 20px;
            text-align: center;
            font-size: 1.1rem;
            color: var(--contact-primary);
            opacity: 0.7;
        }

        .custom-option:hover {
            background: #fdfaf7;
            color: var(--contact-primary);
            padding-left: 1.5rem;
        }

        .custom-option.selected {
            background: #fdfaf7;
            color: var(--contact-primary);
            font-weight: 700;
        }
    </style>

    <div class="contact-wrapper">
        <div class="contact-header">
            <h1>Contact Us</h1>
            <p>Have a question, feedback, or suggestion? We'd love to hear from you!</p>
        </div>

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="success-alert">
                <i class="fa-solid fa-check-circle"></i> <%= success %>
            </div>
        <% } %>

        <% if (typeof user === 'undefined' || !user) { %>
            <div class="contact-card" style="text-align: center; padding: 4rem 2rem; border: 1px solid #f3e9e0;">
                <div style="font-size: 4.5rem; color: var(--contact-primary); margin-bottom: 1.5rem;">
                    <i class="fa-solid fa-lock"></i>
                </div>
                <h2 style="color: var(--contact-primary); font-weight: 800; margin-bottom: 1rem; font-size: 1.8rem;">Authentication Required</h2>
                <p style="color: var(--contact-text-light); line-height: 1.6; max-width: 500px; margin: 0 auto 2.5rem; font-size: 1.1rem;">
                    To protect our community and ensure all feedback is authentic, you must be logged in to get in touch with us.
                </p>
                <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                    <a href="/login" class="submit-btn" style="text-decoration: none; width: auto; min-width: 160px; display: inline-flex; align-items: center; justify-content: center; gap: 8px;">
                        <i class="fa-solid fa-right-to-bracket"></i> Log In
                    </a>
                    <a href="/register" class="submit-btn" style="text-decoration: none; background: transparent; border: 2px solid var(--contact-primary); color: var(--contact-primary); width: auto; min-width: 160px; display: inline-flex; align-items: center; justify-content: center; gap: 8px;">
                        <i class="fa-solid fa-user-plus"></i> Register
                    </a>
                </div>
            </div>
        <% } else { %>
            <div class="contact-card">
                <div id="contact-response" style="display: none;"></div>
                <form id="contact-form">
                    <!-- Premium Logged-in Identity Banner -->
                    <div style="background-color: #fdfaf7; border: 1px solid #f3e9e0; padding: 1.2rem 1.5rem; border-radius: 12px; margin-bottom: 2rem; display: flex; align-items: center; gap: 16px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);">
                        <% if (user.profile_image) { %>
                            <img src="<%= user.profile_image.startsWith('/') || user.profile_image.startsWith('http') || user.profile_image.startsWith('data:') ? user.profile_image : '/uploads/profiles/' + user.profile_image %>" onerror="KapeKanto.handleImageError(this, 'profiles')" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; border: 2px solid var(--contact-primary);">
                        <% } else { %>
                            <div style="width: 50px; height: 50px; border-radius: 50%; background: var(--contact-primary); display: flex; align-items: center; justify-content: center; color: white; font-weight: 800; font-size: 1.2rem;">
                                <%= user.username.charAt(0).toUpperCase() %>
                            </div>
                        <% } %>
                        <div>
                            <div style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--contact-text-light); margin-bottom: 2px;">Sending feedback as</div>
                            <div style="font-size: 1.05rem; font-weight: 700; color: var(--contact-primary);"><%= user.username %></div>
                            <div style="font-size: 0.85rem; color: var(--contact-text-light);"><%= user.email %></div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="subject">Subject</label>
                        <div class="custom-select-container" id="subject-container">
                            <div class="custom-select-trigger">
                                <span id="selected-subject">Select a subject</span>
                                <i class="fa-solid fa-chevron-down"></i>
                            </div>
                            <div class="custom-options">
                                <div class="custom-option" data-value="feedback">
                                    <i class="fa-solid fa-comments"></i> General Feedback
                                </div>
                                <div class="custom-option" data-value="support">
                                    <i class="fa-solid fa-circle-question"></i> Technical Support
                                </div>
                                <div class="custom-option" data-value="order">
                                    <i class="fa-solid fa-box-open"></i> Order Inquiry
                                </div>
                                <div class="custom-option" data-value="other">
                                    <i class="fa-solid fa-ellipsis"></i> Other
                                </div>
                            </div>
                            <input type="hidden" name="subject" id="subject-input" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea id="message" name="message" class="form-control" required placeholder="How can we help you?"></textarea>
                    </div>

                    <button type="submit" class="submit-btn" id="submit-btn">Send Message</button>
                </form>
            </div>
        <% } %>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const container = document.getElementById('subject-container');
            if (!container) return; // Exit if user is not logged in and form is not rendered
            const trigger = container.querySelector('.custom-select-trigger');
            const options = container.querySelectorAll('.custom-option');
            const selectedText = document.getElementById('selected-subject');
            const hiddenInput = document.getElementById('subject-input');

            // Toggle dropdown
            trigger.addEventListener('click', (e) => {
                container.classList.toggle('open');
                e.stopPropagation();
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', () => {
                container.classList.remove('open');
            });

            // Handle option selection
            options.forEach(option => {
                option.addEventListener('click', function() {
                    const value = this.getAttribute('data-value');
                    const text = this.innerText;
                    
                    selectedText.innerText = text;
                    hiddenInput.value = value;
                    
                    // Remove selected class from others
                    options.forEach(opt => opt.classList.remove('selected'));
                    this.classList.add('selected');
                    
                    container.classList.remove('open');
                    
                    // Visual feedback
                    trigger.style.borderColor = 'var(--contact-primary)';
                });
            });

            // Form Submission
            const form = document.getElementById('contact-form');
            const submitBtn = document.getElementById('submit-btn');
            const responseDiv = document.getElementById('contact-response');

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                // Clear previous errors
                const subjectContainer = document.getElementById('subject-container');
                if (window.removeValidationError) removeValidationError(subjectContainer);

                if (!hiddenInput.value) {
                    if (window.showValidationError) {
                        subjectContainer.setAttribute('data-error', 'Please select a subject');
                        showValidationError(subjectContainer);
                    } else {
                        KapeKanto.toast('Please select a subject.', 'warning');
                    }
                    return;
                }

                submitBtn.disabled = true;
                submitBtn.innerText = 'Sending...';
                
                const nameEl = document.getElementById('name');
                const emailEl = document.getElementById('email');
                const formData = {
                    name: nameEl ? nameEl.value : '',
                    email: emailEl ? emailEl.value : '',
                    subject: hiddenInput.value,
                    message: document.getElementById('message').value
                };

                try {
                    const response = await fetch('/contact', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formData)
                    });

                    const result = await response.json();

                    if (response.ok) {
                        responseDiv.innerHTML = `<div class="success-alert" style="margin-bottom: 2rem;"><i class="fa-solid fa-check-circle"></i> ${result.message}</div>`;
                        responseDiv.style.display = 'block';
                        form.style.display = 'none';
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                        KapeKanto.toast('Message sent successfully!', 'success');
                    } else {
                        throw new Error(result.error || 'Failed to send message');
                    }
                } catch (err) {
                    KapeKanto.toast(err.message, 'error');
                    submitBtn.disabled = false;
                    submitBtn.innerText = 'Send Message';
                }
            });
        });
    </script>

<%- include('partials/footer') %>
